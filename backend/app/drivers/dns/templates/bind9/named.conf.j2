// Generated by SpatiumDDI — do not edit by hand.
// Server: {{ server_name }}  ({{ server_id }})
// Generated at: {{ generated_at }}

{%- for acl in acls %}
acl "{{ acl.name }}" {
{%- for value, negate in acl.entries %}
    {{ "!" if negate else "" }}{{ value }};
{%- endfor %}
};
{% endfor %}

{#- Encrypted transports (issue #50). The top-level tls/http statements must
    exist before anything references them. ``tls_cert_present`` mirrors the
    agent renderer: a listener whose cert has been deleted out from under it
    degrades to Do53 rather than emitting a config named refuses to load. #}
{%- if (options.dot_enabled or options.doh_enabled) and tls_cert_present %}
tls spatium-local-tls {
    cert-file "/var/lib/spatium-dns-agent/tls/listener.crt";
    key-file "/var/lib/spatium-dns-agent/tls/listener.key";
    protocols { TLSv1.2; TLSv1.3; };
};
{%- endif %}
{%- if options.doh_enabled and tls_cert_present %}
http spatium-local-http {
    endpoints { "{{ options.doh_path }}"; };
};
{%- endif %}
{%- if options.forward_transport == "tls" %}
tls spatium-upstream-tls {
    {%- if options.forward_tls_verify and options.forward_tls_hostname %}
    ca-file "/etc/ssl/certs/ca-certificates.crt";
    remote-hostname "{{ options.forward_tls_hostname }}";
    {%- endif %}
    protocols { TLSv1.2; TLSv1.3; };
};
{%- endif %}

options {
    directory "/var/cache/bind";
    {%- if options.dot_enabled and tls_cert_present %}
    listen-on port {{ options.dot_port }} tls spatium-local-tls { any; };
    listen-on-v6 port {{ options.dot_port }} tls spatium-local-tls { any; };
    {%- endif %}
    {%- if options.doh_enabled and tls_cert_present %}
    listen-on port {{ options.doh_port }} tls spatium-local-tls http spatium-local-http { any; };
    listen-on-v6 port {{ options.doh_port }} tls spatium-local-tls http spatium-local-http { any; };
    {%- endif %}
    recursion {{ "yes" if options.recursion_enabled else "no" }};
    allow-recursion { {% for a in options.allow_recursion %}{{ a }}; {% endfor %}};
    allow-query { {% for a in options.allow_query %}{{ a }}; {% endfor %}};
    allow-query-cache { {% for a in options.allow_query_cache %}{{ a }}; {% endfor %}};
    allow-transfer { {% for a in options.allow_transfer %}{{ a }}; {% endfor %}};
    {%- if options.blackhole %}
    blackhole { {% for a in options.blackhole %}{{ a }}; {% endfor %}};
    {%- endif %}
    dnssec-validation {{ options.dnssec_validation }};
    notify {{ options.notify_enabled }};
    {%- if options.also_notify %}
    also-notify { {% for a in options.also_notify %}{{ a }}; {% endfor %}};
    {%- endif %}
    {%- if options.allow_notify %}
    allow-notify { {% for a in options.allow_notify %}{{ a }}; {% endfor %}};
    {%- endif %}
    {#- Over DoT the port defaults to 853 (RFC 7858), and each upstream
        carries the tls statement defined above. ``ip@port`` is the
        control-plane wire shape; splitting it here keeps a forwarder that
        pins a port from rendering an unloadable ``1.1.1.1@853;`` token. #}
    {%- if options.forwarders %}
    {%- set _tls_up = options.forward_transport == "tls" %}
    forwarders { {% for f in options.forwarders %}
        {%- set _ip = f.split("@")[0] %}
        {%- set _port = f.split("@")[1] if "@" in f else ("853" if _tls_up else "") %}
        {{- _ip }}{% if _port %} port {{ _port }}{% endif %}
        {%- if _tls_up %} tls spatium-upstream-tls{% endif %}; {% endfor %}};
    forward {{ options.forward_policy }};
    {%- endif %}
    {#- RRL + amplification defenses (issue #146); render only when set #}
    {%- if options.minimal_responses %}
    minimal-responses yes;
    {%- endif %}
    {%- if options.tcp_clients is not none %}
    tcp-clients {{ options.tcp_clients }};
    {%- endif %}
    {%- if options.clients_per_query is not none %}
    clients-per-query {{ options.clients_per_query }};
    {%- endif %}
    {%- if options.max_clients_per_query is not none %}
    max-clients-per-query {{ options.max_clients_per_query }};
    {%- endif %}
    {%- if options.rrl_enabled %}
    rate-limit {
        responses-per-second {{ options.rrl_responses_per_second }};
        window {{ options.rrl_window }};
        slip {{ options.rrl_slip }};
        {%- if options.rrl_qps_scale is not none %}
        qps-scale {{ options.rrl_qps_scale }};
        {%- endif %}
        {%- set _exempt = options.rrl_exempt_clients | map("trim") | select | list %}
        {%- if _exempt %}
        exempt-clients { {% for c in _exempt %}{{ c }}; {% endfor %}};
        {%- endif %}
        {%- if options.rrl_log_only %}
        log-only yes;
        {%- endif %}
    };
    {%- endif %}
};

{#- DNSSEC signing policies (issue #49). Custom policies referenced by a
    signed zone; BIND's built-in "default" needs no block. #}
{%- for p in dnssec_policies %}
dnssec-policy "{{ p.name }}" {
    keys {
        ksk lifetime {{ "unlimited" if p.ksk_lifetime_days == 0 else (p.ksk_lifetime_days|string ~ "d") }} algorithm {{ p.algorithm }};
        zsk lifetime {{ "unlimited" if p.zsk_lifetime_days == 0 else (p.zsk_lifetime_days|string ~ "d") }} algorithm {{ p.algorithm }};
    };
    {%- if p.nsec3 %}
    nsec3param iterations {{ p.nsec3_iterations }} optout {{ "yes" if p.nsec3_optout else "no" }} salt-length {{ p.nsec3_salt_length }};
    {%- endif %}
};
{% endfor %}

{%- if options.query_log_enabled %}
logging {
    channel queries_channel {
        {%- if options.query_log_channel == "file" %}
        file "{{ options.query_log_file }}" versions 5 size 50m;
        {%- elif options.query_log_channel == "syslog" %}
        syslog daemon;
        {%- else %}
        stderr;
        {%- endif %}
        severity {{ options.query_log_severity }};
        print-category {{ "yes" if options.query_log_print_category else "no" }};
        print-severity {{ "yes" if options.query_log_print_severity else "no" }};
        print-time {{ "yes" if options.query_log_print_time else "no" }};
    };
    category queries { queries_channel; };
    category query-errors { queries_channel; };
};
{%- endif %}

{%- for ta in options.trust_anchors %}
{%- if loop.first %}
trust-anchors {
{%- endif %}
    "{{ ta.zone_name }}" {{ "initial-key" if ta.is_initial_key else "static-key" }} 257 3 {{ ta.algorithm }} "{{ ta.public_key }}";
{%- if loop.last %}
};
{%- endif %}
{%- endfor %}

{%- for key in tsig_keys %}
key "{{ key.name }}" {
    algorithm {{ key.algorithm }};
    secret "{{ key.secret }}";
};
{% endfor %}

{%- if views %}
{%- for view in views %}
{# Per-view RPZ (issue #24): each view owns its blocklist + the
   response-policy directive. ``view_name == none`` is a group-level
   blocklist that applies to EVERY view; BIND9 forbids top-level
   ``zone {}`` alongside views, so RPZ can't be hoisted out. #}
{%- set view_bls = blocklists | selectattr("view_name", "in", [view.name, none]) | list %}
view "{{ view.name }}" {
    match-clients { {% for c in view.match_clients %}{{ c }}; {% endfor %}};
    {%- if view.match_destinations %}
    match-destinations { {% for c in view.match_destinations %}{{ c }}; {% endfor %}};
    {%- endif %}
    recursion {{ "yes" if view.recursion else "no" }};
    {%- if view_bls %}
    response-policy { {% for bl in view_bls %}zone "{{ bl.rpz_zone_name }}"; {% endfor %}} break-dnssec yes;
    {%- endif %}
{%- for zone in zones %}
{%- if zone.view_name == view.name %}
{{ zone_stanzas[(zone.view_name, zone.name)] | indent(4, true) }}
{%- endif %}
{%- endfor %}
{%- for bl in view_bls %}
    zone "{{ bl.rpz_zone_name }}" { type primary; file "/var/cache/bind/rpz/{{ view.name }}/{{ bl.rpz_zone_name }}db"; allow-query { none; }; };
{%- endfor %}
};
{% endfor %}
{%- else %}
{%- for zone in zones %}
{{ zone_stanzas[(zone.view_name, zone.name)] }}
{%- endfor %}
{%- for bl in blocklists %}
zone "{{ bl.rpz_zone_name }}" {
    type primary;
    file "/var/cache/bind/rpz/{{ bl.rpz_zone_name }}db";
    allow-query { none; };
};
{%- endfor %}
{%- endif %}
