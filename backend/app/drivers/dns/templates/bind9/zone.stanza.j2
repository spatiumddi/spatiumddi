{%- if zone.zone_type == "forward" %}
zone "{{ zone.name }}" {
    type forward;
    forward {{ "only" if zone.forward_only else "first" }};
    forwarders { {% for f in zone.forwarders %}{{ f }}; {% endfor %}};
};
{%- elif zone.zone_type in ("secondary", "slave", "stub") %}
zone "{{ zone.name }}" {
    type {{ "stub" if zone.zone_type == "stub" else "slave" }};
    file "/var/cache/bind/zones/{{ zone.name }}db";
    masters { {% for m in zone.masters %}{{ m.replace("@", " port ") }}; {% endfor %}};
    {%- if zone.allow_query %}
    allow-query { {% for a in zone.allow_query %}{{ a }}; {% endfor %}};
    {%- endif %}
    {%- if zone.allow_transfer %}
    allow-transfer { {% for a in zone.allow_transfer %}{{ a }}; {% endfor %}};
    {%- endif %}
};
{%- else %}
zone "{{ zone.name }}" {
    type master;
    file "/var/cache/bind/zones/{{ zone.name }}db";
    {%- if zone.dnssec_enabled and zone.zone_type == "primary" %}
    dnssec-policy "{{ zone.dnssec_policy_name or "default" }}";
    inline-signing yes;
    {%- endif %}
    {%- if zone.allow_query %}
    allow-query { {% for a in zone.allow_query %}{{ a }}; {% endfor %}};
    {%- endif %}
    {%- if zone.allow_transfer %}
    allow-transfer { {% for a in zone.allow_transfer %}{{ a }}; {% endfor %}};
    {%- endif %}
    {#- Dynamic-update (RFC 2136) ACL (issue #641). Coarse allow-update:
        grant-only IP/TSIG entries. Name-scoped / per-type / deny entries
        are the P2 update-policy path and never reach a coarse render. #}
    {%- if zone.dynamic_update_enabled and zone.update_acl %}
    {%- set _upd = [] %}
    {%- for e in zone.update_acl %}
    {%- if e.action == "grant" and not e.name_scope and not e.name_pattern and not e.record_types %}
    {%- if e.match_kind == "ip" and e.ip_cidr %}{% set _ = _upd.append(e.ip_cidr ~ ";") %}
    {%- elif e.match_kind == "tsig_key" and e.tsig_key_name %}{% set _ = _upd.append('key "' ~ e.tsig_key_name ~ '";') %}
    {%- endif %}
    {%- endif %}
    {%- endfor %}
    {%- if _upd %}
    allow-update { {{ _upd | join(" ") }} };
    {%- endif %}
    {%- endif %}
    {%- if zone.also_notify %}
    also-notify { {% for a in zone.also_notify %}{{ a }}; {% endfor %}};
    {%- endif %}
    {%- if zone.notify_enabled %}
    notify {{ zone.notify_enabled }};
    {%- endif %}
};
{%- endif %}
