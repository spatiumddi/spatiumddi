{
  "family": "ipv4",
  "source": "RFC 2132 + IANA bootp-dhcp-parameters",
  "options": [
    { "code": 1,   "name": "subnet-mask",            "kind": "ipv4-address", "rfc": "RFC 2132", "description": "Subnet mask (legacy — Kea derives this from the subnet itself; setting explicitly is rarely needed)." },
    { "code": 2,   "name": "time-offset",            "kind": "int32",        "rfc": "RFC 2132", "description": "Client offset from UTC in seconds (deprecated — use NTP)." },
    { "code": 3,   "name": "routers",                "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "Default gateway(s) for clients on this scope." },
    { "code": 4,   "name": "time-servers",           "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "Time-protocol (RFC 868) servers — almost never used; prefer NTP (option 42)." },
    { "code": 5,   "name": "name-servers",           "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "IEN 116 name servers — historical, prefer DNS (option 6)." },
    { "code": 6,   "name": "domain-name-servers",    "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "DNS resolver IP list (most clients use the first 3)." },
    { "code": 7,   "name": "log-servers",            "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "MIT-LCS UDP log servers — historical." },
    { "code": 8,   "name": "cookie-servers",         "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "RFC 865 quote-of-the-day servers — historical." },
    { "code": 9,   "name": "lpr-servers",            "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "Line printer (RFC 1179) servers." },
    { "code": 10,  "name": "impress-servers",        "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "Imagen Impress servers — historical." },
    { "code": 11,  "name": "resource-location-servers","kind": "ipv4-list",  "rfc": "RFC 2132", "description": "RFC 887 resource-location-protocol servers." },
    { "code": 12,  "name": "host-name",              "kind": "string",       "rfc": "RFC 2132", "description": "Client hostname (server-supplied — usually client-supplied via option 12 in DISCOVER)." },
    { "code": 13,  "name": "boot-size",              "kind": "uint16",       "rfc": "RFC 2132", "description": "Boot file length in 512-byte blocks." },
    { "code": 14,  "name": "merit-dump",             "kind": "string",       "rfc": "RFC 2132", "description": "Path of the file to dump core to." },
    { "code": 15,  "name": "domain-name",            "kind": "string",       "rfc": "RFC 2132", "description": "DNS search-suffix domain (single domain — multiple via option 119)." },
    { "code": 16,  "name": "swap-server",            "kind": "ipv4-address", "rfc": "RFC 2132", "description": "Diskless workstation swap server." },
    { "code": 17,  "name": "root-path",              "kind": "string",       "rfc": "RFC 2132", "description": "NFS root path for diskless boot." },
    { "code": 18,  "name": "extensions-path",        "kind": "string",       "rfc": "RFC 2132", "description": "TFTP path to extension options." },
    { "code": 19,  "name": "ip-forwarding",          "kind": "uint8",        "rfc": "RFC 2132", "description": "Enable IP forwarding on client (0/1)." },
    { "code": 20,  "name": "non-local-source-routing","kind": "uint8",        "rfc": "RFC 2132", "description": "Enable non-local source routing (0/1)." },
    { "code": 21,  "name": "policy-filter",          "kind": "ipv4-pair-list","rfc": "RFC 2132", "description": "Policy filter (address/mask pairs)." },
    { "code": 22,  "name": "max-dgram-reassembly",   "kind": "uint16",       "rfc": "RFC 2132", "description": "Maximum datagram reassembly size." },
    { "code": 23,  "name": "default-ip-ttl",         "kind": "uint8",        "rfc": "RFC 2132", "description": "Default IP TTL for outgoing packets." },
    { "code": 24,  "name": "path-mtu-aging-timeout", "kind": "uint32",       "rfc": "RFC 2132", "description": "Path MTU aging timeout (seconds)." },
    { "code": 25,  "name": "path-mtu-plateau-table", "kind": "uint16-list",  "rfc": "RFC 2132", "description": "Path MTU plateau values." },
    { "code": 26,  "name": "interface-mtu",          "kind": "uint16",       "rfc": "RFC 2132", "description": "MTU for the client's interface (e.g. 1500, 9000 for jumbo)." },
    { "code": 27,  "name": "all-subnets-local",      "kind": "uint8",        "rfc": "RFC 2132", "description": "All subnets share the same MTU (0/1)." },
    { "code": 28,  "name": "broadcast-address",      "kind": "ipv4-address", "rfc": "RFC 2132", "description": "Subnet broadcast address (Kea derives this; rarely set manually)." },
    { "code": 29,  "name": "perform-mask-discovery", "kind": "uint8",        "rfc": "RFC 2132", "description": "Run ICMP mask-discovery (0/1)." },
    { "code": 30,  "name": "mask-supplier",          "kind": "uint8",        "rfc": "RFC 2132", "description": "Respond to ICMP mask-request (0/1)." },
    { "code": 31,  "name": "router-discovery",       "kind": "uint8",        "rfc": "RFC 2132", "description": "Run ICMP router-discovery (0/1)." },
    { "code": 32,  "name": "router-solicitation-address","kind": "ipv4-address","rfc": "RFC 2132","description": "ICMP router solicitation destination." },
    { "code": 33,  "name": "static-routes",          "kind": "ipv4-pair-list","rfc": "RFC 2132", "description": "Static route list (destination/router pairs) — superseded by option 121 (classless)." },
    { "code": 34,  "name": "trailer-encapsulation",  "kind": "uint8",        "rfc": "RFC 2132", "description": "Trailer-encapsulation (0/1) — historical." },
    { "code": 35,  "name": "arp-cache-timeout",      "kind": "uint32",       "rfc": "RFC 2132", "description": "ARP cache timeout in seconds." },
    { "code": 36,  "name": "ieee802-3-encapsulation","kind": "uint8",        "rfc": "RFC 2132", "description": "Use IEEE 802.3 encapsulation (0/1)." },
    { "code": 37,  "name": "default-tcp-ttl",        "kind": "uint8",        "rfc": "RFC 2132", "description": "Default TCP TTL." },
    { "code": 38,  "name": "tcp-keepalive-interval", "kind": "uint32",       "rfc": "RFC 2132", "description": "TCP keepalive interval (seconds)." },
    { "code": 39,  "name": "tcp-keepalive-garbage",  "kind": "uint8",        "rfc": "RFC 2132", "description": "Send TCP keepalive garbage byte (0/1)." },
    { "code": 40,  "name": "nis-domain",             "kind": "string",       "rfc": "RFC 2132", "description": "NIS (YP) domain name." },
    { "code": 41,  "name": "nis-servers",            "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "NIS (YP) server list." },
    { "code": 42,  "name": "ntp-servers",            "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "NTP time-sync servers — required for Kerberos, TLS, audit accuracy." },
    { "code": 43,  "name": "vendor-encapsulated-options", "kind": "binary",  "rfc": "RFC 2132", "description": "Vendor-specific encapsulated options (paired with option 60)." },
    { "code": 44,  "name": "netbios-name-servers",   "kind": "ipv4-list",    "rfc": "RFC 1001/2132", "description": "NetBIOS over TCP/IP name servers (WINS)." },
    { "code": 45,  "name": "netbios-dd-server",      "kind": "ipv4-list",    "rfc": "RFC 1001/2132", "description": "NetBIOS datagram-distribution servers." },
    { "code": 46,  "name": "netbios-node-type",      "kind": "uint8",        "rfc": "RFC 1001/2132", "description": "NetBIOS node type (1=B, 2=P, 4=M, 8=H)." },
    { "code": 47,  "name": "netbios-scope",          "kind": "string",       "rfc": "RFC 1001/2132", "description": "NetBIOS scope identifier." },
    { "code": 48,  "name": "font-servers",           "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "X Window System font servers." },
    { "code": 49,  "name": "x-display-manager",      "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "X Window System display managers." },
    { "code": 50,  "name": "dhcp-requested-address", "kind": "ipv4-address", "rfc": "RFC 2132", "description": "Client-supplied requested IP — never server-set." },
    { "code": 51,  "name": "dhcp-lease-time",        "kind": "uint32",       "rfc": "RFC 2132", "description": "Lease duration (seconds) — Kea drives this from scope.lease_time." },
    { "code": 52,  "name": "dhcp-option-overload",   "kind": "uint8",        "rfc": "RFC 2132", "description": "Reuse sname/file fields for options (1/2/3)." },
    { "code": 53,  "name": "dhcp-message-type",      "kind": "uint8",        "rfc": "RFC 2132", "description": "DHCP message type (DISCOVER/OFFER/etc.) — protocol-internal." },
    { "code": 54,  "name": "dhcp-server-identifier", "kind": "ipv4-address", "rfc": "RFC 2132", "description": "DHCP server identifier — Kea sets this automatically." },
    { "code": 55,  "name": "dhcp-parameter-request-list", "kind": "uint8-list", "rfc": "RFC 2132", "description": "Client-supplied request list (option 55) — used for fingerprinting." },
    { "code": 56,  "name": "dhcp-message",           "kind": "string",       "rfc": "RFC 2132", "description": "Server error/decline message." },
    { "code": 57,  "name": "dhcp-max-message-size",  "kind": "uint16",       "rfc": "RFC 2132", "description": "Maximum DHCP message size client accepts." },
    { "code": 58,  "name": "dhcp-renewal-time",      "kind": "uint32",       "rfc": "RFC 2132", "description": "T1 renewal timer (seconds) — Kea derives from lease_time." },
    { "code": 59,  "name": "dhcp-rebinding-time",    "kind": "uint32",       "rfc": "RFC 2132", "description": "T2 rebinding timer (seconds) — Kea derives from lease_time." },
    { "code": 60,  "name": "vendor-class-identifier","kind": "string",       "rfc": "RFC 2132", "description": "Client-supplied vendor class identifier (paired with option 43)." },
    { "code": 61,  "name": "dhcp-client-identifier", "kind": "binary",       "rfc": "RFC 2132", "description": "Client-supplied client identifier — used for reservations." },
    { "code": 64,  "name": "nis-domain-name",        "kind": "string",       "rfc": "RFC 2132", "description": "NIS+ (NISv3) domain name." },
    { "code": 65,  "name": "nis-server-addr",        "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "NIS+ server list." },
    { "code": 66,  "name": "tftp-server-name",       "kind": "string",       "rfc": "RFC 2132", "description": "TFTP server hostname (PXE / firmware download)." },
    { "code": 67,  "name": "boot-file-name",         "kind": "string",       "rfc": "RFC 2132", "description": "Boot file name (PXE / iPXE chainload target)." },
    { "code": 68,  "name": "mobile-ip-home-agent",   "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "Mobile-IP home agents." },
    { "code": 69,  "name": "smtp-server",            "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "SMTP servers." },
    { "code": 70,  "name": "pop-server",             "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "POP3 servers." },
    { "code": 71,  "name": "nntp-server",            "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "NNTP news servers." },
    { "code": 72,  "name": "www-server",             "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "Default WWW server (historical)." },
    { "code": 73,  "name": "finger-server",          "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "Finger server (historical)." },
    { "code": 74,  "name": "irc-server",             "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "IRC servers." },
    { "code": 75,  "name": "streettalk-server",      "kind": "ipv4-list",    "rfc": "RFC 2132", "description": "StreetTalk servers (historical)." },
    { "code": 76,  "name": "streettalk-directory-assistance-server","kind": "ipv4-list","rfc": "RFC 2132","description": "StreetTalk directory assistance servers." },
    { "code": 77,  "name": "user-class",             "kind": "binary",       "rfc": "RFC 3004", "description": "Client user class (used in client-class predicates)." },
    { "code": 81,  "name": "fqdn",                   "kind": "binary",       "rfc": "RFC 4702", "description": "Client FQDN — drives DDNS hostname when policy is `client`." },
    { "code": 82,  "name": "dhcp-agent-options",     "kind": "binary",       "rfc": "RFC 3046", "description": "Relay agent information (circuit-id / remote-id / sub-options) — set by relays, not the server." },
    { "code": 88,  "name": "v4-sip-servers-dns-rrs", "kind": "binary",       "rfc": "RFC 3361", "description": "SIP servers (DNS RR encoding)." },
    { "code": 89,  "name": "v4-sip-servers-addr",    "kind": "ipv4-list",    "rfc": "RFC 3361", "description": "SIP servers (address list)." },
    { "code": 93,  "name": "client-system",          "kind": "uint16",       "rfc": "RFC 4578", "description": "Client system architecture type (0=BIOS x86, 6=EFI x86, 7=EFI x86-64, 9=EFI BC, 10=EFI ARM32, 11=EFI ARM64) — drives PXE per-arch matching." },
    { "code": 94,  "name": "client-ndi",             "kind": "binary",       "rfc": "RFC 4578", "description": "Client network interface identifier (PXE)." },
    { "code": 97,  "name": "uuid-guid",              "kind": "binary",       "rfc": "RFC 4578", "description": "Client machine UUID/GUID (PXE)." },
    { "code": 100, "name": "pcode",                  "kind": "string",       "rfc": "RFC 4833", "description": "POSIX timezone string (e.g. EST5EDT,M3.2.0,M11.1.0)." },
    { "code": 101, "name": "tcode",                  "kind": "string",       "rfc": "RFC 4833", "description": "TZ database name (e.g. America/New_York)." },
    { "code": 119, "name": "domain-search",          "kind": "fqdn-list",    "rfc": "RFC 3397", "description": "DNS domain search list (multiple suffixes)." },
    { "code": 120, "name": "sip-server",             "kind": "binary",       "rfc": "RFC 3361", "description": "SIP server FQDN/address — alternative encoding." },
    { "code": 121, "name": "classless-static-route", "kind": "binary",       "rfc": "RFC 3442", "description": "Classless static routes — preferred over option 33 (which is classful)." },
    { "code": 125, "name": "vivso",                  "kind": "binary",       "rfc": "RFC 3925", "description": "Vendor-identifying vendor-specific information option (VI-VSIO)." },
    { "code": 150, "name": "tftp-server-address",    "kind": "ipv4-list",    "rfc": "RFC 5859", "description": "TFTP server IP list (Cisco IP phones)." },
    { "code": 159, "name": "v4-portparams",          "kind": "binary",       "rfc": "RFC 7618", "description": "PCP-related port parameters." },
    { "code": 160, "name": "v4-captive-portal",      "kind": "string",       "rfc": "RFC 7710", "description": "Captive-portal URL (deprecated; use 114)." },
    { "code": 114, "name": "captive-portal",         "kind": "string",       "rfc": "RFC 8910", "description": "Captive-portal API endpoint (replaces option 160)." },
    { "code": 209, "name": "config-file",            "kind": "string",       "rfc": "RFC 5071", "description": "PXELINUX/iPXE config file path." },
    { "code": 210, "name": "path-prefix",            "kind": "string",       "rfc": "RFC 5071", "description": "PXELINUX/iPXE path prefix." },
    { "code": 211, "name": "reboot-time",            "kind": "uint32",       "rfc": "RFC 5071", "description": "PXELINUX reboot time (seconds)." }
  ]
}
