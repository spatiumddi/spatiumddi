[Unit]
Description=Apply pending SpatiumDDI slot upgrade (Phase 8b-3)
Documentation=https://github.com/spatiumddi/spatiumddi/issues/138
# No docker dependency — slot upgrade writes to a block device, not
# any container.

[Service]
Type=oneshot
ExecStart=/usr/local/bin/spatiumddi-slot-upgrade
# No Install section — only invoked by the matching .path unit, never
# directly enabled at boot.
