# Wildcard DHCP for any ethernet-style interface. Bakes a sensible
# default into the appliance image so a plain CD-ROM live boot (no
# cloud-init datasource attached) still gets an IP, and so the qcow2
# disk path works without depending on cloud-init's network config.
# Operators wanting static IPs / VLANs / bonds drop their own
# *.network file at a lower lex-order prefix (10-…) to override.

[Match]
Name=en* eth*

[Network]
DHCP=yes
IPv6AcceptRA=yes
