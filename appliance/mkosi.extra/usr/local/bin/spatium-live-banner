#!/bin/sh
# spatium-live-banner — replaces the auto-login getty on tty1 in
# live mode. Shows the appliance status and a one-line install hint.
# Loops on read so it persists; Ctrl-C drops to a root shell.
set -eu

clear
cat <<'BANNER'
  ____             _   _                  ____  ____  ___
 / ___| _ __   __ _| |_(_)_   _ _ __ ___ |  _ \|  _ \|_ _|
 \___ \| '_ \ / _` | __| | | | | '_ ` _ \| |_) | | | || |
  ___) | |_) | (_| | |_| | |_| | | | | | |  __/| |_| || |
 |____/| .__/ \__,_|\__|_|\__,_|_| |_| |_|_|   |____/|___|
       |_|

 SpatiumDDI Appliance — live mode (running from CD/USB, no install).

BANNER

IP=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)
if [ -n "$IP" ]; then
    echo "   Web UI:   http://$IP/"
else
    echo "   Web UI:   (waiting for network — check 'ip a')"
fi
echo "   Default:  admin / admin   (forces password change on first login)"
echo
echo "   First-boot orchestrator status:"
echo "     systemctl status spatiumddi-firstboot"
echo "     tail -f /var/log/spatiumddi/firstboot.log"
echo
echo "─────────────────────────────────────────────────────────────────"
echo
echo "   To install to disk:    sudo spatium-install"
echo "   To get a shell:        press Enter, then Ctrl-D when done"
echo
while true; do
    printf "Press Enter to refresh, or type 'install' / 'shell' / 'reboot': "
    if ! read -r action; then
        sleep 5
        continue
    fi
    case "$action" in
        install) exec /usr/local/bin/spatium-install ;;
        shell)   exec /bin/bash --login ;;
        reboot)  systemctl reboot ;;
        *)       exec "$0" ;;
    esac
done
