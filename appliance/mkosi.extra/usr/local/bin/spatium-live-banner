#!/bin/sh
# spatium-live-banner — replaces the auto-login getty on tty1 in
# rescue / diagnostics mode (spatium-mode=live). This is NOT a running
# SpatiumDDI — k3s + firstboot are gated ``!boot=live``, so nothing
# serves the Web UI here. It's a recovery environment for repairing an
# unbootable install or capturing diagnostics. Loops on read so it
# persists; Ctrl-C drops to a root shell.
set -eu

clear
cat <<'BANNER'
  ____             _   _                  ____  ____  ___
 / ___| _ __   __ _| |_(_)_   _ _ __ ___ |  _ \|  _ \|_ _|
 \___ \| '_ \ / _` | __| | | | | '_ ` _ \| |_) | | | || |
  ___) | |_) | (_| | |_| | |_| | | | | | |  __/| |_| || |
 |____/| .__/ \__,_|\__|_|\__,_|_| |_| |_|_|   |____/|___|
       |_|

 SpatiumDDI Appliance - RESCUE / DIAGNOSTICS shell (from CD/USB).
 This does NOT run SpatiumDDI: no k3s, no control plane, no Web UI.
 Use it to recover an install or capture diagnostics, then reboot.

BANNER

IP=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)
if [ -n "$IP" ]; then
    echo "   SSH in:   ssh root@$IP"
else
    echo "   SSH in:   (waiting for network - check 'ip a')"
fi
# spatium-live-bootstrap generated a one-time root password for this
# session and wrote it here (world-readable, never reaches a disk).
PWFILE=/var/log/spatium-live-ssh-password
if [ -r "$PWFILE" ]; then
    echo "   Password: $(cat "$PWFILE")   (random, this session only)"
fi
echo
echo "   Recover an installed system (it's on the disk, not here):"
echo "     lsblk -o NAME,PARTLABEL,FSTYPE,SIZE   # find root_A / root_B / var"
echo "     mkdir -p /mnt/r && mount /dev/disk/by-partlabel/root_A /mnt/r"
echo "     mount /dev/disk/by-partlabel/var /mnt/r/var   # firstboot/k3s logs"
echo "     less /mnt/r/var/log/spatiumddi/firstboot.log"
echo
echo "================================================================="
echo
echo "   Re-install to disk:    sudo spatium-install"
echo "   Get a shell:           press Enter, then Ctrl-D when done"
echo
while true; do
    printf "Press Enter to refresh, or type 'install' / 'shell' / 'reboot': "
    if ! read -r action; then
        sleep 5
        continue
    fi
    case "$action" in
        install) exec /usr/local/bin/spatium-install ;;
        shell)   exec /bin/bash --login ;;
        reboot)  systemctl reboot ;;
        *)       exec "$0" ;;
    esac
done
