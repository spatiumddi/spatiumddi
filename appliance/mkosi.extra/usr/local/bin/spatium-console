#!/usr/bin/env python3
# Phase 4h appliance console dashboard (issue #134). Replaces
# getty@tty1 on the installed appliance with a Talos-style
# auto-refreshing view: header / per-role services pane /
# live journalctl tail / F-key footer.
#
# Service: /etc/systemd/system/spatium-console.service (tty1) plus
# the spatium-console@.service template for serial consoles.
# F1 hands off to agetty for traditional login (the only way to
# get a shell on this appliance — by design). F5 / F6 reboot /
# poweroff with a confirm modal. F2 / F3 / F4 surface operator-
# useful read-only views (htop / docker stats / nmtui). F8 re-pairs
# the appliance against a fresh pairing code.
#
# Role-awareness reads APPLIANCE_ROLE from /etc/spatiumddi/.env —
# the same value spatiumddi-firstboot writes after the installer
# wizard picked a role. Three roles: full-stack / frontend-core /
# application. Each role gets a different Services pane.

from __future__ import annotations

import argparse
import json
import os
import re
import select
import signal
import subprocess
import sys
import termios
import threading
import time
import tty
from collections import deque
from datetime import datetime
from pathlib import Path
from typing import Iterable

import psutil
from rich.align import Align
from rich.box import SQUARE
from rich.console import Console, Group
from rich.layout import Layout
from rich.live import Live
from rich.panel import Panel
from rich.rule import Rule
from rich.table import Table
from rich.text import Text


ENV_FILE = Path("/etc/spatiumddi/.env")
FIRSTBOOT_LOG = Path("/var/log/spatiumddi/firstboot.log")
FIRSTBOOT_STAMP = Path("/var/lib/spatiumddi/firstboot.done")
APPLIANCE_RELEASE = Path("/etc/spatiumddi/appliance-release")


ROLE_LABELS = {
    "full-stack": "Full stack — control plane + BIND9 + Kea (AIO)",
    "frontend-core": "Frontend / core — control plane only",
    "application": "Application — supervisor (pairs remote)",
}

# Container service names we render per role. Names match the
# docker-compose service-name; spatiumddi-firstboot's COMPOSE_PROFILES
# already decides which subset actually runs, but we render the full
# expected set so a missing-from-`docker ps` service shows up as
# `(not running)` instead of being silently absent.
ROLE_SERVICES = {
    "full-stack": [
        "postgres", "redis", "migrate", "api", "worker", "beat",
        "frontend", "dns-bind9", "dhcp-kea",
    ],
    "frontend-core": [
        "postgres", "redis", "migrate", "api", "worker", "beat", "frontend",
    ],
    # Application = supervisor + the agent-landing static page. The
    # service container (dns-bind9 / dns-powerdns / dhcp-kea) starts
    # only after admin approval + role assignment in the fleet UI
    # (#170 Wave C); render_services unions any role-supervised
    # container currently in ``docker ps`` so the operator sees them
    # when they're running, without cluttering the dashboard with
    # ``(not running)`` rows for roles the supervisor hasn't been
    # given.
    "application": ["spatium-supervisor", "agent-landing"],
}

# Compose service names the supervisor manages dynamically (#170
# Wave C+). On an Application appliance these only show up after
# admin approval + role assignment, so the dashboard unions whichever
# of these is actually in ``docker ps`` onto the base
# ``ROLE_SERVICES["application"]`` list rather than rendering a
# permanent ``(not running)`` row for every unassigned role.
SUPERVISOR_DYNAMIC_SERVICES = ("dns-bind9", "dns-powerdns", "dhcp-kea")

# Supervisor's role-compose.env on the host (the dashboard reads it
# read-only to discover the watchdog-expected services so a
# missing-but-expected container renders as "(not running)" instead
# of silently absent). The supervisor writes this file atomically on
# every heartbeat that returns a role_assignment.
_SUPERVISOR_ROLE_ENV = Path("/var/persist/spatium-supervisor/role-compose.env")

# Compose profile → compose service name. Mirrors the supervisor's
# own ``watchdog._PROFILE_TO_SERVICE`` map — keep them in sync.
_PROFILE_TO_SERVICE_DASH: dict[str, str] = {
    "dns-bind9": "dns-bind9",
    "dns-powerdns": "dns-powerdns",
    "dhcp": "dhcp-kea",
}


# External supervisor watchdog (#170 Wave E) — host-side bash
# script + systemd timer that restarts the supervisor container when
# its main loop wedges (different signal from the
# in-process watchdog which only watches the supervisor-managed
# service containers). The supervisor writes ``last-loop-at`` at the
# top of every heartbeat-loop iteration; the host timer checks that
# mtime every 2 min and force-restarts the container if it's
# >5 min stale. Surface a one-line status so the operator at the
# physical console can see at a glance whether the loop is ticking.
_SUPERVISOR_LIVENESS_FILE = Path("/var/persist/spatium-supervisor/last-loop-at")
_SUPERVISOR_WATCHDOG_ALERT = Path(
    "/var/lib/spatiumddi/release-state/supervisor-watchdog-alert"
)


def supervisor_watchdog_status() -> tuple[str, str] | None:
    """Return a ``(label, rich-style)`` tuple summarising the
    external watchdog state, or ``None`` when nothing useful to show
    (non-application role, or supervisor never started).

    Three outcomes:

    * ``Loop ticking · N s ago`` (green) — liveness file fresh.
    * ``Loop stale · N s ago`` (yellow) — liveness file older than
      the heartbeat interval; the host timer will restart on its
      next fire.
    * ``Restart cap hit`` (red) — alert trigger file present; the
      external watchdog gave up after MAX_RESTARTS_PER_WINDOW.
    """
    # Alert trigger trumps the staleness check — operator needs to
    # see the bad-news state regardless of what the liveness file
    # currently says.
    if _SUPERVISOR_WATCHDOG_ALERT.exists():
        return ("Restart cap hit — manual intervention required", "bold red")
    if not _SUPERVISOR_LIVENESS_FILE.exists():
        return None
    try:
        mtime = _SUPERVISOR_LIVENESS_FILE.stat().st_mtime
    except OSError:
        return None
    age = int(time.time() - mtime)
    if age < 0:
        age = 0
    # The host-side script's STALE_THRESHOLD_S is 300 s; use the
    # same threshold here so the chip flips colour at the same
    # moment the host watchdog decides to act.
    if age >= 300:
        return (f"Loop stale · {age}s ago", "bold yellow")
    return (f"Loop ticking · {age}s ago", "bold green")


def watchdog_expected_services() -> list[str]:
    """Read the supervisor's role-compose.env to discover which
    service containers the watchdog expects to be running.

    Returns ``[]`` on missing file, empty COMPOSE_PROFILES, or any
    read error. Used by ``render_frame`` to union the
    watchdog-expected set into the dashboard's Services panel so a
    crashed / removed container surfaces as "(not running)" rather
    than disappearing entirely.
    """
    if not _SUPERVISOR_ROLE_ENV.exists():
        return []
    try:
        for line in _SUPERVISOR_ROLE_ENV.read_text(encoding="utf-8").splitlines():
            if line.startswith("COMPOSE_PROFILES="):
                val = line.split("=", 1)[1].strip()
                if not val:
                    return []
                services: list[str] = []
                for p in val.split(","):
                    svc = _PROFILE_TO_SERVICE_DASH.get(p.strip())
                    if svc is not None:
                        services.append(svc)
                return services
    except OSError:
        pass
    return []

# journalctl units the live-log pane tails. Same set on every role —
# operators want to see firstboot / k3s / reboot output regardless of
# which pods ran. k3s.service captures cluster-level events; per-pod
# logs come from ``kubectl logs`` (via the journal too once
# ``log-level=info`` is set, but that's noisier than the per-unit
# tail this surface aims for).
JOURNAL_UNITS = [
    "k3s.service",
    "spatiumddi-firstboot.service",
    "spatiumddi-reboot.service",
    "spatium-console.service",
]

# 0.5 s (2 Hz) is plenty for a system dashboard. The previous 0.25 s
# (4 Hz) tick combined with Rich Live's default auto-refresh thread
# (also 4 Hz) produced two full-layout re-renders per tick and burned
# ~90 % of a CPU on a 1-CPU appliance VM. Spinner animation stays
# usable at 2 Hz.
REFRESH_INTERVAL = 0.5
VITALS_EVERY = 1.0       # seconds — CPU / RAM / Load / clock / disk poll
# 5 s (not 2 s) so a slow ``docker ps`` (parsing JSON output of every
# container on a 1-CPU VM can take >3 s) doesn't starve the rest of
# the loop. The previous 2 s cadence + 3 s subprocess timeout created
# a feedback loop where every dashboard tick timed out dockerd mid-
# response, which dockerd then logged as "superfluous
# response.WriteHeader call from go.opentelemetry.io/contrib/
# instrumentation/..." — the loop kept itself fed because the console
# tails docker.service journal output and re-rendered those errors
# in its live-log pane.
DATA_REFRESH_EVERY = 5.0
SPINNER_CHARS = "|/-\\"


# ── env / role detection ──────────────────────────────────────────────


def read_env(path: Path = ENV_FILE) -> dict[str, str]:
    if not path.exists():
        return {}
    out: dict[str, str] = {}
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        out[k.strip()] = v.strip()
    return out


def role_from_env(env: dict[str, str]) -> str:
    raw = (env.get("APPLIANCE_ROLE") or "full-stack").strip()
    return raw if raw in ROLE_LABELS else "full-stack"


def role_label(role: str) -> str:
    return ROLE_LABELS.get(role, role)


# ── k3s pod state ─────────────────────────────────────────────────────
#
# Issue #183 Phase 7/8 — the appliance is k3s-only; this used to talk
# to /var/run/docker.sock + parse ``docker ps`` output. Now we query
# the local kubeapi via ``kubectl get pods -o json`` and translate
# the pod shape into the dict shape the downstream renderer already
# expects (``Names`` / ``Image`` / ``Status`` / ``Labels`` / ``State`` /
# ``Ports`` / ``NetworkMode``). Keeping the same shape means the
# Services-row renderer + service-name parser + watchdog status reader
# all keep working unchanged.


_STATUS_HEALTH_RE = re.compile(r"\(([^)]+)\)")


def docker_ps() -> list[dict]:
    """Return every pod on the local cluster via
    ``kubectl get pods -A -o json``, translated into the docker-ps
    dict shape the rest of the console expects.

    Function name kept as ``docker_ps`` so the rest of the renderer
    code doesn't have to change. Pre-Phase-7 this hit
    /var/run/docker.sock directly; now it shells to the local k3s
    binary's embedded kubectl. ~50 ms per call (fork + JSON parse)
    is fine for the dashboard's 2 s refresh cadence.

    Returns every namespace's pods (was previously filtered to
    ``spatium`` + a chart label) so the dashboard surfaces
    kube-system add-ons (coredns / local-path / helm-install) +
    anything operators kubectl-applied themselves.

    Returns [] on any failure (k3s not running, kubeconfig missing).
    """
    try:
        proc = subprocess.run(
            [
                "/usr/local/bin/k3s",
                "kubectl",
                "get",
                "pods",
                "-A",
                "-o",
                "json",
            ],
            env={
                **os.environ,
                "KUBECONFIG": "/etc/rancher/k3s/k3s.yaml",
            },
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        return []
    if proc.returncode != 0:
        return []
    try:
        data = json.loads(proc.stdout)
    except (json.JSONDecodeError, ValueError):
        return []
    out: list[dict] = []
    for pod in data.get("items") or []:
        meta = pod.get("metadata") or {}
        spec = pod.get("spec") or {}
        status = pod.get("status") or {}
        phase = status.get("phase") or "Unknown"
        containers = spec.get("containers") or []
        first = containers[0] if containers else {}
        labels = meta.get("labels") or {}

        # Derive a docker-ps-style ``Status`` string. The renderer's
        # ``health_from_status`` reads the trailing ``(healthy)`` /
        # ``(unhealthy)`` / ``(health: starting)`` marker, so we
        # synthesise one from the pod's container readiness +
        # waiting-reason. Mirrors what the watchdog does in
        # ``_derive_pod_status``.
        container_statuses = status.get("containerStatuses") or []
        if phase == "Running" and container_statuses:
            all_ready = all(cs.get("ready") for cs in container_statuses)
            if all_ready:
                status_str = "Running (healthy)"
                state_str = "running"
            else:
                # Find any waiting-reason for the unhealthy marker.
                reason = ""
                for cs in container_statuses:
                    if cs.get("ready"):
                        continue
                    waiting = (cs.get("state") or {}).get("waiting") or {}
                    reason = (waiting.get("reason") or "").lower()
                    if reason:
                        break
                if reason in ("crashloopbackoff", "errimagepull", "imagepullbackoff"):
                    status_str = f"Running (unhealthy: {reason})"
                else:
                    status_str = "Running (health: starting)"
                state_str = "running"
        elif phase == "Pending":
            status_str = "Pending (health: starting)"
            state_str = "starting"
        elif phase in ("Failed", "Succeeded"):
            status_str = f"{phase} (unhealthy)"
            state_str = "exited"
        else:
            status_str = phase
            state_str = phase.lower()

        # Translate container ports → docker-ps ``Ports`` shape.
        # Pre-Phase-7 ``PublicPort`` was the host-side mapping; k3s
        # uses host ports only for ``hostNetwork: true`` pods, which
        # we mark as NetworkMode=host so the renderer collapses the
        # whole row to ``host net`` regardless of the ports list.
        ports_out: list[dict] = []
        for c in containers:
            for p in c.get("ports") or []:
                cport = p.get("containerPort")
                proto = p.get("protocol") or "TCP"
                if cport is None:
                    continue
                ports_out.append(
                    {
                        "PrivatePort": cport,
                        "PublicPort": cport if spec.get("hostNetwork") else None,
                        "Type": proto.lower(),
                    }
                )

        out.append(
            {
                "Names": meta.get("name") or "",
                "Namespace": meta.get("namespace") or "",
                "Image": (first.get("image") or "") if first else "",
                "Status": status_str,
                "Labels": labels,
                "State": state_str,
                "Ports": ports_out,
                "NetworkMode": "host" if spec.get("hostNetwork") else "default",
            }
        )

    # Plus the supervisor pod from the kube-system / spatium
    # namespace — query it separately since its labels match the
    # selector above only on the same chart.
    return out


def container_port_summary(row: dict) -> str:
    """Return a compact ports / network-mode string for the Services
    column.

    Output shapes:

    * ``host net`` — container in ``NetworkMode=host`` (DHCP-kea
      runs here for broadcast-relay reachability).
    * ``53/tcp 53/udp`` — bridge-mode container with published
      ports; dedupes IPv4/IPv6 entries that the engine API returns
      twice for the same port.
    * ``""`` (empty) — no published ports + not host mode (the
      supervisor itself, internal-only containers).
    """
    if row.get("NetworkMode") == "host":
        return "host net"
    pairs: set[tuple[int, str]] = set()
    for p in row.get("Ports") or []:
        pub = p.get("PublicPort")
        # Skip rows without a PublicPort — those are exposed-only
        # (declared in EXPOSE but not published to host). The
        # operator-visible signal is "what's reachable from outside
        # the container", which only matters when PublicPort is set.
        if pub is None:
            continue
        ptype = p.get("Type") or "tcp"
        pairs.add((int(pub), str(ptype)))
    if not pairs:
        return ""
    return " ".join(f"{port}/{proto}" for port, proto in sorted(pairs))


def container_service_name(row: dict) -> str:
    """Pull the logical service name (``dns-bind9`` / ``dhcp-kea`` /
    ``spatium-supervisor``) out of a ps row.

    Phase 7: rows now come from k3s pods. The chart labels every pod
    with ``app.kubernetes.io/component=<name>``, so we read that
    first. Falls back to the bare ``Names`` field (or pod name) when
    the label isn't present — covers pre-Phase-7-compatible callers
    + any operator-deployed pods that bypassed the chart.
    """
    labels = row.get("Labels") or {}
    if isinstance(labels, dict):
        component = labels.get("app.kubernetes.io/component")
        if component:
            return component
    # Fallback: parse from the pod name. k3s pods are
    # ``<deployment>-<replicaset>-<hash>`` so strip the trailing
    # two hash segments and we're left with the workload name.
    name = (row.get("Names") or "").strip().lstrip("/")
    if not name:
        return ""
    parts = name.split("-")
    # Last two parts of a Deployment-managed pod are
    # ``<rs-hash>-<pod-hash>``; strip them.
    if len(parts) >= 3 and len(parts[-1]) == 5 and len(parts[-2]) >= 5:
        return "-".join(parts[:-2])
    return name


def health_from_status(status: str) -> str:
    """Extract the docker healthcheck verdict from a ps Status string.

    Status looks like "Up 2 hours (healthy)" / "Up 4 seconds (health:
    starting)" / "Up 2 hours" (no healthcheck) / "Exited (1) 5m ago".
    Returns "healthy" / "unhealthy" / "starting" / "running" / "exited"
    / "created" / "restarting" — the last four when no healthcheck is
    declared and we just have the state.
    """
    if not status:
        return "unknown"
    m = _STATUS_HEALTH_RE.search(status)
    if m:
        h = m.group(1).lower()
        if "healthy" in h and "unhealthy" not in h:
            return "healthy"
        if "unhealthy" in h:
            return "unhealthy"
        if "starting" in h:
            return "starting"
    s = status.lower()
    if s.startswith("up"):
        return "running"
    if s.startswith("exit"):
        return "exited"
    if s.startswith("restart"):
        return "restarting"
    if s.startswith("created"):
        return "created"
    return "unknown"


def host_ips() -> tuple[list[str], list[str]]:
    """Return ``(ipv4_addresses, ipv6_addresses)``. Splits the two
    families so the header can render the IPv4 list inline + a
    compact ``+N IPv6`` summary chip — listing every SLAAC IPv6
    inline blew past the available width on standard 80-col TTYs.

    Skips: loopback, docker bridges, veth pairs, virbr, link-local
    IPv4 (169.254/16), link-local IPv6 (fe80::/10).
    """
    v4: list[str] = []
    v6: list[str] = []
    for name, addrs in psutil.net_if_addrs().items():
        if name == "lo" or name.startswith("docker") or name.startswith("br-") \
                or name.startswith("veth") or name.startswith("virbr"):
            continue
        for addr in addrs:
            fam = getattr(addr, "family", None)
            value = addr.address
            if not value:
                continue
            v = value.split("%", 1)[0]
            # IPv4 = AF_INET = 2 ; IPv6 = AF_INET6 = 10 on Linux. Use
            # the value rather than psutil's enum so a heredoc / mocked
            # test doesn't depend on AF_PACKET being 17.
            if fam == 2 and not v.startswith("169.254."):
                v4.append(v)
            elif fam == 10 and not v.startswith("fe80"):
                v6.append(v)
    return v4, v6


def uptime_str() -> str:
    secs = int(time.time() - psutil.boot_time())
    d, rem = divmod(secs, 86400)
    h, rem = divmod(rem, 3600)
    m, _ = divmod(rem, 60)
    if d:
        return f"{d}d {h}h {m}m"
    if h:
        return f"{h}h {m}m"
    return f"{m}m"


def disk_summary() -> list[tuple[str, float, float, float]]:
    """List of (mountpoint, used_GiB, total_GiB, percent) for real disks.

    Skips synthetic filesystems (tmpfs, devtmpfs, overlay, squashfs,
    proc, sysfs, …) and the EFI partition (small, never interesting
    for capacity tracking). Sorted by mountpoint length so / appears
    before /var, /boot/efi, etc.
    """
    skip_fstypes = {
        "tmpfs", "devtmpfs", "squashfs", "overlay", "proc", "sysfs",
        "cgroup", "cgroup2", "mqueue", "pstore", "bpf", "tracefs",
        "debugfs", "configfs", "securityfs", "fusectl", "ramfs",
        "binfmt_misc", "autofs", "nsfs", "hugetlbfs", "fuse.gvfsd-fuse",
    }
    skip_mounts = {"/boot/efi"}
    # Skip the loop-mounted baked-image overlay — it's an internal
    # implementation detail (Phase 8 firstboot loop-mounts the
    # /usr/lib/spatiumddi/docker-overlay.img read-only as a lower
    # layer for the docker storage driver). The operator-visible
    # storage signal is /, /var, and ESP; the overlay's capacity
    # doesn't change once the image is laid down at boot.
    skip_mount_prefixes = ("/var/lib/spatiumddi/docker-overlay/",)
    rows: list[tuple[str, float, float, float]] = []
    # Dedupe by device — bind mounts (e.g. /home → /var/home, /root →
    # /var/root per #170 Phase 8a) report the SAME underlying device
    # as the parent, just at a different mountpoint. Listing them all
    # overflows the dashboard's Disk row with three identical 3.9/15.2
    # GiB cells. Keep the first occurrence (shortest mountpoint wins
    # after the sort below).
    seen_devices: set[str] = set()
    parts = list(psutil.disk_partitions(all=False))
    # Sort so dedupe keeps the canonical (shorter / earlier) mount.
    parts.sort(key=lambda p: (len(p.mountpoint), p.mountpoint))
    for part in parts:
        if part.fstype in skip_fstypes:
            continue
        if part.mountpoint in skip_mounts:
            continue
        if any(part.mountpoint.startswith(p) for p in skip_mount_prefixes):
            continue
        if part.device in seen_devices:
            continue
        seen_devices.add(part.device)
        try:
            u = psutil.disk_usage(part.mountpoint)
        except OSError:
            continue
        rows.append((part.mountpoint, u.used / 2**30, u.total / 2**30, u.percent))
    return rows


def detect_slot_info() -> tuple[str, str] | None:
    """Return (current_slot, durable_default) — both "slot_a"/"slot_b" or
    None if we can't determine. Phase 8c A/B boot detection:
      * current = which slot we booted from, derived from /proc/cmdline's
        root=UUID= → lsblk PARTLABEL.
      * durable = grubenv's saved_entry (the committed default that
        future boots will land on; differs from current during a
        TRIAL boot before spatiumddi-firstboot commits via
        grub-set-default after /health/live passes).
    Cached for the life of the process — neither value changes at
    runtime under normal operation."""
    cmdline = ""
    try:
        cmdline = Path("/proc/cmdline").read_text()
    except OSError:
        return None
    import re as _re
    m = _re.search(r"root=UUID=([0-9a-fA-F-]+)", cmdline)
    if not m:
        return None
    root_uuid = m.group(1).lower()
    current = ""
    try:
        out = subprocess.run(
            ["lsblk", "-no", "PARTLABEL,UUID"],
            capture_output=True, text=True, check=True, timeout=2,
        ).stdout
        for line in out.splitlines():
            parts = line.strip().split()
            if len(parts) >= 2 and parts[-1].lower() == root_uuid:
                label = parts[0].lower()
                if label.startswith("root_"):
                    current = "slot_" + label.split("_", 1)[1]
                break
    except (FileNotFoundError, subprocess.CalledProcessError,
            subprocess.TimeoutExpired):
        # Optional probe — when blkid isn't present (dev container) or
        # the call times out, leave `current` empty and fall through to
        # the "no slot info" branch below.
        pass

    durable = ""
    try:
        out = subprocess.run(
            ["grub-editenv", "/boot/efi/grub/grubenv", "list"],
            capture_output=True, text=True, check=True, timeout=2,
        ).stdout
        for line in out.splitlines():
            if line.startswith("saved_entry="):
                durable = line.split("=", 1)[1].strip()
                break
    except (FileNotFoundError, subprocess.CalledProcessError,
            subprocess.TimeoutExpired):
        # Optional probe — grubenv may not exist on a pre-Phase-8c
        # install, and we don't want a probe failure to suppress the
        # current_slot we already detected. Leave `durable` empty so
        # the renderer falls back to the un-committed display.
        pass

    if not current:
        return None
    return current, durable


# Sentinel that distinguishes "we haven't probed yet" from "we probed
# but detect_slot_info() returned None". Without this, every call to
# slot_info() on a non-appliance build would re-run blkid + grub-editenv.
_UNPROBED: object = object()
_SLOT_INFO_CACHE: tuple[str, str] | None | object = _UNPROBED


def slot_info() -> tuple[str, str] | None:
    global _SLOT_INFO_CACHE
    if _SLOT_INFO_CACHE is _UNPROBED:
        _SLOT_INFO_CACHE = detect_slot_info()
    return _SLOT_INFO_CACHE  # type: ignore[return-value]


def appliance_version_string(env: dict[str, str]) -> str:
    """Resolve the appliance + image versions for the header.

    /etc/spatiumddi/appliance-release is the build-time stamp written
    by mkosi.postinst. SPATIUMDDI_VERSION in .env is the container
    image tag (CalVer or "latest"). Collapse to one value when they
    match (the normal case — every release pins them together); only
    spell out both when they diverge, which signals an in-flight
    Phase 4c release-apply that updated the docker image tag without
    a partition re-image.
    """
    appliance = env.get("APPLIANCE_VERSION") or "?"
    spddi = env.get("SPATIUMDDI_VERSION") or "?"
    if APPLIANCE_RELEASE.exists():
        try:
            for line in APPLIANCE_RELEASE.read_text().splitlines():
                if line.startswith("APPLIANCE_VERSION="):
                    appliance = line.split("=", 1)[1].strip().strip('"')
        except OSError:
            # /etc/spatiumddi/appliance-release is optional; fall back
            # to whatever .env carried in `appliance` (default "?"). A
            # missing release stamp shouldn't blank the header.
            pass
    if appliance == spddi:
        return appliance
    return f"appliance {appliance} · stack {spddi}"


# ── live log tailing ──────────────────────────────────────────────────


class JournalTail(threading.Thread):
    """Tail journalctl into a deque so the renderer can read recent
    lines without blocking on subprocess I/O each refresh."""

    # Operator-hostile log lines (rich/python tracebacks, "Active:" /
    # "Restart " systemd state spam) that we filter out before the
    # renderer sees them. Internal stack traces from a crash-looping
    # spatium-console process used to flood the Live log pane with
    # multi-line ``File "/usr/lib/.../rich/live.py"`` entries that
    # tell the operator nothing useful — only the originating
    # ``OSError`` / ``Exception`` summary line is worth surfacing.
    _NOISE_PATTERNS = (
        # Python traceback frames + caret indicators + raise lines.
        re.compile(r"\bFile \"/usr/lib/python[\d.]+/"),
        re.compile(r"^\s*\^+~*\^*\s*$"),
        re.compile(r"^\s+(self\.|with |return |elif |if |except |raise )"),
        re.compile(r"^Traceback \(most recent call last\):"),
        # systemd transient state churn (re-emitted on every restart).
        re.compile(r"Active: (activating|deactivating|inactive)"),
        re.compile(r"Scheduled restart job, restart counter is at \d+"),
        re.compile(r"Main process exited, code=exited, status="),
        re.compile(r"Failed with result 'exit-code'"),
        re.compile(r"Started spatium-console\.service"),
    )

    def __init__(self, units: Iterable[str], maxlen: int = 200):
        super().__init__(daemon=True)
        self.units = list(units)
        self.lines: deque[str] = deque(maxlen=maxlen)
        self._stop = threading.Event()
        self._proc: subprocess.Popen | None = None

    @classmethod
    def _is_noise(cls, line: str) -> bool:
        return any(p.search(line) for p in cls._NOISE_PATTERNS)

    def stop(self) -> None:
        self._stop.set()
        if self._proc and self._proc.poll() is None:
            try:
                self._proc.terminate()
            except (ProcessLookupError, OSError):
                # Race with natural exit — journalctl already terminated
                # between our poll() check and the terminate() call.
                # Nothing to clean up.
                pass

    def run(self) -> None:
        while not self._stop.is_set():
            argv = [
                "journalctl",
                "--no-pager",
                "--output", "short-iso",
                # 2 min (not 10) so a crash-loop on an earlier instance
                # of spatium-console clears out of the live-log pane
                # within ~2 min of recovery, rather than sitting on
                # screen for 10 min until the journal window naturally
                # rolls forward. Steady-state output from
                # firstboot/update/reboot units lands in real time so
                # the shortened window doesn't lose anything
                # operator-relevant.
                "--since", "2 minutes ago",
                "-f",
            ]
            for u in self.units:
                argv += ["-u", u]
            try:
                self._proc = subprocess.Popen(
                    argv,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.DEVNULL,
                    text=True,
                    bufsize=1,
                )
            except FileNotFoundError:
                # journalctl not on PATH — exotic build. Bail gracefully.
                self.lines.append("[journalctl not available on this host]")
                return
            assert self._proc.stdout is not None
            for line in self._proc.stdout:
                if self._stop.is_set():
                    break
                line = line.rstrip("\n")
                if line and not self._is_noise(line):
                    self.lines.append(line)
            # Subprocess exited (rotate / journald restart). Restart in
            # 2 s unless we're stopping.
            self._proc = None
            if self._stop.is_set():
                return
            time.sleep(2)


# ── key handling ──────────────────────────────────────────────────────


# F-key escape sequences. Linux console + xterm + vt100/vt220 variants
# all coexist (tty1 uses Linux console encoding by default; ttyS0
# typically reports TERM=vt220). Map every known sequence onto the
# logical key.
KEY_SEQUENCES: dict[bytes, str] = {
    # Linux console (TERM=linux)
    b"\x1b[[A": "F1", b"\x1b[[B": "F2", b"\x1b[[C": "F3",
    b"\x1b[[D": "F4", b"\x1b[[E": "F5",
    # xterm / vt100 / vt220 (PF keys)
    b"\x1bOP": "F1", b"\x1bOQ": "F2", b"\x1bOR": "F3", b"\x1bOS": "F4",
    # Numeric form (rxvt, screen, tmux, many serial terms)
    b"\x1b[11~": "F1", b"\x1b[12~": "F2", b"\x1b[13~": "F3",
    b"\x1b[14~": "F4", b"\x1b[15~": "F5", b"\x1b[17~": "F6",
    b"\x1b[18~": "F7", b"\x1b[19~": "F8", b"\x1b[20~": "F9",
    b"\x1b[21~": "F10", b"\x1b[23~": "F11", b"\x1b[24~": "F12",
}


class KeyReader(threading.Thread):
    """Read keypresses from stdin in cbreak mode and post matched
    F-keys to a callback. Buffer accumulates bytes until either a
    known sequence matches or 100 ms passes with no further input."""

    def __init__(self, on_key, tty_fd: int = 0):
        super().__init__(daemon=True)
        self.on_key = on_key
        self.tty_fd = tty_fd
        self._stop = threading.Event()

    def stop(self) -> None:
        self._stop.set()
        # Block until the thread has actually exited and restored the
        # tty's termios state. Without this join the modal that takes
        # over after stop() can race with our select() and eat the
        # operator's first keystroke (or worse, the keyreader can
        # tcsetattr-back to our cbreak settings just after the modal
        # has set its own).
        if self.is_alive():
            self.join(timeout=2.0)

    def run(self) -> None:
        # cbreak (not raw): keep ISIG so SIGTERM/SIGINT from systemd
        # still drop us; we just want non-canonical, no-echo input.
        try:
            saved = termios.tcgetattr(self.tty_fd)
        except termios.error:
            return
        try:
            tty.setcbreak(self.tty_fd)
            # Disable echo explicitly — cbreak leaves it on so the F-key
            # escape sequence would otherwise print as garbage.
            new = termios.tcgetattr(self.tty_fd)
            new[3] = new[3] & ~termios.ECHO  # lflags
            termios.tcsetattr(self.tty_fd, termios.TCSANOW, new)

            buf = b""
            while not self._stop.is_set():
                r, _, _ = select.select([self.tty_fd], [], [], 0.1)
                if not r:
                    if buf and buf in KEY_SEQUENCES:
                        self.on_key(KEY_SEQUENCES[buf])
                    buf = b""
                    continue
                try:
                    chunk = os.read(self.tty_fd, 32)
                except OSError:
                    continue
                if not chunk:
                    continue
                buf += chunk
                # Try longest-prefix match repeatedly so a burst of
                # bytes (e.g. operator pasting) drains cleanly.
                while buf:
                    matched = None
                    for k in sorted(KEY_SEQUENCES, key=len, reverse=True):
                        if buf.startswith(k):
                            matched = k
                            break
                    if not matched:
                        # No prefix matched — could still be incomplete
                        # (b"\x1b[" pending the rest). If it doesn't
                        # look like the start of any known sequence,
                        # drop it.
                        if not any(s.startswith(buf) for s in KEY_SEQUENCES):
                            buf = b""
                        break
                    self.on_key(KEY_SEQUENCES[matched])
                    buf = buf[len(matched):]
        finally:
            try:
                termios.tcsetattr(self.tty_fd, termios.TCSANOW, saved)
            except termios.error:
                # Restoring termios on tty teardown can race the kernel
                # closing the fd (e.g. operator pressed F1 → execvp'd
                # agetty and the parent's tty_fd is already gone). Cosmetic
                # at worst since the parent is about to exit anyway.
                pass


# ── rendering ────────────────────────────────────────────────────────


HEALTH_STYLES = {
    "healthy":    ("●", "bold green"),
    "running":    ("●", "bold green"),
    "completed":  ("✓", "bold green"),   # one-shot exit 0 (e.g. migrate)
    "starting":   ("◐", "bold yellow"),
    "unhealthy":  ("●", "bold red"),
    "restarting": ("◐", "bold yellow"),
    "exited":     ("○", "bold red"),
    "created":    ("○", "dim"),
    "missing":    ("○", "dim"),
    "unknown":    ("?", "dim"),
}

# Compose services that are expected one-shots — they run to
# completion and exit 0. The dashboard renders their "Exited (0)"
# state as "completed" (green) instead of "exited" (red).
ONE_SHOT_SERVICES = {"migrate"}


def render_header(state: "DashboardState", mono_t: float) -> Panel:
    """6-row header with identity / vitals / disk sections separated by a Rule.

    All values come from state.* (cached at the vitals tier, 1 s
    cadence). Only the spinner is derived live from mono_t so its
    rotation animates at the render cadence (4 Hz) — that's the one
    thing operators want jittery (visible "alive" indicator).
    """
    env = state.env
    role = state.role
    hostname = env.get("APPLIANCE_HOSTNAME") or os.uname().nodename
    v4_ips, v6_ips = host_ips()
    cpu = state.cpu_percent
    load = " ".join(f"{x:.2f}" for x in state.load_avg)
    build = appliance_version_string(env)
    clock = state.clock_str
    spinner = SPINNER_CHARS[int(mono_t * 2) % len(SPINNER_CHARS)]

    # Line 1 — identity on the left, clock + spinner on the right.
    line1 = Table.grid(expand=True)
    line1.add_column(ratio=1, no_wrap=False)
    line1.add_column(justify="right", no_wrap=True)
    left1 = Text()
    left1.append("Host ", style="dim")
    left1.append(hostname, style="bold")
    left1.append("   Role ", style="dim")
    left1.append(role_label(role), style="bold cyan")
    right1 = Text()
    right1.append(clock, style="bold")
    right1.append("  ")
    right1.append(spinner, style="bold bright_yellow")
    line1.add_row(left1, right1)

    # Line 2 — IPs. IPv4 inline; IPv6 collapsed to a ``+N IPv6``
    # chip so SLAAC's typically-40-char addresses don't push the
    # header off-screen on standard 80-col TTYs. Operators who need
    # the full list can hit F4 (nmtui) for the per-NIC view.
    line2 = Text()
    line2.append("IPs  ", style="dim")
    if v4_ips:
        line2.append(", ".join(v4_ips))
        if v6_ips:
            line2.append(f"  +{len(v6_ips)} IPv6", style="dim")
    elif v6_ips:
        # IPv6-only host (rare): show the first; the chip carries
        # the rest.
        line2.append(v6_ips[0])
        if len(v6_ips) > 1:
            line2.append(f"  +{len(v6_ips) - 1} IPv6", style="dim")
    else:
        line2.append("—")

    # Line 3 — build / version
    line3 = Text()
    line3.append("Build ", style="dim")
    line3.append(build)

    # Line 3a — Control plane + Identity (only on application
    # appliances; #170 Wave D). Inlining these into the header lets
    # us drop the separate Agent panel, saving ~4 rows of vertical
    # space the operator would otherwise spend looking at one panel
    # title + two values.
    agent_line: Text | None = None
    if role == "application":
        cp_url = env.get("CONTROL_PLANE_URL") or "(not configured)"
        pairing = pairing_status(env, role, state.ps_rows)
        agent_line = Text()
        agent_line.append("Agent ", style="dim")
        agent_line.append(cp_url, style="bold")
        if pairing is not None:
            label, pstyle = pairing
            agent_line.append("  ", style="dim")
            agent_line.append(label, style=pstyle)

    # Line 3a-2 — External supervisor watchdog status (Wave E). Only
    # renders on application appliances + only when we have a
    # supervisor liveness file to read. The host-side timer keeps
    # the supervisor process alive across deadlocks; surfacing the
    # mtime delta here gives the physical-console operator the same
    # signal the host watchdog acts on.
    watchdog_line: Text | None = None
    if role == "application":
        wd_status = supervisor_watchdog_status()
        if wd_status is not None:
            label, wstyle = wd_status
            watchdog_line = Text()
            watchdog_line.append("Watchdog ", style="dim")
            watchdog_line.append(label, style=wstyle)

    # Line 3b — Phase 8c A/B slot indicator. Only renders on the
    # appliance (where slot detection succeeds). On dev/non-appliance
    # boxes detect_slot_info() returns None and we skip the line.
    def _slot_letter(s: str) -> str:
        # ``slot_a`` → ``A``, ``slot_b`` → ``B``. Falls through
        # untouched on anything else so a future ``slot_c`` doesn't
        # render as empty.
        if s.startswith("slot_") and len(s) > 5:
            return s[5:].upper()
        return s

    slots = slot_info()
    slot_line: Text | None = None
    if slots is not None:
        current, durable = slots
        slot_line = Text()
        slot_line.append("Slot  ", style="dim")
        slot_line.append(_slot_letter(current), style="bold cyan")
        if durable and durable != current:
            slot_line.append("  ", style="dim")
            slot_line.append(
                f"TRIAL — durable default is {_slot_letter(durable)}",
                style="bold bright_yellow",
            )
        elif durable:
            slot_line.append("  ", style="dim")
            slot_line.append("· committed default", style="dim")
        else:
            slot_line.append("  ", style="dim")
            slot_line.append("(grubenv unreadable)", style="dim")

    # Slot-upgrade status line. Only renders when there's something to
    # show (in-flight / failed / done waiting for reboot) — quiet
    # otherwise so a steady-state appliance doesn't carry a permanent
    # "no upgrade pending" row.
    upgrade_line: Text | None = None
    if role == "application":
        ustatus = upgrade_status()
        if ustatus is not None:
            label, ustyle = ustatus
            upgrade_line = Text()
            upgrade_line.append("Upgrade ", style="dim")
            upgrade_line.append(label, style=ustyle)

    # Issue #183 Phase 1 — k3s row. Quiet on pre-#183 slots (no k3s
    # binary baked); always-on once the slot ships k3s so operators
    # can see the cluster's version + readiness at a glance. The
    # "disabled" state is the Phase 1 default — k3s ships in the
    # slot but isn't auto-enabled until Phase 3 wires the supervisor.
    k3s_line: Text | None = None
    k3s_state = k3s_status()
    if k3s_state is not None:
        label, kstyle = k3s_state
        k3s_line = Text()
        k3s_line.append("k3s   ", style="dim")
        k3s_line.append(label, style=kstyle)

    # Rule — horizontal divider between identity and vitals.
    rule = Rule(style="cyan dim", characters="─")

    # Vitals line — uptime / cpu / ram / load / disks all on one row.
    # Previously disks were on a separate ``line5`` but with the bind-
    # mount dedupe + docker-overlay skip there are typically only 2-3
    # mount entries, easily fitting alongside the vitals on the same
    # row on any 80+ col TTY. Saves one vertical row on the dashboard.
    vitals = Text()
    vitals.append("Up ", style="dim"); vitals.append(uptime_str(), style="bold")
    vitals.append("   CPU ", style="dim"); vitals.append(f"{cpu:.0f}%", style="bold")
    vitals.append("   RAM ", style="dim")
    vitals.append(
        f"{state.ram_used_gib:.1f}/{state.ram_total_gib:.1f} GiB ({state.ram_percent:.0f}%)",
        style="bold",
    )
    vitals.append("   Load ", style="dim"); vitals.append(load, style="bold")
    if state.disks:
        vitals.append("   Disk ", style="dim")
        disk_bits = [
            f"{mp} {used_g:.1f}/{total_g:.1f} GiB ({pct:.0f}%)"
            for mp, used_g, total_g, pct in state.disks
        ]
        vitals.append("  ".join(disk_bits))

    # Pack the short label-value rows into a two-column grid so the
    # right half of the panel (~40 chars on an 80-col TTY) stops
    # rendering as dead space. line1 stays full-width since its
    # right column is already used by clock+spinner; vitals stays
    # full-width because it's one long line of bits that flows
    # naturally. Everything else (IPs/Build/Agent/Watchdog/Slot/
    # Upgrade/k3s) is short enough to fit in a half-width cell.
    short_lines: list[Text] = [line2, line3]
    if agent_line is not None:
        short_lines.append(agent_line)
    if watchdog_line is not None:
        short_lines.append(watchdog_line)
    if slot_line is not None:
        short_lines.append(slot_line)
    if upgrade_line is not None:
        short_lines.append(upgrade_line)
    if k3s_line is not None:
        short_lines.append(k3s_line)

    paired_grid = Table.grid(expand=True, padding=(0, 2))
    paired_grid.add_column(ratio=1, no_wrap=False)
    paired_grid.add_column(ratio=1, no_wrap=False)
    for i in range(0, len(short_lines), 2):
        left = short_lines[i]
        right = short_lines[i + 1] if i + 1 < len(short_lines) else Text("")
        paired_grid.add_row(left, right)

    body_parts: list = [line1, paired_grid, rule, vitals]
    body = Group(*body_parts)
    return Panel(body, box=SQUARE, border_style="cyan", padding=(0, 1),
                 title="[bold]SpatiumDDI[/bold]", title_align="left")


def render_services(role: str, ps_rows: list[dict]) -> Panel:
    """Render the Pods panel — every pod on the local k3s cluster
    grouped by namespace, with status + ports + image.

    Function name kept as ``render_services`` so call sites in
    ``render_frame`` don't need to change. Pre-Phase-7 this was
    role-scoped (showed only the compose services for the active
    role). Phase 7 widens the scope: the appliance is a real
    Kubernetes node and operators want the same view ``kubectl get
    pods -A -o wide`` gives, condensed for the TTY.

    The ``role`` argument is unused now but kept on the signature
    so the call site in render_frame stays unchanged.
    """
    _ = role  # signature kept for compatibility

    tbl = Table.grid(padding=(0, 1), expand=True)
    tbl.add_column(width=2, no_wrap=True)          # health glyph
    tbl.add_column(width=12, no_wrap=True)         # namespace
    tbl.add_column(min_width=20, no_wrap=False)    # pod name
    tbl.add_column(width=10, no_wrap=True)         # state
    tbl.add_column(width=18, no_wrap=True)         # ports / net mode
    tbl.add_column(min_width=14, no_wrap=False)    # image
    tbl.add_column(justify="right", no_wrap=True)  # status text

    # Sort: spatium first (the role pods operators care about most),
    # kube-system next, then anything else alphabetically. Within a
    # namespace, alphabetical by name.
    def _ns_rank(ns: str) -> tuple[int, str]:
        if ns == "spatium":
            return (0, ns)
        if ns == "kube-system":
            return (1, ns)
        return (2, ns)

    sorted_rows = sorted(
        ps_rows,
        key=lambda r: (_ns_rank(r.get("Namespace") or ""), r.get("Names") or ""),
    )

    if not sorted_rows:
        tbl.add_row(
            Text("·", style="dim"),
            Text("—", style="dim"),
            Text("no pods running (k3s not ready?)", style="dim"),
            Text("", style="dim"),
            Text("", style="dim"),
            Text("", style="dim"),
            Text("", style="dim"),
        )
        return Panel(
            tbl, box=SQUARE, border_style="cyan",
            title="[bold]Pods[/bold]", title_align="left",
        )

    for row in sorted_rows:
        status = row.get("Status") or ""
        verdict = health_from_status(status)
        if (row.get("State") or "") == "exited" and status.startswith("Succeeded"):
            verdict = "completed"
        glyph, style = HEALTH_STYLES[verdict]

        image = row.get("Image") or ""
        short_image = image.rsplit("/", 1)[1] if "/" in image else image

        ports = container_port_summary(row)
        ports_style = "bold cyan" if ports == "host net" else "dim"

        tbl.add_row(
            Text(glyph, style=style),
            Text(row.get("Namespace") or "—", style="dim"),
            Text(row.get("Names") or "", style="bold"),
            Text(verdict, style=style),
            Text(ports or "—", style=ports_style),
            Text(short_image, style="dim"),
            Text(status, style="dim"),
        )

    return Panel(
        tbl, box=SQUARE, border_style="cyan",
        title="[bold]Pods[/bold]", title_align="left",
    )


def upgrade_status() -> tuple[str, str] | None:
    """Slot-upgrade state derived from
    ``/var/lib/spatiumddi/release-state/`` (#138 Phase 8b).

    Returns ``(label, rich-style)`` for the header's Upgrade line, or
    ``None`` when there's nothing relevant to show (no pending trigger,
    no recent run). The runner writes one of three state values into
    ``slot-upgrade-pending.state``:

      * ``in-flight`` — dd + grub edit in progress; trigger file still
        present
      * ``done`` — last apply succeeded; trigger renamed to
        ``slot-upgrade-pending.done.<ts>``
      * ``failed`` — last apply errored; trigger renamed to
        ``slot-upgrade-pending.failed.<ts>``

    We also surface a count of recent ``.failed.<ts>`` sidecars so
    the operator can tell a one-off bad-network glitch from a
    persistent fault.
    """
    state_dir = Path("/var/lib/spatiumddi/release-state")
    if not state_dir.is_dir():
        return None
    state_file = state_dir / "slot-upgrade-pending.state"
    pending_marker = state_dir / "slot-upgrade-pending"

    state_text = ""
    try:
        state_text = state_file.read_text(encoding="utf-8").strip()
    except OSError:
        # Sidecar missing or unreadable → treat as "no upgrade state".
        # The dashboard is best-effort observability; a stat() race
        # against the host runner's rename shouldn't crash the panel.
        pass
    parts = state_text.split(None, 1)
    state_val = parts[0] if parts else ""

    # Count failed sidecars in the last hour so a single transient
    # failure doesn't look as scary as a stuck loop. The path-unit
    # cadence is roughly once per heartbeat (60 s) so >5 failures /
    # hour is a real fault.
    now = time.time()
    failed_recent = 0
    try:
        for f in state_dir.glob("slot-upgrade-pending.failed.*"):
            try:
                if now - f.stat().st_mtime < 3600:
                    failed_recent += 1
            except OSError:
                # Sidecar disappeared between glob() and stat() — the
                # host runner rotates these on each apply. Skip and
                # keep counting the rest.
                pass
    except OSError:
        # /var/lib/spatiumddi/release-state isn't readable (fresh
        # boot before firstboot, or unprivileged execution path).
        # Fall through with failed_recent=0; the dashboard then
        # rolls up to whatever state_val we managed to read above.
        pass

    # In-flight beats everything else — the trigger file's still
    # present so the runner hasn't completed (or is currently
    # mid-dd). ``state=in-flight`` confirms it.
    if pending_marker.exists() or state_val == "in-flight":
        return ("Upgrading…", "bold yellow")
    if state_val == "failed" or failed_recent >= 3:
        # ≥3 failures in the last hour → call it red even if the
        # current state somehow recovered. Operators want to see the
        # red chip until they've investigated.
        label = "Upgrade failed"
        if failed_recent > 1:
            label += f" ({failed_recent}× recent)"
        label += " — see /var/log/spatiumddi/slot-upgrade.log"
        return (label, "bold red")
    if state_val == "done":
        # Show the success chip until the next reboot picks up the
        # new slot. ``slot_info()`` separately renders "TRIAL" once
        # the appliance has actually booted into the new slot.
        return ("Upgrade ready · reboot to activate", "bold green")
    return None


def k3s_status() -> tuple[str, str] | None:
    """Issue #183 Phase 1 — derive a (label, style) tuple for the
    console's 'k3s' row, or ``None`` when k3s isn't baked into this
    slot at all (pre-#183 fielded appliances).

    Three observable states:

    * **disabled** — k3s binary baked + unit installed but
      ``k3s.service`` not enabled. The default Phase 1 shape: ships
      in the slot, operator opts in for validation. Yellow chip.
    * **initializing** — unit active but kubeapi not yet responsive.
      Boot transient (~30s on a fresh appliance, ~3s on a re-bind).
      Yellow chip.
    * **ready** — kubeapi reports the node Ready. Green chip with
      version + node-condition summary.
    * **failed** — unit reports failed/dead. Red chip with the last
      exit reason if we can extract it.
    """
    if not Path("/usr/local/bin/k3s").exists():
        return None  # Not a #183-aware slot; quiet.

    # Resolve version from the baked sidecar (cheaper + race-free vs
    # shelling to ``k3s --version`` which has to fork the static
    # binary). Falls back to a runtime ``k3s --version`` only when
    # the sidecar is missing.
    version = "unknown"
    sidecar = Path("/usr/share/doc/k3s/.version")
    if sidecar.exists():
        try:
            version = sidecar.read_text(encoding="utf-8").strip() or "unknown"
        except OSError:
            # Sidecar unreadable — fall through to the runtime probe.
            pass

    # Unit state via systemctl is-active. systemctl returns 0 on
    # active, 3 on inactive/failed/disabled — we check the textual
    # output rather than relying on exit code so we can distinguish
    # ``inactive`` (operator hasn't enabled yet, expected Phase 1)
    # from ``failed`` (operator enabled but k3s crashed).
    try:
        proc = subprocess.run(
            ["systemctl", "is-active", "k3s.service"],
            capture_output=True,
            text=True,
            timeout=2,
        )
        unit_state = proc.stdout.strip()
    except (FileNotFoundError, subprocess.TimeoutExpired):
        unit_state = "unknown"

    if unit_state in ("inactive", "unknown"):
        return (f"{version} · disabled (systemctl enable --now k3s)", "yellow")
    if unit_state == "failed":
        return (f"{version} · failed — journalctl -u k3s", "bold red")
    if unit_state == "activating":
        return (f"{version} · starting…", "yellow")

    # unit is active — probe the kubeapi via the local kubeconfig.
    # Use a tight timeout so a wedged apiserver doesn't stall the
    # render loop (whole function runs every 1 s).
    if not Path("/etc/rancher/k3s/k3s.yaml").exists():
        return (f"{version} · active · no kubeconfig yet", "yellow")
    try:
        proc = subprocess.run(
            [
                "/usr/local/bin/k3s",
                "kubectl",
                "get",
                "--raw=/readyz",
            ],
            env={
                **os.environ,
                "KUBECONFIG": "/etc/rancher/k3s/k3s.yaml",
            },
            capture_output=True,
            text=True,
            timeout=2,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return (f"{version} · active · api not responding", "yellow")
    if proc.returncode == 0 and proc.stdout.strip() == "ok":
        return (f"{version} · ready", "bold green")
    return (f"{version} · active · api {proc.returncode}", "yellow")


def pairing_status(env: dict[str, str], role: str, ps_rows: list[dict]) -> tuple[str, str] | None:
    """#170 — derive a (label, style) tuple for the console's
    'Identity' row, or ``None`` when the role doesn't pair against
    a remote control plane.

    Reads the supervisor's state dir under
    ``/var/persist/spatium-supervisor/``:

    * ``approval-state`` — when present and ``revoked``, the control
      plane has rejected our heartbeats long enough that the
      supervisor flipped to the revoked state (issue #170 Wave E
      follow-up). Takes precedence over cert.pem so a stale-cert
      "Approved ✓" can't mislead the operator after a server-side
      deletion.
    * ``identity/appliance_id`` — created when the supervisor's
      pairing-code claim succeeds.
    * ``tls/cert.pem`` — created when the admin approves the row.

    Returns ``(label, rich-style)`` so the renderer can colour the row.
    """
    if role != "application":
        return None
    state_dir = Path("/var/persist/spatium-supervisor")
    approval_state_file = state_dir / "approval-state"
    identity_dir = state_dir / "identity"
    appliance_id_file = identity_dir / "appliance_id"
    cert_file = state_dir / "tls" / "cert.pem"

    # Revoked is the loudest signal — read it first so an operator
    # who deleted the row but didn't yet ``rm`` cert.pem doesn't see
    # a stale green chip. The recovery path is documented in the
    # label text (re-pair from /appliance/pairing).
    try:
        approval_state_text = approval_state_file.read_text(encoding="utf-8").strip()
    except OSError:
        approval_state_text = ""
    if approval_state_text == "revoked":
        return ("Approval revoked — re-pair from /appliance/pairing", "bold red")

    if cert_file.exists() and cert_file.stat().st_size > 0:
        return ("Approved ✓", "bold green")
    if appliance_id_file.exists() and appliance_id_file.stat().st_size > 0:
        return ("Awaiting approval", "bold yellow")
    # No appliance_id yet — supervisor either hasn't claimed the
    # code or the claim failed. Surface container exit as the
    # actionable hint.
    for row in ps_rows:
        if container_service_name(row) != "spatium-supervisor":
            continue
        state = (row.get("State") or "").lower()
        status = (row.get("Status") or "").lower()
        if "exited" in state or "dead" in state or "exited" in status:
            return ("Pair failed — regenerate code on control plane", "bold red")
        break
    return ("Bootstrapping…", "bold yellow")


def render_log(tail: JournalTail, height: int) -> Panel:
    # Take the last `height-2` lines (room for borders). On a fresh
    # boot the deque can be empty for a few seconds — render a
    # placeholder rather than an empty frame.
    if not tail.lines:
        body: Group | Text = Text("(waiting for log output…)", style="dim italic")
    else:
        body = Group(*(
            Text(line, style="dim", overflow="ellipsis", no_wrap=True)
            for line in list(tail.lines)[-(max(height - 2, 1)):]
        ))
    return Panel(body, box=SQUARE, border_style="cyan",
                 title="[bold]Live log[/bold]", title_align="left")


def render_footer(message: str = "") -> Text:
    """Borderless single-line F-key strip. Returns a Text (not Panel)
    so the Layout cell claims exactly one row, with no border padding
    eating vertical space."""
    keys = [
        ("F1", "Login"),
        ("F2", "Monitor"),
        ("F3", "Pods"),
        ("F4", "Network"),
        ("F5", "Reboot"),
        ("F6", "Shutdown"),
        ("F8", "Re-pair"),
    ]
    t = Text(no_wrap=True, overflow="ellipsis")
    t.append(" ")
    for i, (k, label) in enumerate(keys):
        if i:
            t.append("  ")
        # bold black on bright_blue chip + bold white label.
        t.append(f" {k} ", style="bold black on bright_blue")
        t.append(f" {label}", style="bold white")
    if message:
        t.append("   ")
        t.append(message, style="bold bright_yellow")
    return t


def render_frame(state: "DashboardState", mono_t: float) -> Layout:
    # Compact sizing — feedback was that the dashboard occupied too
    # many rows. Each panel claims exactly content + 2 border rows;
    # footer is a borderless 1-row strip.

    # Phase 7 — Pods panel shows every pod on the local cluster, not
    # the pre-Phase-7 role-scoped service list. Row count is dynamic:
    # number of pods, plus 2 for the panel border. Min 3 rows so the
    # empty-state "no pods running" hint stays visible while k3s comes
    # up. Capped at terminal-height-aware ceiling in render_frame's
    # log_height clamp below.
    pods_count = len(state.ps_rows) if state.ps_rows else 1
    # Header layout: 1 line1 (host+role | clock) + N rows of the
    # 2-col paired grid + 1 horizontal rule + 1 vitals + 2 panel
    # border. The grid packs IPs + Build + every conditional row
    # (agent / watchdog / slot / upgrade / k3s) 2-per-row, so
    # what would have been 5-7 separate rows becomes 3-4 paired
    # rows — saves ~3 vertical rows on a typical appliance.
    has_agent_line = state.role == "application"
    has_watchdog_line = (
        state.role == "application" and supervisor_watchdog_status() is not None
    )
    has_upgrade_line = state.role == "application" and upgrade_status() is not None
    has_k3s_line = k3s_status() is not None
    short_count = (
        2  # IPs + Build, always present
        + (1 if slot_info() is not None else 0)
        + (1 if has_agent_line else 0)
        + (1 if has_watchdog_line else 0)
        + (1 if has_upgrade_line else 0)
        + (1 if has_k3s_line else 0)
    )
    paired_rows = (short_count + 1) // 2  # ceil(short_count / 2)
    HEADER_ROWS = 1 + paired_rows + 1 + 1 + 2  # line1 + grid + rule + vitals + border
    SVC_ROWS = pods_count + 2   # tight: just borders, no padding
    FOOTER_ROWS = 1   # single-line borderless strip

    layout = Layout()
    layout.split_column(
        Layout(name="header", size=HEADER_ROWS),
        Layout(name="body", ratio=1),
        Layout(name="footer", size=FOOTER_ROWS),
    )
    layout["body"].split_column(
        Layout(name="services", size=SVC_ROWS),
        Layout(name="log", ratio=1),
    )
    layout["header"].update(render_header(state, mono_t))
    layout["body"]["services"].update(render_services(state.role, state.ps_rows))
    fixed = HEADER_ROWS + SVC_ROWS + FOOTER_ROWS
    log_height = max(state.term_size[1] - fixed, 4)
    layout["body"]["log"].update(render_log(state.tail, log_height))
    layout["footer"].update(render_footer(state.status_message))
    return layout


# ── action handling ───────────────────────────────────────────────────


class DashboardState:
    def __init__(self, env: dict[str, str], tail: JournalTail, tty_path: str):
        self.env = env
        self.role = role_from_env(env)
        self.tail = tail
        self.tty_path = tty_path
        self.ps_rows: list[dict] = []
        self.status_message = ""
        self.status_expires = 0.0
        self.pending_action: str | None = None
        self.term_size = (80, 24)
        self.lock = threading.Lock()
        # Three refresh tiers — operator feedback was that CPU % +
        # clock were flickering when sampled at 4 Hz (the render
        # cadence). Keep render fast for the spinner only; cache
        # everything else at 1 s (vitals) or 2 s (docker / env).
        self._last_vitals_refresh = 0.0
        self._last_data_refresh = 0.0
        # Cached vitals + clock (read by render_header each tick).
        self.cpu_percent: float = 0.0
        self.ram_used_gib: float = 0.0
        self.ram_total_gib: float = 0.0
        self.ram_percent: float = 0.0
        self.load_avg: tuple[float, float, float] = (0.0, 0.0, 0.0)
        self.clock_str: str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        self.disks: list[tuple[str, float, float, float]] = []

    def refresh(self, force: bool = False) -> None:
        now = time.monotonic()

        # Vitals tier (1 s) — CPU sample / RAM / Load / clock / disk.
        if force or (now - self._last_vitals_refresh) >= VITALS_EVERY:
            self._last_vitals_refresh = now
            self.cpu_percent = psutil.cpu_percent(interval=None)
            vm = psutil.virtual_memory()
            self.ram_used_gib = vm.used / 2**30
            self.ram_total_gib = vm.total / 2**30
            self.ram_percent = vm.percent
            self.load_avg = os.getloadavg()
            self.clock_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            self.disks = disk_summary()

        # Data tier (2 s) — docker ps + env re-read.
        if force or (now - self._last_data_refresh) >= DATA_REFRESH_EVERY:
            self._last_data_refresh = now
            self.ps_rows = docker_ps()
            try:
                self.env = read_env()
            except Exception:
                # .env may be missing on a fresh image before firstboot
                # writes it, or transiently locked while firstboot
                # generates secrets. Keep the previous self.env (already
                # has sensible defaults) so the dashboard doesn't blank.
                pass
            new_role = role_from_env(self.env)
            if new_role:
                self.role = new_role

        # Status-message TTL ticks on every call regardless.
        if self.status_expires and time.time() > self.status_expires:
            self.status_message = ""
            self.status_expires = 0.0

    def flash(self, msg: str, ttl: float = 3.0) -> None:
        self.status_message = msg
        self.status_expires = time.time() + ttl

    def set_action(self, action: str) -> None:
        with self.lock:
            self.pending_action = action


def _draw_confirm(console: Console, question: str, yes_selected: bool) -> None:
    """Render the confirm modal at vertical centre with one button
    highlighted. Called once on open and again each time the selection
    flips, never on every input tick (would flicker)."""
    if yes_selected:
        yes_chip = "[bold black on bright_green]  Yes  [/bold black on bright_green]"
        no_chip = "[bold white]  No   [/bold white]"
    else:
        yes_chip = "[bold white]  Yes  [/bold white]"
        no_chip = "[bold black on bright_red]  No   [/bold black on bright_red]"

    body = Group(
        Align.center(Text(question, style="bold")),
        Text(""),
        Align.center(Text.from_markup(f"{yes_chip}      {no_chip}")),
        Text(""),
        Align.center(Text.from_markup(
            "[dim]← → switch  ·  Enter confirm  ·  Esc cancel  ·  Y / N shortcut[/dim]"
        )),
    )
    panel = Panel(
        body, box=SQUARE, border_style="yellow", padding=(1, 4),
        title="[bold yellow] Confirm [/bold yellow]",
        title_align="center",
        width=min(64, console.size.width - 4),
    )

    console.clear()
    pad = max(console.size.height // 3, 1)
    for _ in range(pad):
        console.print("")
    console.print(Align.center(panel))


def confirm_modal(console: Console, question: str, ttl: float = 30.0) -> bool:
    """Arrow-key navigable Yes/No popup. Returns True if the operator
    picks Yes (highlighted + Enter), False on No/Esc/timeout.

    Default selection is No — destructive ops shouldn't fire on a
    careless Enter. Single-key shortcuts (Y/N) still work for muscle
    memory.

    Caller is responsible for tearing down whatever owns the TTY
    before calling (KeyReader stopped + Live stopped) so this function
    has clean ownership of stdin/stdout.
    """
    try:
        saved = termios.tcgetattr(0)
    except termios.error:
        return False

    selected = False  # default: No
    confirmed: bool | None = None
    last_drawn: bool | None = None
    buf = b""

    try:
        tty.setcbreak(0)
        attrs = termios.tcgetattr(0)
        attrs[3] &= ~termios.ECHO
        termios.tcsetattr(0, termios.TCSANOW, attrs)

        deadline = time.time() + ttl
        while confirmed is None and time.time() < deadline:
            if last_drawn != selected:
                _draw_confirm(console, question, selected)
                last_drawn = selected

            # Tight poll so a lone Esc disambiguates from the start of
            # an arrow-key escape sequence — arrow keys arrive as a
            # 3-byte burst (\x1b [ C) within milliseconds, lone Esc
            # stands alone. 80 ms is more than enough wall time for
            # the trailing bytes to land but short enough for Esc to
            # feel responsive.
            r, _, _ = select.select([0], [], [], 0.08 if buf else 0.5)
            if not r:
                # No follow-up bytes — if buf is a lone Esc, treat as cancel.
                if buf == b"\x1b":
                    confirmed = False
                buf = b""
                continue
            try:
                chunk = os.read(0, 16)
            except OSError:
                continue
            if not chunk:
                continue
            buf += chunk

            # ── Match complete sequences from longest first ──────────
            # Left / Right arrows: ESC[D / ESC[C (xterm), ESCO D / ESCO C (vt220)
            if buf in (b"\x1b[D", b"\x1b[C", b"\x1bOD", b"\x1bOC",
                       b"\x1b[A", b"\x1b[B"):  # also Up/Down — same effect
                selected = not selected
                buf = b""
                continue
            # Tab also flips selection.
            if buf == b"\t":
                selected = not selected
                buf = b""
                continue
            # Y / N shortcuts (immediate confirm).
            if buf in (b"y", b"Y"):
                confirmed = True
                break
            if buf in (b"n", b"N", b"q", b"Q"):
                confirmed = False
                break
            # Enter / Space — confirm CURRENT selection.
            if buf in (b"\r", b"\n", b" "):
                confirmed = selected
                break
            # Ctrl-C — cancel.
            if buf == b"\x03":
                confirmed = False
                break
            # Incomplete escape sequence — keep buffering, the
            # 80 ms select above will give the rest a chance to land.
            if buf.startswith(b"\x1b") and len(buf) < 4:
                continue
            # Unknown — drop and keep waiting.
            buf = b""

        return confirmed if confirmed is not None else False
    finally:
        try:
            termios.tcsetattr(0, termios.TCSANOW, saved)
        except termios.error:
            pass


def do_login(tty_path: str) -> None:
    """Hand off tty to agetty. Never returns (execvp). systemd's
    Restart=always brings spatium-console back when the operator
    logs out."""
    tty_name = os.path.basename(tty_path) if tty_path else "tty1"
    # Linux's agetty is at /sbin/agetty on Debian; --keep-baud is a
    # no-op on virtual consoles, harmless on serial. --noclear keeps
    # the dashboard's last frame visible until the operator types.
    args = ["agetty", "-o", "-p -- \\u", "--noclear", "--keep-baud",
            tty_name, "linux"]
    try:
        os.execvp(args[0], args)
    except FileNotFoundError:
        # Fallback to `login` if agetty is somehow missing.
        os.execvp("login", ["login"])


def do_reboot(console: Console) -> None:
    if confirm_modal(console, "Reboot the appliance now?"):
        console.clear()
        console.print("\n\n[bold yellow]Rebooting…[/bold yellow]\n")
        subprocess.run(["systemctl", "reboot"], check=False)


def do_shutdown(console: Console) -> None:
    if confirm_modal(console, "Power off the appliance now?"):
        console.clear()
        console.print("\n\n[bold yellow]Powering off…[/bold yellow]\n")
        subprocess.run(["systemctl", "poweroff"], check=False)


def _term_env() -> dict[str, str]:
    """Build a subprocess env with a usable ``TERM`` for ncurses tools
    (whiptail in spatium-pair, htop, nmtui).

    The tty1 systemd unit doesn't ``Environment=TERM=...``, so the
    Python process inherits whatever systemd defaults to — which can
    be empty. whiptail with no TERM renders a black screen with a
    cursor, no dialog box, no exit path. Force ``linux`` for tty1
    (the right type for the Linux VT console) and ``vt220`` for
    serial consoles so newt picks the right capability set.
    """
    env = os.environ.copy()
    term = env.get("TERM", "").strip()
    if not term or term in {"dumb", "unknown"}:
        try:
            ttyname = os.ttyname(0)
        except OSError:
            ttyname = "/dev/tty1"
        env["TERM"] = "vt220" if "ttyS" in ttyname else "linux"
    return env


def _prepare_tty_for_subprocess(tty: str) -> None:
    """Flush Rich's altscreen-exit + main-screen-clear sequences to the
    physical TTY *before* forking an ncurses subprocess.

    Rich's ``Live(screen=True).stop()`` writes ``\\x1b[?1049l`` (exit
    altscreen) through Python's buffered stdout. The buffer doesn't
    drain before ``subprocess.run`` forks, so whiptail / htop / nmtui
    draw onto the alternate screen buffer the user is no longer
    looking at — operator sees a blank screen with a cursor and can't
    escape. Writing the reset sequence directly to ``/dev/ttyN``
    bypasses the buffer entirely and forces the terminal back to the
    main screen + a clean cursor before the subprocess starts.
    """
    try:
        with open(tty, "w") as tty_out:
            # \\x1b[?1049l = leave altscreen; \\x1bc = full reset
            # (clears screen, resets attrs, cursor home).
            tty_out.write("\x1b[?1049l\x1bc")
            tty_out.flush()
    except OSError:
        # If the TTY isn't writable we're in trouble anyway —
        # nothing to do here.
        pass
    # Also flush Python's own stdout so any residual Rich output
    # doesn't get interleaved with the subprocess.
    try:
        sys.stdout.flush()
        sys.stderr.flush()
    except OSError:
        # Best-effort flush before handing the TTY to a subprocess.
        # A broken stdout/stderr here means Rich already failed to
        # write its altscreen exit sequence, which is a much bigger
        # problem the subprocess will surface in its own output.
        pass


def do_monitor(console: Console, tty: str) -> None:
    """Launch htop as the unprivileged ``admin`` user.

    Running as ``admin`` (not root) means htop's interactive kill /
    renice features can only target processes that user actually owns,
    so a physical-console operator can't ctrl-K the api container or
    SIGKILL pid 1 by accident. htop itself only needs /proc reads to
    *display* every process, which any user can do — so the view stays
    full-system, only the actions are scoped.
    """
    console.clear()
    console.print("[bold]Launching htop — q or F10 to exit.[/bold]\n")
    _prepare_tty_for_subprocess(tty)
    try:
        with open(tty, "r+b", buffering=0) as tty_io:
            try:
                subprocess.run(
                    ["runuser", "-u", "admin", "--", "htop"],
                    check=False,
                    env=_term_env(),
                    stdin=tty_io,
                    stdout=tty_io,
                    stderr=tty_io,
                )
            except FileNotFoundError:
                # htop missing on this image — fall back to top.
                console.print(
                    "[yellow]htop not installed; falling back to top.[/yellow]"
                )
                subprocess.run(
                    ["runuser", "-u", "admin", "--", "top"],
                    check=False,
                    env=_term_env(),
                    stdin=tty_io,
                    stdout=tty_io,
                    stderr=tty_io,
                )
    except OSError as exc:
        console.print(f"[red]Failed to open {tty}: {exc}[/red]")
        time.sleep(3)


def do_containers(console: Console, tty: str) -> None:
    """Pod picker → per-pod log streamer.

    Issue #183 Phase 9 — list every pod with a numbered shortcut,
    prompt the operator to pick one, then ``kubectl logs -f`` until
    Ctrl-C. Loop back to the picker; q exits to the dashboard.

    Previously F3 streamed ``kubectl top pod`` (metrics-server-
    dependent) or fell through to a watch on all pods. Watch is
    useful for "did anything change" but operators triaging a real
    incident actually need logs. The new design: pick a pod, see
    its logs, ctrl-C, pick another.
    """
    _prepare_tty_for_subprocess(tty)
    env = {**os.environ, "KUBECONFIG": "/etc/rancher/k3s/k3s.yaml"}

    try:
        with open(tty, "r+b", buffering=0) as tty_io:
            while True:
                console.clear()
                console.print("[bold]F3 — Pods (logs viewer)[/bold]")
                console.print(
                    "[dim]Pick a number to tail logs (Ctrl-C exits "
                    "logs view), or q to return to dashboard.[/dim]\n"
                )

                # Re-fetch the pod list on each iteration so a pod
                # that crashed or got rescheduled between picks shows
                # its new state.
                proc = subprocess.run(
                    [
                        "/usr/local/bin/k3s", "kubectl",
                        "get", "pods", "-A", "-o", "wide",
                        "--no-headers",
                    ],
                    env=env, capture_output=True, text=True, timeout=5,
                )
                if proc.returncode != 0:
                    console.print(
                        f"[red]kubectl get pods failed: "
                        f"{proc.stderr.strip()[:200]}[/red]"
                    )
                    time.sleep(3)
                    return

                # Each line: NAMESPACE NAME READY STATUS RESTARTS AGE IP NODE …
                pods: list[tuple[str, str, str]] = []  # (ns, name, status)
                for line in proc.stdout.splitlines():
                    parts = line.split()
                    if len(parts) >= 4:
                        pods.append((parts[0], parts[1], parts[3]))

                if not pods:
                    console.print("[dim]No pods found.[/dim]")
                    time.sleep(2)
                    return

                # Two-column numbered list. Same sort as the dashboard
                # Pods panel (spatium first, then kube-system, then
                # alphabetical).
                def _ns_rank(ns: str) -> tuple[int, str]:
                    if ns == "spatium":
                        return (0, ns)
                    if ns == "kube-system":
                        return (1, ns)
                    return (2, ns)

                pods.sort(key=lambda p: (_ns_rank(p[0]), p[1]))

                for i, (ns, name, status) in enumerate(pods, 1):
                    status_color = (
                        "green" if status == "Running"
                        else "yellow" if status in ("Pending", "ContainerCreating")
                        else "red" if status in ("Error", "CrashLoopBackOff")
                        else "dim"
                    )
                    console.print(
                        f"  [bold cyan]{i:>2}[/bold cyan]  "
                        f"[dim]{ns:<14}[/dim] {name}  "
                        f"[{status_color}]{status}[/{status_color}]"
                    )

                console.print("")
                try:
                    answer = input("Pick (number/q): ").strip().lower()
                except (EOFError, KeyboardInterrupt):
                    return
                if not answer or answer == "q":
                    return

                try:
                    pick = int(answer)
                except ValueError:
                    console.print("[red]Not a number.[/red]")
                    time.sleep(1)
                    continue

                if not (1 <= pick <= len(pods)):
                    console.print(
                        f"[red]Out of range (1-{len(pods)}).[/red]"
                    )
                    time.sleep(1)
                    continue

                ns, name, _ = pods[pick - 1]
                console.clear()
                console.print(
                    f"[bold]kubectl logs -f -n {ns} {name}[/bold]  "
                    f"[dim](Ctrl-C to return to picker)[/dim]\n"
                )
                try:
                    subprocess.run(
                        [
                            "/usr/local/bin/k3s", "kubectl",
                            "logs", "-f", "--tail=200",
                            "-n", ns, name,
                        ],
                        env=env,
                        stdin=tty_io, stdout=tty_io, stderr=tty_io,
                        check=False,
                    )
                except KeyboardInterrupt:
                    pass
                # Loop back to picker.
    except OSError as exc:
        console.print(f"[red]Failed to open {tty}: {exc}[/red]")
        time.sleep(3)


def do_network(console: Console, tty: str) -> None:
    """Hand off to nmtui for network reconfiguration.

    Runs as root because every meaningful nmtui action (add / edit /
    activate a connection) calls into NetworkManager via D-Bus and
    needs the network-manager polkit privilege — root is the simplest
    way to grant that without configuring polkit rules. The operator
    at the physical console is already trusted enough to reboot /
    power off the appliance, so privilege-escalation isn't the threat
    model here.
    """
    console.clear()
    _prepare_tty_for_subprocess(tty)
    # Same TTY-redirect pattern as do_pair — keep stderr off the
    # journald pipe so ncurses error / status output reaches the
    # screen.
    try:
        with open(tty, "r+b", buffering=0) as tty_io:
            subprocess.run(
                ["nmtui"],
                check=False,
                env=_term_env(),
                stdin=tty_io,
                stdout=tty_io,
                stderr=tty_io,
            )
    except FileNotFoundError:
        console.print(
            "[red]nmtui not installed — this appliance image predates the "
            "NetworkManager switch. Edit /etc/systemd/network/ files and run "
            "`systemctl restart systemd-networkd` to reconfigure.[/red]"
        )
        time.sleep(4)
    except OSError as exc:
        console.print(f"[red]Failed to open {tty}: {exc}[/red]")
        time.sleep(3)


def do_pair(console: Console, tty: str) -> None:
    """Run ``spatium-pair`` to re-enter control-plane URL + pairing code.

    Strict appliance-application gate — refuses on full-stack /
    frontend-core boxes (those ARE the control plane; nothing to
    pair against). The CLI itself prints a useful error if invoked
    on a non-application role, so the gate here is purely a UX
    polish to avoid running the tool when it can't help.
    """
    role_config = Path("/etc/spatiumddi/role-config")
    if not role_config.exists():
        console.print(
            "[yellow]spatium-pair is only available on Application "
            "appliances; this box has no /etc/spatiumddi/role-config.[/yellow]"
        )
        time.sleep(3)
        return
    try:
        text = role_config.read_text(encoding="utf-8")
    except OSError:
        text = ""
    is_application = any(
        line.strip() == "ROLE=application" for line in text.splitlines()
    )
    if not is_application:
        console.print(
            "[yellow]This appliance isn't an Application role — "
            "spatium-pair only applies to remote-paired boxes.[/yellow]"
        )
        time.sleep(3)
        return
    console.clear()
    _prepare_tty_for_subprocess(tty)
    # CRITICAL: explicitly route stdin / stdout / stderr to the TTY.
    # The systemd unit sets ``StandardError=journal`` so the Python
    # process's stderr is a pipe to journald, NOT the terminal.
    # spatium-pair uses the standard bash whiptail idiom ``3>&1 1>&2
    # 2>&3`` which swaps stdout ↔ stderr so whiptail's UI (drawn on
    # whatever ends up as fd 2 post-swap) reaches the terminal. With
    # stderr → journald inherited, the swap puts whiptail's UI on the
    # journald pipe instead — operator sees a blank screen. Forcing
    # all three streams to the TTY here bypasses the journald redirect.
    try:
        with open(tty, "r+b", buffering=0) as tty_io:
            subprocess.run(
                ["spatium-pair"],
                check=False,
                env=_term_env(),
                stdin=tty_io,
                stdout=tty_io,
                stderr=tty_io,
            )
    except FileNotFoundError:
        console.print("[red]spatium-pair not installed[/red]")
        time.sleep(3)
    except OSError as exc:
        console.print(f"[red]Failed to open {tty}: {exc}[/red]")
        time.sleep(3)


# ── main loop ─────────────────────────────────────────────────────────


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--tty", default=os.ttyname(0) if sys.stdin.isatty() else "/dev/tty1",
                    help="TTY device path (default: stdin's tty or /dev/tty1)")
    ap.add_argument("--dev", action="store_true",
                    help="Dev mode: synthetic env + skip privileged actions")
    args = ap.parse_args()

    # Don't die on SIGHUP — systemd sends one when the TTY hangs up
    # briefly during the F1 → agetty handoff. SIGTERM is honoured.
    signal.signal(signal.SIGHUP, signal.SIG_IGN)

    # Probe the target TTY before doing anything expensive (docker
    # subprocess calls, journal-tail thread, psutil sampler). The
    # kernel always creates /dev/ttyS0 + /dev/ttyS1 + ... when boot
    # cmdline carries ``console=ttyS0,…`` even if the VM has no
    # actual serial device attached — systemd-getty-generator spawns
    # serial-getty@ttyS0 unconditionally, and the corresponding
    # spatium-console@ttyS0 instance inherits the same fate.
    # Without this guard the dashboard goes Live(...) → first frame
    # render → EIO on stdout.flush() → exit 1 → systemd Restart=always
    # respawns in 2 s, repeat forever. Each spawn calls docker_ps()
    # once before failing, which generates a broken-pipe entry on
    # docker.sock — and at 2 s intervals that's ~30 noise lines/min
    # in the docker daemon journal for the no-op crash loop. Bailing
    # out cleanly with exit 0 plus systemd's Restart=on-failure
    # semantics would be cleaner, but the existing unit uses
    # Restart=always so we end the loop via RestartPreventExitStatus
    # — a separate unit-file change adds 75 to that list.
    if not args.dev:
        try:
            with open(args.tty, "wb", buffering=0) as probe:
                probe.write(b"")
        except OSError as exc:
            print(
                f"spatium-console: {args.tty} not usable ({exc.strerror}); "
                "skipping dashboard render.",
                file=sys.stderr,
            )
            return 75  # EX_TEMPFAIL — paired with RestartPreventExitStatus=75

    env = read_env() if not args.dev else {
        "APPLIANCE_ROLE": "full-stack",
        "APPLIANCE_HOSTNAME": "ddi-dev-01",
        "APPLIANCE_VERSION": "0.1.0-dev",
        "SPATIUMDDI_VERSION": "dev",
        "CONTROL_PLANE_URL": "https://ddi.example.com",
        "AGENT_GROUP": "default",
    }

    tail = JournalTail(JOURNAL_UNITS)
    tail.start()

    # Prime psutil's CPU sampler so the first frame doesn't show 0.0% —
    # cpu_percent(None) returns the delta since the last call; the
    # first call always returns 0.0 because there's no baseline yet.
    psutil.cpu_percent(interval=None)

    state = DashboardState(env, tail, args.tty)
    state.refresh(force=True)  # prime cached vitals so first frame isn't all zeros

    console = Console(soft_wrap=False, force_terminal=True, safe_box=True)
    state.term_size = console.size

    def on_key(key: str) -> None:
        if key == "F1":
            state.set_action("login")
        elif key == "F5":
            state.set_action("reboot")
        elif key == "F6":
            state.set_action("shutdown")
        elif key == "F2":
            state.set_action("monitor")
        elif key == "F3":
            state.set_action("containers")
        elif key == "F4":
            state.set_action("network")
        elif key == "F8":
            state.set_action("pair")

    keys = KeyReader(on_key)
    keys.start()

    try:
        first_t = time.monotonic()
        # ``auto_refresh=False`` disables Rich's background refresh
        # thread — we drive every frame from the main loop's
        # ``live.update()`` call below. With auto_refresh on (the
        # default), Rich's internal thread spins at refresh_per_second
        # AND the main loop re-renders on every REFRESH_INTERVAL tick,
        # doubling the render cost for no visual benefit. CPU on a
        # 1-CPU appliance VM dropped from ~92 % to ~30 % after the
        # toggle.
        with Live(render_frame(state, first_t), console=console,
                  refresh_per_second=4, auto_refresh=False,
                  screen=True, transient=False) as live:
            while True:
                mono_t = time.monotonic()
                state.refresh()  # self-throttling — only polls docker every DATA_REFRESH_EVERY
                state.term_size = console.size
                # ``refresh=True`` is required when Live is constructed
                # with ``auto_refresh=False`` — otherwise update() just
                # stores the new renderable and the screen stays stale.
                live.update(render_frame(state, mono_t), refresh=True)

                # Drain pending action if any.
                action = None
                with state.lock:
                    if state.pending_action:
                        action = state.pending_action
                        state.pending_action = None
                if action:
                    if args.dev:
                        state.flash(f"[dev] would invoke action: {action}", ttl=4)
                    else:
                        # Tear down keypress raw mode + Live so the action
                        # has a clean cooked-tty.
                        keys.stop()
                        live.stop()
                        try:
                            if action == "login":
                                do_login(args.tty)  # noreturn
                            elif action == "reboot":
                                do_reboot(console)
                            elif action == "shutdown":
                                do_shutdown(console)
                            elif action == "monitor":
                                do_monitor(console, args.tty)
                            elif action == "containers":
                                do_containers(console, args.tty)
                            elif action == "network":
                                do_network(console, args.tty)
                            elif action == "pair":
                                do_pair(console, args.tty)
                        finally:
                            # Hard-reset the terminal state before
                            # re-entering Live. whiptail (do_pair) +
                            # nmtui (do_network) + htop (do_monitor)
                            # can leave the TTY in altscreen-on / raw
                            # mode / corrupted colour state if they
                            # exit abnormally; without an explicit
                            # reset the next ``live.start()`` either
                            # renders against the wrong cursor coords
                            # or crashes on the first flush — and
                            # systemd's Restart=always burns through
                            # the start-limit before the dashboard
                            # recovers, leaving operators staring at
                            # a black tty1. ``stty sane`` + the
                            # ``\x1b[?1049l`` (exit-altscreen) + ESC c
                            # (full reset) sequence are cheap and
                            # idempotent on a working TTY.
                            try:
                                subprocess.run(
                                    ["stty", "sane"], check=False, timeout=2
                                )
                                with open(args.tty, "w") as tty_out:
                                    tty_out.write("\x1b[?1049l\x1bc")
                                    tty_out.flush()
                            except OSError:
                                pass
                            # Re-arm keypress capture, re-enter Live.
                            keys = KeyReader(on_key)
                            keys.start()
                            live.start()

                time.sleep(REFRESH_INTERVAL)
    except KeyboardInterrupt:
        return 0
    finally:
        tail.stop()
        keys.stop()


if __name__ == "__main__":
    sys.exit(main())
