#!/bin/sh
# SpatiumDDI appliance first-boot orchestrator.
#
# Runs on every boot but only performs first-boot setup once. On first
# run: generates secrets, writes /etc/spatiumddi/.env, pulls the
# ghcr.io image set, and brings up the docker-compose stack. On
# subsequent boots: just `docker-compose up -d` to ensure the stack is
# running.
#
# Output is mirrored to /var/log/spatiumddi/firstboot.log so the
# operator can debug from the console without journalctl.

set -eu

LOG=/var/log/spatiumddi/firstboot.log
ENV_FILE=/etc/spatiumddi/.env
COMPOSE_DIR=/usr/local/share/spatiumddi
STAMP=/var/lib/spatiumddi/firstboot.done

mkdir -p "$(dirname "$LOG")" "$(dirname "$STAMP")"
exec >>"$LOG" 2>&1
echo "=== spatiumddi-firstboot $(date -Iseconds) ==="

# ── Swap (created once, idempotent) ──────────────────────────────────────────
# 2 GiB swapfile if the system has no active swap. Protects docker
# containers (Postgres / api / worker) from OOM when memory tightens.
# Sized small — operators with bigger workloads can grow it.
SWAPFILE=/var/lib/spatiumddi/swapfile
if [ "$(swapon --show=NAME --noheadings | wc -l)" = "0" ] && [ ! -f "$SWAPFILE" ]; then
    echo "Creating 2 GiB swapfile at $SWAPFILE"
    if fallocate -l 2G "$SWAPFILE" 2>/dev/null || \
       dd if=/dev/zero of="$SWAPFILE" bs=1M count=2048 status=none; then
        chmod 0600 "$SWAPFILE"
        mkswap "$SWAPFILE" && swapon "$SWAPFILE"
        if ! grep -q "^$SWAPFILE " /etc/fstab 2>/dev/null; then
            echo "$SWAPFILE none swap sw 0 0" >> /etc/fstab
        fi
    else
        echo "WARN: couldn't create swapfile — continuing without swap"
    fi
fi

gen_hex()    { openssl rand -hex "${1:-32}"; }
gen_fernet() { openssl rand 32 | base64 | tr -d '\n' | tr '+/' '-_'; }

# Read optional release pin dropped by cloud-init.
SPATIUMDDI_VERSION="latest"
if [ -f /etc/spatiumddi/release ]; then
    # shellcheck disable=SC1091
    . /etc/spatiumddi/release
fi

# Host-side state dirs the api container bind-mounts (Phase 4c/4e/4f).
# 1000 is the uid+gid of the ``app`` user inside the api image —
# chown'ing here lets the unprivileged container write trigger files
# / read diagnostic data without anyone running docker exec --user root.
mkdir -p /var/lib/spatiumddi/release-state /var/log/spatiumddi
chown -R 1000:1000 /var/lib/spatiumddi/release-state
# 1777 (rwxrwxrwt) — Phase 8f-4 fleet upgrade also has the DNS / DHCP
# agent containers write into this directory (their unprivileged
# ``spatium`` user has a different uid than the api's ``app`` user, so
# 0755 + chown 1000:1000 wouldn't let them through). Sticky bit
# prevents one container from removing another's pending trigger. The
# directory only carries trigger files + state sidecars — no secrets,
# no operator data — so world-write is acceptable here.
chmod 1777 /var/lib/spatiumddi/release-state
chmod 0755 /var/log/spatiumddi

if [ ! -f "$ENV_FILE" ]; then
    echo "Generating $ENV_FILE (first boot)"
    umask 077
    # Appliance metadata for the Phase 4 management hub. APPLIANCE_VERSION
    # tracks the ISO release (set from /etc/spatiumddi/appliance-release
    # if dropped at build time, otherwise the placeholder 0.1.0).
    # APPLIANCE_HOSTNAME is the kernel's view of `hostname` at first
    # boot; the management UI displays it as a chip next to the title.
    # Both flow through the api container's compose env into Settings.
    APPLIANCE_VERSION_VAL="0.1.0"
    if [ -f /etc/spatiumddi/appliance-release ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/appliance-release
        APPLIANCE_VERSION_VAL="${APPLIANCE_VERSION:-0.1.0}"
    fi
    APPLIANCE_HOSTNAME_VAL=$(hostname 2>/dev/null || echo "spatiumddi")
    # Host's globally-scoped IPv4/IPv6 addresses, comma-separated.
    # The api container is on docker's bridge network and can't see
    # the host's real IPs from inside; without this env var the
    # self-signed cert (Phase 4b.5) would only carry the docker-bridge
    # IP (e.g. 172.18.0.5) as a SAN, which browsers pointing at the
    # host IP see as a SAN mismatch. By exporting the real host IPs
    # here, ensure_self_signed_cert() puts the right SANs in the cert
    # and the warning becomes just "unknown CA" instead of
    # "subject mismatch + unknown CA". Operator-uploaded certs are
    # unaffected (the operator supplies whatever SANs they need).
    APPLIANCE_HOST_IPS_VAL=$(ip -o addr show scope global 2>/dev/null \
        | awk '{print $4}' | cut -d/ -f1 | paste -sd, -)
    # Docker socket gid — the api container's `app` user needs
    # supplementary group access to /var/run/docker.sock for the
    # Phase 4b.2 cert-deployer SIGHUP + Phase 4d container management.
    # Read the gid off the live socket so we track whatever the
    # docker.io package install picked (defaults to 999 on Debian
    # but can drift). Falls back to 999 if the socket doesn't exist
    # yet (firstboot races docker.service); the compose group_add
    # has the same default.
    DOCKER_GID_VAL=$(stat -c '%g' /var/run/docker.sock 2>/dev/null || echo "999")
    # #170 Wave B2 role rename: control → full-stack, control-only →
    # frontend-core, dns-agent-* / dhcp-agent → application (single
    # generic agent role; the control plane assigns per-role
    # behaviour after admin approval). spatium-install drops
    # /etc/spatiumddi/role-config with ROLE + CONTROL_PLANE_URL +
    # BOOTSTRAP_PAIRING_CODE (application role only). The pre-B2
    # legacy keys (DNS_AGENT_KEY / DHCP_AGENT_KEY / AGENT_GROUP) are
    # still parsed for backwards-compat with appliances installed
    # off an A4-era ISO; the legacy roles below alias to their
    # post-B2 equivalents so an in-field appliance keeps booting
    # after a slot upgrade.
    ROLE=full-stack
    INSTALL_CONTROL_PLANE_URL=""
    INSTALL_BOOTSTRAP_PAIRING_CODE=""
    # Legacy (pre-B2) bridges, only read when the role-config carries
    # one of the old role names.
    INSTALL_DNS_AGENT_KEY=""
    INSTALL_DHCP_AGENT_KEY=""
    INSTALL_AGENT_GROUP=""
    if [ -f /etc/spatiumddi/role-config ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/role-config
        INSTALL_CONTROL_PLANE_URL="${CONTROL_PLANE_URL:-}"
        INSTALL_BOOTSTRAP_PAIRING_CODE="${BOOTSTRAP_PAIRING_CODE:-}"
        INSTALL_DNS_AGENT_KEY="${DNS_AGENT_KEY:-}"
        INSTALL_DHCP_AGENT_KEY="${DHCP_AGENT_KEY:-}"
        INSTALL_AGENT_GROUP="${AGENT_GROUP:-}"
    fi

    # Map legacy role names onto the new shape. Existing dev / lab
    # appliances installed off an A4-era ISO keep booting through this
    # alias path. New installs (B2+) write the post-B2 names directly.
    case "$ROLE" in
        control)             ROLE=full-stack ;;
        control-only)        ROLE=frontend-core ;;
        dns-agent-bind9|dns-agent-powerdns|dhcp-agent)
            # Old per-service agents become Application. The control
            # plane assigns the role + group + DNS engine after admin
            # approval in the fleet UI; the supervisor pulls the
            # matching service container then.
            ROLE=application
            ;;
    esac

    # COMPOSE_PROFILES drives which services come up.
    #   full-stack    → full control plane + bundled BIND9 + Kea.
    #   frontend-core → control plane only.
    #   application   → spatium-supervisor + agent-landing static
    #                   page; no service container until the control
    #                   plane assigns a role (Wave C).
    # Agent keys: control planes (full-stack / frontend-core)
    # generate fresh DNS+DHCP agent keys so the operator can reveal
    # + paste them into legacy agent installs from the Settings UI.
    # Application appliances don't need them — the supervisor's
    # Ed25519 keypair + control-plane-CA-signed cert is the only
    # identity. .env still carries empty values so compose's env
    # subst doesn't error.
    BOOTSTRAP_PAIRING_CODE_VAL=""
    case "$ROLE" in
        application)
            # Supervisor (mandatory) + agent-landing static page so
            # ``curl http://<appliance>/`` confirms the box is up +
            # which control plane it pairs against. Role assignment
            # (DNS / DHCP / multi-role) happens later from the fleet
            # UI; service containers start then.
            COMPOSE_PROFILES_VAL="supervisor,agent"
            DNS_AGENT_KEY_VAL=""
            DHCP_AGENT_KEY_VAL=""
            BOOTSTRAP_PAIRING_CODE_VAL="$INSTALL_BOOTSTRAP_PAIRING_CODE"
            CONTROL_PLANE_URL_VAL="$INSTALL_CONTROL_PLANE_URL"
            AGENT_GROUP_VAL="default"
            ;;
        frontend-core)
            # Control plane only — no bundled DNS/DHCP. Agent keys
            # are still generated because the operator's whole reason
            # for picking this role is to register external agents.
            # They reveal the keys via Settings → Security → Agent
            # bootstrap keys (or mint pairing codes under
            # /appliance → Pairing for B2+ Application appliances).
            COMPOSE_PROFILES_VAL="control"
            DNS_AGENT_KEY_VAL=$(gen_hex 24)
            DHCP_AGENT_KEY_VAL=$(gen_hex 24)
            CONTROL_PLANE_URL_VAL=""
            AGENT_GROUP_VAL="default"
            ;;
        *)
            # ``full-stack`` (default) — control plane + bundled
            # BIND9 + Kea. Single-box AIO deployment. Bundled agents
            # register into the same default group so an external
            # agent joining later lands alongside them.
            ROLE=full-stack
            COMPOSE_PROFILES_VAL="control,dns-bind9,dhcp"
            DNS_AGENT_KEY_VAL=$(gen_hex 24)
            DHCP_AGENT_KEY_VAL=$(gen_hex 24)
            CONTROL_PLANE_URL_VAL=""
            AGENT_GROUP_VAL="default"
            ;;
    esac
    cat > "$ENV_FILE" <<EOF
# Auto-generated by spatiumddi-firstboot on $(date -Iseconds).
# Edit + run \`docker-compose -f $COMPOSE_DIR/docker-compose.yml up -d\` to apply.
# Appliance role (#170 Wave B2): $ROLE
SPATIUMDDI_VERSION=${SPATIUMDDI_VERSION}
POSTGRES_PASSWORD=$(gen_hex 24)
SECRET_KEY=$(gen_hex 32)
CREDENTIAL_ENCRYPTION_KEY=$(gen_fernet)
DNS_AGENT_KEY=${DNS_AGENT_KEY_VAL}
DHCP_AGENT_KEY=${DHCP_AGENT_KEY_VAL}
BOOTSTRAP_PAIRING_CODE=${BOOTSTRAP_PAIRING_CODE_VAL}
COMPOSE_PROFILES=${COMPOSE_PROFILES_VAL}
CONTROL_PLANE_URL=${CONTROL_PLANE_URL_VAL}
AGENT_GROUP=${AGENT_GROUP_VAL}
APPLIANCE_ROLE=${ROLE}
APPLIANCE_VERSION=${APPLIANCE_VERSION_VAL}
APPLIANCE_HOSTNAME=${APPLIANCE_HOSTNAME_VAL}
APPLIANCE_HOST_IPS=${APPLIANCE_HOST_IPS_VAL}
DOCKER_GID=${DOCKER_GID_VAL}
EOF
    chmod 600 "$ENV_FILE"

    # #170 Wave B2 — for Application installs, render the agent
    # landing page from the template into /var/lib/spatiumddi/
    # agent-landing/ where the nginx:alpine sidecar mounts it
    # read-only. Frontend-core / full-stack don't need it — the
    # SpatiumDDI frontend serves the web UI on those roles.
    #
    # The ``umask 077`` set earlier (for the .env's secrets) leaks
    # into the mkdir + sed > index.html and would leave the file
    # mode 600 + dir 700 — nginx-the-process runs as uid 101 inside
    # the alpine image and can't read root-owned 600 files, so the
    # landing page would return 403. Reset umask before the write.
    umask 022
    case "$ROLE" in
        application)
            mkdir -p /var/lib/spatiumddi/agent-landing
            chmod 0755 /var/lib/spatiumddi/agent-landing
            # Role-specific labels for the static landing page. The
            # supervisor doesn't know its assigned service role yet
            # (control plane decides post-approval); the landing
            # surface reflects "supervisor, awaiting role" until the
            # fleet UI assigns one. The Wave-D fleet UI will rewrite
            # the page on role assignment.
            ROLE_LABEL="Application (awaiting approval)"
            ROLE_SHORT="supervisor"
            sed \
                -e "s|__ROLE__|${ROLE}|g" \
                -e "s|__ROLE_LABEL__|${ROLE_LABEL}|g" \
                -e "s|__ROLE_SHORT__|${ROLE_SHORT}|g" \
                -e "s|__HOSTNAME__|${APPLIANCE_HOSTNAME_VAL}|g" \
                -e "s|__CONTROL_PLANE_URL__|${INSTALL_CONTROL_PLANE_URL}|g" \
                -e "s|__APPLIANCE_VERSION__|${APPLIANCE_VERSION_VAL}|g" \
                /usr/local/share/spatiumddi/agent-landing/index.html.in \
                > /var/lib/spatiumddi/agent-landing/index.html
            chmod 0644 /var/lib/spatiumddi/agent-landing/index.html
            ;;
    esac
fi

# docker-compose looks for .env in the compose file's directory.
ln -sfn "$ENV_FILE" "$COMPOSE_DIR/.env"

cd "$COMPOSE_DIR"

# Re-runs of firstboot (post-reboot) need APPLIANCE_ROLE to drive
# the role-aware readiness check below. The fresh-install branch
# already sets it inline; on re-runs we reload it from .env so the
# variable is in scope no matter which path got us here.
if [ -z "${APPLIANCE_ROLE:-}" ] && [ -f "$ENV_FILE" ]; then
    APPLIANCE_ROLE=$(grep -E '^APPLIANCE_ROLE=' "$ENV_FILE" | tail -1 | cut -d= -f2-)
    CONTROL_PLANE_URL=$(grep -E '^CONTROL_PLANE_URL=' "$ENV_FILE" | tail -1 | cut -d= -f2-)
    export APPLIANCE_ROLE CONTROL_PLANE_URL
fi

# Wait for the docker daemon socket to be ready. systemd's
# After=docker.service only means docker.service was STARTED, not
# that dockerd has finished initialising and accepting connections
# on /var/run/docker.sock. Without this wait, docker-compose pull
# can race and emit "Cannot connect to the Docker daemon" for a
# subset of services.
echo "Waiting for docker daemon..."
for i in $(seq 1 30); do
    if docker info >/dev/null 2>&1; then break; fi
    sleep 1
done
docker info >/dev/null 2>&1 || {
    echo "ERROR: docker daemon never came up after 30 s"
    exit 1
}

# Wait for DNS resolution. systemd-resolved is the resolver but it
# needs NetworkManager to have an IP + DNS info from DHCP first
# (NM hands DNS info to resolved over D-Bus). With a slow DHCP
# server we'd otherwise race and `docker-compose pull` would fail
# on the first image with "lookup registry-1.docker.io on ::1:53:
# read: connection refused" because /etc/resolv.conf is resolved's
# symlink and resolved hasn't been told a DNS server yet.
echo "Waiting for DNS resolution..."
for i in $(seq 1 30); do
    if getent hosts registry-1.docker.io >/dev/null 2>&1; then break; fi
    sleep 2
done
getent hosts registry-1.docker.io >/dev/null 2>&1 || {
    echo "WARN: DNS for registry-1.docker.io didn't resolve after 60 s — pull will likely fail."
    echo "      Check 'resolvectl status' and 'nmcli device status'."
}

# Phase 4 dev-iteration support — if this ISO was built with
# ``bake-images.sh``, it ships locally-built image tarballs at
# /usr/local/share/spatiumddi/images/*.tar.zst. Load each one
# into the daemon BEFORE attempting any pull, so the operator's
# in-flight changes take precedence over whatever's pullable
# from ghcr.io. The marker file ``BAKED_AT`` is dropped by
# bake-images.sh; its presence is the signal "this slot carries
# offline images". When present we skip docker-compose pull
# entirely (pulls of unpublished tags would 404 against ghcr).
#
# Slot-upgrade aware: each slot rootfs ships its own BAKED_AT
# stamp. We persist the last-loaded BAKED_AT timestamp on the
# shared /var partition; if the rootfs's BAKED_AT is newer, we
# re-load the tarballs even on a non-first boot. This is what
# makes ``spatium-upgrade-slot apply`` followed by a reboot
# actually pick up the new container images — without it, the
# previous slot's STAMP shorts out the load and docker-compose
# happily reuses the stale images already on /var/lib/docker.
IMAGES_DIR=/usr/local/share/spatiumddi/images
BAKED_AT_FILE="$IMAGES_DIR/BAKED_AT"
LOADED_AT_FILE=/var/lib/spatiumddi/images-loaded-at
BAKED=0
LOAD_REASON=""

if [ -f "$BAKED_AT_FILE" ]; then
    rootfs_baked_at=$(cat "$BAKED_AT_FILE")
    loaded_baked_at=""
    [ -f "$LOADED_AT_FILE" ] && loaded_baked_at=$(cat "$LOADED_AT_FILE")
    if [ ! -f "$STAMP" ]; then
        LOAD_REASON="first boot (baked $rootfs_baked_at)"
    elif [ "$rootfs_baked_at" != "$loaded_baked_at" ]; then
        LOAD_REASON="rootfs BAKED_AT changed (was $loaded_baked_at, now $rootfs_baked_at) — slot upgrade detected"
    fi

    if [ -n "$LOAD_REASON" ]; then
        echo "Loading pre-baked container images from $IMAGES_DIR — $LOAD_REASON"
        for img in "$IMAGES_DIR"/*.tar.zst; do
            [ -f "$img" ] || continue
            echo "  → $(basename "$img")"
            zstd -dc "$img" | docker load
        done

        # #170 Phase A4 — stamp the ``<image>:slot-baked`` alias on
        # every SpatiumDDI image loaded above. The supervisor's
        # air-gap-strict mode (Wave C polish) references images by
        # this stable local tag so a compose template doesn't have to
        # carry the CalVer version through env substitution. Reading
        # the version from the bake's VERSION sidecar (which the bake
        # script writes alongside BAKED_AT) avoids re-parsing the
        # tarball filenames.
        if [ -f "$IMAGES_DIR/VERSION" ]; then
            baked_version=$(cat "$IMAGES_DIR/VERSION")
            for image in \
                ghcr.io/spatiumddi/spatiumddi-api \
                ghcr.io/spatiumddi/spatiumddi-frontend \
                ghcr.io/spatiumddi/spatium-supervisor \
                ghcr.io/spatiumddi/dns-bind9 \
                ghcr.io/spatiumddi/dns-powerdns \
                ghcr.io/spatiumddi/dhcp-kea; do
                if docker image inspect "${image}:${baked_version}" >/dev/null 2>&1; then
                    docker tag "${image}:${baked_version}" "${image}:slot-baked" \
                        2>/dev/null || true
                fi
            done
        fi

        echo "$rootfs_baked_at" > "$LOADED_AT_FILE"
        BAKED=1
    fi
fi

if [ ! -f "$STAMP" ] && [ "$BAKED" = 0 ]; then
    # No locally-baked images present (clean ISO from ghcr.io
    # release artefact) — first boot must pull.
    echo "Pulling SpatiumDDI image set (first boot)..."
    # Retry pull on transient failures (slow image hosts, partial
    # download). set -e at the script top would otherwise kill us
    # on the first transient blip.
    pull_ok=0
    for i in 1 2 3; do
        if docker-compose pull; then
            pull_ok=1
            break
        fi
        echo "Pull attempt $i failed; retrying in 10 s..."
        sleep 10
    done
    [ "$pull_ok" = 1 ] || {
        echo "ERROR: docker-compose pull failed 3 times. Check network + DNS."
        exit 1
    }
elif [ "$BAKED" = 1 ]; then
    echo "Skipping docker-compose pull (locally-baked images installed)."
fi

echo "Bringing stack up..."
docker-compose up -d

# Phase 8 — refresh /var/lib/spatiumddi/release-state/slot-versions.json
# so the OS Image card + Fleet view show the right APPLIANCE_VERSION
# per slot. Best-effort: a failure here doesn't block the stack from
# coming up, the api just falls back to "unknown" for both slots.
if [ -x /usr/local/bin/spatium-upgrade-slot ] && [ -e /etc/spatiumddi/role-config ]; then
    /usr/local/bin/spatium-upgrade-slot sync-versions || \
        echo "WARN: sync-versions failed — OS Image card will show 'unknown' for slot versions"
fi

# Role-aware readiness check.
#
# full-stack / frontend-core roles run the api container, which
# exposes /health/live on port 8000 (port-mapped to the host). Poll
# until it answers; that's the "the operator can sign in now" signal.
#
# application (and legacy dns-* / dhcp-* roles still running from
# pre-B2 installs) don't run a local api — there's no /health/live
# to poll on this box. Instead, confirm every container in the active
# compose profile reports state=running. The supervisor itself
# retries forever against the remote control plane, so "containers
# up" is the strongest signal we can give without a round trip across
# the LAN.
# Phase 8c — commit the active slot as the durable default after a
# successful trial boot. spatium-upgrade-slot set-next-boot writes a
# one-shot saved_entry to grubenv via grub-reboot; that's auto-cleared
# on this boot. If THIS boot is healthy, we make the swap permanent
# via grub-set-default. If anything fails before this point, the
# previous slot's saved_entry stays in grubenv → next reboot reverts.
commit_slot_if_healthy() {
    local grub_boot_dir=/boot/efi
    if [ ! -f "${grub_boot_dir}/grub/grubenv" ]; then
        # Pre-Phase-8c install (grub.cfg on /boot/grub) — nothing to commit.
        return 0
    fi
    # Which slot are we booted from? Read root= partition UUID from
    # /proc/cmdline, look it up against partition labels.
    local root_uuid="" current_slot=""
    root_uuid=$(awk 'BEGIN{RS=" "} /^root=UUID=/{print substr($0,11)}' /proc/cmdline 2>/dev/null | head -1)
    if [ -n "$root_uuid" ]; then
        # blkid returns the device; lsblk gives us PARTLABEL.
        local root_dev
        root_dev=$(blkid -U "$root_uuid" 2>/dev/null)
        if [ -n "$root_dev" ]; then
            current_slot=$(lsblk -no PARTLABEL "$root_dev" 2>/dev/null | tr 'A-Z' 'a-z' | head -1)
        fi
    fi
    case "$current_slot" in
        root_a) current_slot=slot_a ;;
        root_b) current_slot=slot_b ;;
        *)      return 0 ;;
    esac
    # Read grubenv's current default. If it already matches us,
    # nothing to do (we're the durable default — no in-flight upgrade).
    local saved
    saved=$(grub-editenv "${grub_boot_dir}/grub/grubenv" list 2>/dev/null \
            | awk -F= '/^saved_entry=/{print $2}')
    if [ "$saved" = "$current_slot" ]; then
        echo "  slot $current_slot is already the durable default — nothing to commit."
        return 0
    fi
    echo "  trial boot detected (booted=$current_slot, durable=${saved:-unset})."
    echo "  /health/live passed — committing $current_slot as the new default."
    grub-set-default --boot-directory="$grub_boot_dir" "$current_slot" \
        >> "$LOG" 2>&1 || true
}

case "${APPLIANCE_ROLE:-full-stack}" in
    full-stack|frontend-core|control|control-only)
        echo "Waiting for control plane on http://127.0.0.1:8000/health/live …"
        for i in $(seq 1 60); do
            if curl -fsS --max-time 3 http://127.0.0.1:8000/health/live >/dev/null 2>&1; then
                date -Iseconds > "$STAMP"
                IP=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
                echo "Ready: http://${IP:-<appliance-ip>}/"
                commit_slot_if_healthy
                exit 0
            fi
            sleep 5
        done
        echo "WARN: /health/live did not respond within 5 minutes." >&2
        echo "      Check 'docker-compose -f $COMPOSE_DIR/docker-compose.yml logs'." >&2
        exit 1
        ;;
    *)
        echo "Waiting for agent container(s) to start (role=${APPLIANCE_ROLE}) …"
        for i in $(seq 1 30); do
            # Every service that COULD be running per the profile set
            # must report state=running. Allow up to 2.5 min before we
            # give up; agent images may need to docker-pull on first
            # boot if they weren't baked into the ISO.
            non_running=$(docker-compose ps --status=created --status=exited --status=dead --status=restarting -q 2>/dev/null | wc -l)
            total=$(docker-compose ps -q 2>/dev/null | wc -l)
            if [ "$total" -gt 0 ] && [ "$non_running" -eq 0 ]; then
                date -Iseconds > "$STAMP"
                IP=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
                echo "Ready: agent appliance up at http://${IP:-<appliance-ip>}/"
                echo "       Agent registers against: ${CONTROL_PLANE_URL:-<not set>}"
                echo "       Live state: docker logs spatiumddi-*-1"
                commit_slot_if_healthy
                exit 0
            fi
            sleep 5
        done
        echo "WARN: agent containers did not all report 'running' within 2.5 minutes." >&2
        echo "      Check 'docker-compose -f $COMPOSE_DIR/docker-compose.yml logs'." >&2
        exit 1
        ;;
esac
