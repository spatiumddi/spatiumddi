#!/bin/sh
# SpatiumDDI appliance first-boot orchestrator.
#
# Runs on every boot but only performs first-boot setup once. On first
# run: generates secrets, writes /etc/spatiumddi/.env, pulls the
# ghcr.io image set, and brings up the docker-compose stack. On
# subsequent boots: just `docker-compose up -d` to ensure the stack is
# running.
#
# Output is mirrored to /var/log/spatiumddi/firstboot.log so the
# operator can debug from the console without journalctl.

set -eu

LOG=/var/log/spatiumddi/firstboot.log
ENV_FILE=/etc/spatiumddi/.env
COMPOSE_DIR=/usr/local/share/spatiumddi
STAMP=/var/lib/spatiumddi/firstboot.done

mkdir -p "$(dirname "$LOG")" "$(dirname "$STAMP")"
exec >>"$LOG" 2>&1
echo "=== spatiumddi-firstboot $(date -Iseconds) ==="

# ── Swap (created once, idempotent) ──────────────────────────────────────────
# 2 GiB swapfile if the system has no active swap. Protects docker
# containers (Postgres / api / worker) from OOM when memory tightens.
# Sized small — operators with bigger workloads can grow it.
SWAPFILE=/var/lib/spatiumddi/swapfile
if [ "$(swapon --show=NAME --noheadings | wc -l)" = "0" ] && [ ! -f "$SWAPFILE" ]; then
    echo "Creating 2 GiB swapfile at $SWAPFILE"
    if fallocate -l 2G "$SWAPFILE" 2>/dev/null || \
       dd if=/dev/zero of="$SWAPFILE" bs=1M count=2048 status=none; then
        chmod 0600 "$SWAPFILE"
        mkswap "$SWAPFILE" && swapon "$SWAPFILE"
        if ! grep -q "^$SWAPFILE " /etc/fstab 2>/dev/null; then
            echo "$SWAPFILE none swap sw 0 0" >> /etc/fstab
        fi
    else
        echo "WARN: couldn't create swapfile — continuing without swap"
    fi
fi

gen_hex()    { openssl rand -hex "${1:-32}"; }
gen_fernet() { openssl rand 32 | base64 | tr -d '\n' | tr '+/' '-_'; }

# Read optional release pin dropped by cloud-init.
SPATIUMDDI_VERSION="latest"
if [ -f /etc/spatiumddi/release ]; then
    # shellcheck disable=SC1091
    . /etc/spatiumddi/release
fi

if [ ! -f "$ENV_FILE" ]; then
    echo "Generating $ENV_FILE (first boot)"
    umask 077
    # Appliance metadata for the Phase 4 management hub. APPLIANCE_VERSION
    # tracks the ISO release (set from /etc/spatiumddi/appliance-release
    # if dropped at build time, otherwise the placeholder 0.1.0).
    # APPLIANCE_HOSTNAME is the kernel's view of `hostname` at first
    # boot; the management UI displays it as a chip next to the title.
    # Both flow through the api container's compose env into Settings.
    APPLIANCE_VERSION_VAL="0.1.0"
    if [ -f /etc/spatiumddi/appliance-release ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/appliance-release
        APPLIANCE_VERSION_VAL="${APPLIANCE_VERSION:-0.1.0}"
    fi
    APPLIANCE_HOSTNAME_VAL=$(hostname 2>/dev/null || echo "spatiumddi")
    # Docker socket gid — the api container's `app` user needs
    # supplementary group access to /var/run/docker.sock for the
    # Phase 4b.2 cert-deployer SIGHUP + Phase 4d container management.
    # Read the gid off the live socket so we track whatever the
    # docker.io package install picked (defaults to 999 on Debian
    # but can drift). Falls back to 999 if the socket doesn't exist
    # yet (firstboot races docker.service); the compose group_add
    # has the same default.
    DOCKER_GID_VAL=$(stat -c '%g' /var/run/docker.sock 2>/dev/null || echo "999")
    cat > "$ENV_FILE" <<EOF
# Auto-generated by spatiumddi-firstboot on $(date -Iseconds).
# Edit + run \`docker-compose -f $COMPOSE_DIR/docker-compose.yml up -d\` to apply.
SPATIUMDDI_VERSION=${SPATIUMDDI_VERSION}
POSTGRES_PASSWORD=$(gen_hex 24)
SECRET_KEY=$(gen_hex 32)
CREDENTIAL_ENCRYPTION_KEY=$(gen_fernet)
DNS_AGENT_KEY=$(gen_hex 24)
DHCP_AGENT_KEY=$(gen_hex 24)
COMPOSE_PROFILES=dns,dhcp
APPLIANCE_VERSION=${APPLIANCE_VERSION_VAL}
APPLIANCE_HOSTNAME=${APPLIANCE_HOSTNAME_VAL}
DOCKER_GID=${DOCKER_GID_VAL}
EOF
    chmod 600 "$ENV_FILE"
fi

# docker-compose looks for .env in the compose file's directory.
ln -sfn "$ENV_FILE" "$COMPOSE_DIR/.env"

cd "$COMPOSE_DIR"

# Wait for the docker daemon socket to be ready. systemd's
# After=docker.service only means docker.service was STARTED, not
# that dockerd has finished initialising and accepting connections
# on /var/run/docker.sock. Without this wait, docker-compose pull
# can race and emit "Cannot connect to the Docker daemon" for a
# subset of services.
echo "Waiting for docker daemon..."
for i in $(seq 1 30); do
    if docker info >/dev/null 2>&1; then break; fi
    sleep 1
done
docker info >/dev/null 2>&1 || {
    echo "ERROR: docker daemon never came up after 30 s"
    exit 1
}

# Wait for DNS resolution. systemd-resolved is the resolver but it
# needs networkd to have an IP + DNS info from DHCP. With a slow
# DHCP server we'd otherwise race and `docker-compose pull` would
# fail on the first image with "lookup registry-1.docker.io on
# ::1:53: read: connection refused" because /etc/resolv.conf is
# resolved's symlink and resolved hasn't been told a DNS server yet.
echo "Waiting for DNS resolution..."
for i in $(seq 1 30); do
    if getent hosts registry-1.docker.io >/dev/null 2>&1; then break; fi
    sleep 2
done
getent hosts registry-1.docker.io >/dev/null 2>&1 || {
    echo "WARN: DNS for registry-1.docker.io didn't resolve after 60 s — pull will likely fail."
    echo "      Check 'resolvectl status' and the wildcard DHCP networkd config."
}

if [ ! -f "$STAMP" ]; then
    echo "Pulling SpatiumDDI image set (first boot)..."
    # Retry pull on transient failures (slow image hosts, partial
    # download). set -e at the script top would otherwise kill us
    # on the first transient blip.
    pull_ok=0
    for i in 1 2 3; do
        if docker-compose pull; then
            pull_ok=1
            break
        fi
        echo "Pull attempt $i failed; retrying in 10 s..."
        sleep 10
    done
    [ "$pull_ok" = 1 ] || {
        echo "ERROR: docker-compose pull failed 3 times. Check network + DNS."
        exit 1
    }
fi

echo "Bringing stack up..."
docker-compose up -d

# Wait up to 5 min for the control plane to answer /health/live.
echo "Waiting for control plane on http://127.0.0.1:8000/health/live …"
for i in $(seq 1 60); do
    if curl -fsS --max-time 3 http://127.0.0.1:8000/health/live >/dev/null 2>&1; then
        date -Iseconds > "$STAMP"
        IP=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
        echo "Ready: http://${IP:-<appliance-ip>}/"
        exit 0
    fi
    sleep 5
done

echo "WARN: /health/live did not respond within 5 minutes." >&2
echo "      Check 'docker-compose -f $COMPOSE_DIR/docker-compose.yml logs'." >&2
exit 1
