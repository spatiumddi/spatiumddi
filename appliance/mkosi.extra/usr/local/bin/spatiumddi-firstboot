#!/bin/sh
# SpatiumDDI appliance first-boot orchestrator (#183 Phase 7 — k3s only).
#
# Runs on every boot. On first run: generates secrets, writes /etc/
# spatiumddi/.env, renders /var/lib/rancher/k3s/server/manifests/
# spatium-bootstrap.yaml (HelmChart CR that brings up the supervisor
# pod on the local k3s). On every boot: reconciles SPATIUMDDI_VERSION
# + APPLIANCE_VERSION in .env (so a slot upgrade picks up the new
# tags), refreshes per-slot version sidecar, and (post-trial-boot)
# commits the active slot as durable once k3s reports Ready.
#
# No docker. No docker-compose. k3s.service comes up first (After=
# ordering in spatiumddi-firstboot.service); k3s's helm-controller
# applies the bootstrap manifest the moment k3s is reachable.
#
# Output is mirrored to /var/log/spatiumddi/firstboot.log so the
# operator can debug from the console without journalctl.

set -eu

LOG=/var/log/spatiumddi/firstboot.log
ENV_FILE=/etc/spatiumddi/.env
STAMP=/var/lib/spatiumddi/firstboot.done
CHART_TGZ=/usr/lib/spatiumddi/charts/spatiumddi-appliance.tgz
CONTROL_CHART_TGZ=/usr/lib/spatiumddi/charts/spatiumddi.tgz
K3S_MANIFESTS_DIR=/var/lib/rancher/k3s/server/manifests
BOOTSTRAP_MANIFEST="$K3S_MANIFESTS_DIR/spatium-bootstrap.yaml"
CONTROL_MANIFEST="$K3S_MANIFESTS_DIR/spatium-control.yaml"
SPATIUMDDI_VERSION_FILE=/usr/lib/spatiumddi/spatiumddi-version

mkdir -p "$(dirname "$LOG")" "$(dirname "$STAMP")"
exec >>"$LOG" 2>&1
echo "=== spatiumddi-firstboot $(date -Iseconds) ==="

# ── Swap (created once, idempotent) ──────────────────────────────────────────
# 2 GiB swapfile if the system has no active swap. Protects k3s
# control-plane components (etcd-like kine, kubeapi, helm-controller)
# from OOM under memory pressure. Sized small — operators with bigger
# workloads grow it.
SWAPFILE=/var/lib/spatiumddi/swapfile
if [ "$(swapon --show=NAME --noheadings | wc -l)" = "0" ] && [ ! -f "$SWAPFILE" ]; then
    echo "Creating 2 GiB swapfile at $SWAPFILE"
    if fallocate -l 2G "$SWAPFILE" 2>/dev/null || \
       dd if=/dev/zero of="$SWAPFILE" bs=1M count=2048 status=none; then
        chmod 0600 "$SWAPFILE"
        mkswap "$SWAPFILE" && swapon "$SWAPFILE"
        if ! grep -q "^$SWAPFILE " /etc/fstab 2>/dev/null; then
            echo "$SWAPFILE none swap sw 0 0" >> /etc/fstab
        fi
    else
        echo "WARN: couldn't create swapfile — continuing without swap"
    fi
fi

gen_hex()    { openssl rand -hex "${1:-32}"; }
gen_fernet() { openssl rand 32 | base64 | tr -d '\n' | tr '+/' '-_'; }

# ── Resolve SPATIUMDDI_VERSION (image tag for the chart) ─────────────────────
# Two sources, in priority order:
#   1. /usr/lib/spatiumddi/spatiumddi-version — written by the bake
#      script at build time; matches the tag every preloaded image
#      carries inside /var/lib/rancher/k3s/agent/images/*.tar.zst.
#   2. /etc/spatiumddi/release — operator override (e.g. via
#      cloud-init) to pin to a specific older / pre-release version.
# Without (1), the chart's ``image: ghcr.io/.../:${SPATIUMDDI_VERSION}``
# would resolve to ``:latest`` + try to pull from ghcr.io. Air-gap:
# fatal. The bake stamps this sidecar precisely so the chart can pull
# locally.
SPATIUMDDI_VERSION="dev"
if [ -f "$SPATIUMDDI_VERSION_FILE" ]; then
    SPATIUMDDI_VERSION="$(cat "$SPATIUMDDI_VERSION_FILE")"
fi
if [ -f /etc/spatiumddi/release ]; then
    # shellcheck disable=SC1091
    . /etc/spatiumddi/release
fi

# ── Host-side state dirs ─────────────────────────────────────────────────────
# /var/lib/spatiumddi/release-state — trigger files for slot upgrades,
# host runner state sidecars. Sticky-bit world-write so the supervisor
# pod (uid varies per image) can drop trigger files without us tracking
# its in-pod uid.
mkdir -p /var/lib/spatiumddi/release-state /var/log/spatiumddi
chmod 1777 /var/lib/spatiumddi/release-state
chmod 0755 /var/log/spatiumddi

# Detect the host's root block device's rotational flag so the
# supervisor pod (which can't see the host's /proc/mounts properly —
# its container view shows ``overlay`` mounted at /) can surface
# "ssd" / "hdd" in the Fleet UI's capabilities block. Write to a
# sidecar in release-state; the supervisor reads it on every
# heartbeat. ``unknown`` written on detection failure.
{
    detected="unknown"
    while read -r src mount _; do
        [ "$mount" = "/" ] || continue
        case "$src" in
            /dev/*)
                name="${src#/dev/}"
                # Strip trailing partition digits, but preserve nvme's
                # pN suffix by stripping until a non-digit then one
                # more strip if it ends with 'p'.
                while [ -n "$name" ] && [ -z "${name##*[0-9]}" ]; do
                    name="${name%?}"
                done
                case "$name" in *p) name="${name%p}";; esac
                if [ -r "/sys/block/$name/queue/rotational" ]; then
                    rot=$(cat "/sys/block/$name/queue/rotational")
                    if [ "$rot" = "1" ]; then
                        detected="hdd"
                    else
                        detected="ssd"
                    fi
                fi
                ;;
        esac
        break
    done < /proc/mounts
    printf '%s\n' "$detected" > /var/lib/spatiumddi/release-state/host-storage-type
    chmod 0644 /var/lib/spatiumddi/release-state/host-storage-type
}

# k3s's auto-deploy manifests dir. k3s creates this on first start,
# but firstboot races k3s.service so we may get here first. Pre-
# create with permissive perms so the supervisor / helm-controller
# can write status sidecars.
mkdir -p "$K3S_MANIFESTS_DIR"
chmod 0700 "$K3S_MANIFESTS_DIR"

# ── First-boot only: generate .env ───────────────────────────────────────────
if [ ! -f "$ENV_FILE" ]; then
    echo "Generating $ENV_FILE (first boot)"
    umask 077
    APPLIANCE_VERSION_VAL="0.1.0"
    if [ -f /etc/spatiumddi/appliance-release ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/appliance-release
        APPLIANCE_VERSION_VAL="${APPLIANCE_VERSION:-0.1.0}"
    fi
    APPLIANCE_HOSTNAME_VAL=$(hostname 2>/dev/null || echo "spatiumddi")
    # Host's globally-scoped IPs — surfaced as SANs on the self-
    # signed cert the appliance generates so browser warnings are
    # "unknown CA" instead of "subject mismatch". Comma-separated.
    APPLIANCE_HOST_IPS_VAL=$(ip -o addr show scope global 2>/dev/null \
        | awk '{print $4}' | cut -d/ -f1 | paste -sd, -)
    # spatium-install drops /etc/spatiumddi/role-config with ROLE +
    # CONTROL_PLANE_URL + BOOTSTRAP_PAIRING_CODE for Application
    # appliances. The .env carries them so the supervisor pod's
    # entrypoint can source the file + propagate to the pod env.
    # #272 — two roles: control-plane (default) + appliance. The old
    # full-stack / frontend-core / application strings are accepted as
    # legacy aliases (full-stack + frontend-core → control-plane,
    # application → appliance) so a not-yet-reinstalled box still boots.
    ROLE=control-plane
    INSTALL_CONTROL_PLANE_URL=""
    INSTALL_BOOTSTRAP_PAIRING_CODE=""
    if [ -f /etc/spatiumddi/role-config ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/role-config
        INSTALL_CONTROL_PLANE_URL="${CONTROL_PLANE_URL:-}"
        INSTALL_BOOTSTRAP_PAIRING_CODE="${BOOTSTRAP_PAIRING_CODE:-}"
    fi

    BOOTSTRAP_PAIRING_CODE_VAL=""
    case "$ROLE" in
        appliance|application)
            # Supervisor-only data-plane node — pairs with a remote
            # control plane. The supervisor injects per-role agent keys
            # from the control plane at role-assign time, so none are
            # baked here.
            ROLE=appliance
            DNS_AGENT_KEY_VAL=""
            DHCP_AGENT_KEY_VAL=""
            BOOTSTRAP_PAIRING_CODE_VAL="$INSTALL_BOOTSTRAP_PAIRING_CODE"
            CONTROL_PLANE_URL_VAL="$INSTALL_CONTROL_PLANE_URL"
            AGENT_GROUP_VAL="default"
            ;;
        *)
            # control-plane (or legacy full-stack / frontend-core). DNS
            # + DHCP are OFF at install; the operator enables them per
            # node via the Fleet role toggle. The agent keys are still
            # generated here so the api can validate agent registrations
            # once those roles ARE enabled (the api needs the key
            # server-side, the role pods need it client-side).
            ROLE=control-plane
            DNS_AGENT_KEY_VAL=$(gen_hex 24)
            DHCP_AGENT_KEY_VAL=$(gen_hex 24)
            # #272 — the control-plane node's supervisor MUST heartbeat to
            # the LOCAL api, otherwise it skips heartbeat ("no_control_
            # plane_url") and never runs the cp-size + MetalLB reconcile
            # (which writes the durable HelmChartConfig overrides). Without
            # it, a seed reboot strands the cluster at the manifest
            # defaults (cp-size=1, MetalLB off). Point at the in-cluster
            # api Service (plain http → no TLS-verify concern); same URL
            # the role pods use as their control plane.
            CONTROL_PLANE_URL_VAL="http://spatium-control-spatiumddi-api.spatium.svc.cluster.local:8000"
            AGENT_GROUP_VAL="default"
            ;;
    esac
    cat > "$ENV_FILE" <<EOF
# Auto-generated by spatiumddi-firstboot on $(date -Iseconds).
# Sourced by the spatium-supervisor pod entrypoint at startup.
# Appliance role (#170 Wave B2): $ROLE
SPATIUMDDI_VERSION=${SPATIUMDDI_VERSION}
POSTGRES_PASSWORD=$(gen_hex 24)
SECRET_KEY=$(gen_hex 32)
CREDENTIAL_ENCRYPTION_KEY=$(gen_fernet)
DNS_AGENT_KEY=${DNS_AGENT_KEY_VAL}
DHCP_AGENT_KEY=${DHCP_AGENT_KEY_VAL}
BOOTSTRAP_PAIRING_CODE=${BOOTSTRAP_PAIRING_CODE_VAL}
CONTROL_PLANE_URL=${CONTROL_PLANE_URL_VAL}
AGENT_GROUP=${AGENT_GROUP_VAL}
APPLIANCE_ROLE=${ROLE}
APPLIANCE_VERSION=${APPLIANCE_VERSION_VAL}
APPLIANCE_HOSTNAME=${APPLIANCE_HOSTNAME_VAL}
APPLIANCE_HOST_IPS=${APPLIANCE_HOST_IPS_VAL}
EOF
    # Mode 644 so the supervisor pod's unprivileged user (uid varies
    # per image) can read the file through the hostPath bind mount
    # at /etc/spatiumddi-host/.env.
    chmod 644 "$ENV_FILE"
fi

# ── Every boot: reconcile SPATIUMDDI_VERSION + APPLIANCE_VERSION ─────────────
# A slot upgrade lands new container images on the new rootfs but
# .env (on /var, shared across slots) still points at the OLD tag.
# Re-sed the matching lines so the chart's ``image: ...:${VERSION}``
# always resolves to bytes preloaded in containerd.
if [ -f "$ENV_FILE" ]; then
    if [ -f "$SPATIUMDDI_VERSION_FILE" ]; then
        CURRENT_SPATIUMDDI_VERSION="$(cat "$SPATIUMDDI_VERSION_FILE")"
        sed -i "s|^SPATIUMDDI_VERSION=.*|SPATIUMDDI_VERSION=${CURRENT_SPATIUMDDI_VERSION}|" "$ENV_FILE"
    fi
    if [ -f /etc/spatiumddi/appliance-release ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/appliance-release
        CURRENT_APPLIANCE_VERSION="${APPLIANCE_VERSION:-0.1.0}"
        sed -i "s|^APPLIANCE_VERSION=.*|APPLIANCE_VERSION=${CURRENT_APPLIANCE_VERSION}|" "$ENV_FILE"
    fi
fi

# ── Render the bootstrap HelmChart manifest ──────────────────────────────────
# k3s's helm-controller watches /var/lib/rancher/k3s/server/manifests/
# for ``HelmChart`` CRs + reconciles them into Helm releases at
# startup. We base64-encode the baked chart tarball into
# ``spec.chartContent`` so the chart applies inline (no registry
# lookup, no chart repo — air-gap-clean).
#
# ``supervisor.enabled: true`` is the only operator-driven flag — the
# control plane assigns role flags (dnsBind9.enabled, dnsPowerdns.
# enabled, dhcpKea.enabled) later via the supervisor's lifecycle
# module once the appliance is paired.
#
# We re-render on every boot. The chart bytes don't change between
# boots on the same slot, but a slot upgrade swings in a new tgz +
# we want the bootstrap manifest to reflect that without an extra
# step. Atomic-rename via .new so a partial write doesn't break
# helm-controller's parse.
# Phase 11 (#183) — variant-aware bootstrap manifest. The install
# wizard's ``ROLE`` selection lands in /etc/spatiumddi/.env above;
# read it back to decide what chart(s) get installed:
#
#   appliance     — appliance chart only (supervisor + agent-landing).
#                   Supervisor pairs with a remote control plane;
#                   role pods live in the supervisor-driven
#                   spatiumddi-appliance release.
#   control-plane — control chart (api/frontend/db/redis/worker/
#                   beat/migrate) PLUS the appliance chart (supervisor
#                   enabled, role pods OFF at boot). DNS/DHCP are
#                   enabled later per node via the Fleet role toggle —
#                   the supervisor flips dnsBind9/dhcpKea + applies the
#                   labels. (Legacy full-stack / frontend-core map here.)
# ── Phase 11 wave 3 — self-signed TLS cert for the appliance UI ─────────────
# Generated on every boot (overwriting an operator-uploaded cert
# would be wrong — gated on the Secret manifest not already
# existing in /var/lib/rancher/k3s/server/manifests/). The cert
# Secret lands in the spatium namespace via k3s's auto-deploy
# manifest mechanism, BEFORE the chart bootstraps, so the
# frontend pod's volume mount finds it on first schedule.
#
# Standard kubernetes.io/tls Secret keys (tls.crt / tls.key)
# match the chart's volume mount + the in-cluster cert-deployer
# update path that the api uses on operator upload.
TLS_CERT_MANIFEST="$K3S_MANIFESTS_DIR/spatium-appliance-tls.yaml"
if [ ! -f "$TLS_CERT_MANIFEST" ]; then
    HN_VAL=$(grep "^APPLIANCE_HOSTNAME=" "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2-)
    HN_VAL="${HN_VAL:-$(hostname 2>/dev/null || echo spatiumddi)}"
    IPS_VAL=$(grep "^APPLIANCE_HOST_IPS=" "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2-)
    # SAN list: DNS:<hostname>, DNS:localhost, IP:<each host IP>,
    # IP:127.0.0.1. ip-of-this-host is what the operator will type
    # into the browser, so include each one.
    san_parts="DNS:${HN_VAL},DNS:localhost,IP:127.0.0.1"
    if [ -n "$IPS_VAL" ]; then
        for ip in $(echo "$IPS_VAL" | tr ',' ' '); do
            san_parts="$san_parts,IP:$ip"
        done
    fi
    TLS_TMP=$(mktemp -d)
    chmod 0700 "$TLS_TMP"
    openssl req -x509 -newkey rsa:2048 -nodes \
        -keyout "$TLS_TMP/tls.key" -out "$TLS_TMP/tls.crt" \
        -days 3650 -subj "/CN=$HN_VAL" \
        -addext "subjectAltName=$san_parts" \
        2>&1 | tail -2 || echo "WARN: self-signed cert generation failed"
    if [ -s "$TLS_TMP/tls.crt" ] && [ -s "$TLS_TMP/tls.key" ]; then
        TLS_CRT_B64=$(base64 -w0 "$TLS_TMP/tls.crt")
        TLS_KEY_B64=$(base64 -w0 "$TLS_TMP/tls.key")
        tmp_manifest="${TLS_CERT_MANIFEST}.new"
        cat > "$tmp_manifest" <<EOF
# Auto-generated by spatiumddi-firstboot on first boot only.
# Self-signed TLS cert for the appliance Web UI (https://).
# Operators replace this via the SpatiumDDI cert manager UI —
# the api PATCHes this Secret in-place; do NOT regenerate from
# firstboot on subsequent boots (the ``if [ ! -f ... ]`` guard
# above enforces this).
apiVersion: v1
kind: Secret
metadata:
  name: spatium-appliance-tls
  namespace: spatium
type: kubernetes.io/tls
data:
  tls.crt: ${TLS_CRT_B64}
  tls.key: ${TLS_KEY_B64}
EOF
        mv "$tmp_manifest" "$TLS_CERT_MANIFEST"
        chmod 0600 "$TLS_CERT_MANIFEST"
        echo "Wrote self-signed TLS Secret manifest to $TLS_CERT_MANIFEST"
    fi
    rm -rf "$TLS_TMP"
fi

# Helper — read a single key out of /etc/spatiumddi/.env. Hoisted
# from the agent-landing renderer below so the bootstrap manifest
# dispatch (which also needs APPLIANCE_ROLE) can use it.
_env_get() {
    grep "^${1}=" "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2-
}

APPLIANCE_ROLE_VAL=$(_env_get APPLIANCE_ROLE)
APPLIANCE_ROLE_VAL="${APPLIANCE_ROLE_VAL:-control-plane}"

# Agent pre-shared keys + in-cluster API service URL for the AIO
# control-plane node. The DNS + DHCP role pods need them to
# register against the local control plane, AND the api pod needs
# them server-side to validate incoming agent registrations
# (otherwise the api returns 503 "DNS_AGENT_KEY is not configured
# on the control plane"). Both come from /etc/spatiumddi/.env which
# firstboot writes (or carries over) on every boot.
DNS_AGENT_KEY_VAL=$(_env_get DNS_AGENT_KEY)
DHCP_AGENT_KEY_VAL=$(_env_get DHCP_AGENT_KEY)
# In-cluster service DNS for the api. Matches the umbrella chart's
# release name (``spatium-control``) + the workload suffix the
# template ``include "spatiumddi.fullname"`` produces. ClusterFirstWithHostNet
# on the role pods means cluster DNS resolves even though the pod
# uses hostNetwork.
APPLIANCE_API_URL="http://spatium-control-spatiumddi-api.spatium.svc.cluster.local:8000"

_render_namespace_yaml() {
    cat <<EOF
apiVersion: v1
kind: Namespace
metadata:
  name: spatium
EOF
}

# Renders the appliance HelmChart CR. Args:
#   $1 — chart_content_b64
#   $2 — supervisor_enabled (true / false)
#   $3 — role_pods_enabled (true / false) — toggles
#        dnsBind9/dnsPowerdns/dhcpKea all together
#   $4 — agent_landing_enabled (true / false) — only the
#        Application variant ships the "this is a SpatiumDDI
#        appliance" landing page on :80. The control-plane node
#        have the real control-plane frontend on :80, so leaving
#        agent-landing enabled there gives us a pod stuck Pending
#        on a port conflict that would also fight the frontend for
#        the host's :80 if scheduling ever resolved.
_render_appliance_helmchart() {
    local chart_b64="$1"
    local supervisor_enabled="$2"
    local role_pods_enabled="$3"
    local agent_landing_enabled="$4"
    # #277 — the CNPG operator (cloudnative-pg subchart) runs only on the
    # control-plane node, where the spatium-control chart's CNPG Cluster
    # lives. Data-plane appliances don't host postgres, so they skip it.
    local cnpg_enabled="${5:-false}"
    # role_pods_enabled=true (full-stack) needs control-plane URL +
    # pre-shared keys + a default server group name so the BIND9 /
    # Kea agents can bootstrap-register against the local control
    # plane on first start. Empty for application (supervisor
    # injects them at role-assign time) and frontend-core (no
    # role pods anyway).
    cat <<EOF
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: spatium-bootstrap
  namespace: kube-system
spec:
  chartContent: ${chart_b64}
  targetNamespace: spatium
  createNamespace: false
  valuesContent: |
    global:
      imageTag: ${SPATIUMDDI_VERSION}
      imagePullPolicy: Never
    supervisor:
      enabled: ${supervisor_enabled}
    dnsBind9:
      enabled: ${role_pods_enabled}
      controlPlaneUrl: ${APPLIANCE_API_URL}
      agentKey: ${DNS_AGENT_KEY_VAL}
      serverGroupName: default
    dnsPowerdns:
      enabled: false
    dhcpKea:
      enabled: ${role_pods_enabled}
      controlPlaneUrl: ${APPLIANCE_API_URL}
      agentKey: ${DHCP_AGENT_KEY_VAL}
      serverGroupName: default
    agentLanding:
      enabled: ${agent_landing_enabled}
    # #277 — CloudNativePG operator (manages the control plane's
    # postgres Cluster + streaming replicas + failover). Only the
    # control-plane node enables it.
    cnpg:
      enabled: ${cnpg_enabled}
    # #272 Phase 7c — MetalLB L2 pool for the control-plane VIP. Off /
    # empty on a fresh install; the seed supervisor patches these marked
    # lines from platform_settings when the operator sets a pool + VIP in
    # Fleet → Control plane. ``ipPool.addresses`` renders as a flow-style
    # YAML list (e.g. ["192.0.2.240/28"]); the supervisor writes JSON,
    # which is valid flow YAML. When enabled, the controller/speaker come
    # up + the IPAddressPool / L2Advertisement land (templates/
    # metallb-pool.yaml). The VIP itself is set on the umbrella chart's
    # frontend Service (see spatium-control above).
    metallb:
      enabled: false  # spatium:metallb-enabled
      ipPool:
        addresses: []  # spatium:metallb-pool
      # The metallb subchart ships its CRDs as a (templated) sub-subchart.
      # On the appliance metallb always starts DISABLED, so the subchart +
      # its CRDs aren't rendered at first install; enabling it later is a
      # helm UPGRADE, and helm won't establish those CRDs before applying
      # the IPAddressPool / L2Advertisement CRs in the same release → the
      # upgrade fails "no matches for kind IPAddressPool". So we DON'T let
      # helm own the CRDs at all — they're pre-loaded unconditionally as a
      # k3s auto-deploy manifest at firstboot (place_metallb_crds below).
      crds:
        enabled: false
EOF
}

# #272 — pre-load the MetalLB CRDs as a k3s auto-deploy manifest so they
# exist cluster-wide BEFORE the operator ever enables MetalLB. MetalLB
# always starts disabled on the appliance and is turned on via a helm
# UPGRADE of the spatium-bootstrap release; helm can't establish the
# metallb subchart's CRDs before applying the IPAddressPool /
# L2Advertisement CRs in that same release ("no matches for kind
# IPAddressPool"). So we keep the CRDs out of helm entirely
# (metallb.crds.enabled=false in the valuesContent above) and lay them
# down here — k3s applies everything in its manifests dir at boot, well
# before the operator could enable MetalLB. The baked file is vendored
# from the metallb 0.16.0 chart (its {{ .Release.Namespace }} already
# substituted to ``spatium``).
place_metallb_crds() {
    local src=/usr/local/share/spatiumddi/metallb-crds.yaml
    if [ -r "$src" ]; then
        install -m 0644 "$src" "$K3S_MANIFESTS_DIR/spatium-metallb-crds.yaml"
        echo "Placed MetalLB CRDs at $K3S_MANIFESTS_DIR/spatium-metallb-crds.yaml"
    else
        echo "WARN: $src missing — MetalLB CRDs not pre-loaded; enabling MetalLB later will fail."
    fi
}

# Renders the control-plane HelmChart CR for the control-plane
# role. Args:
#   $1 — chart_content_b64
#   $2 — dns/dhcp agents enabled in umbrella (frontend-core=false,
#        full-stack=false because the appliance chart owns them)
_render_control_helmchart() {
    local chart_b64="$1"
    cat <<EOF
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: spatium-control
  namespace: kube-system
spec:
  chartContent: ${chart_b64}
  targetNamespace: spatium
  createNamespace: false
  valuesContent: |
    image:
      tag: "${SPATIUMDDI_VERSION}"
      pullPolicy: IfNotPresent
    # #272 Phase 1 — gate every control-plane workload onto nodes
    # carrying ``spatium.io/role-control-plane=true``. Install-time
    # bakes the label for full-stack + frontend-core variants (see
    # spatium-install); the supervisor re-asserts it on every
    # heartbeat. application appliances never carry the label and
    # so never schedule control-plane workloads even if joined to
    # the cluster.
    global:
      controlPlaneNodeSelector:
        spatium.io/role-control-plane: "true"
    # Appliance overrides — collapse the frontend to a single
    # replica with hostNetwork on the node IP so http://<ip>/
    # serves the SpatiumDDI UI. klipper-lb is disabled in our
    # k3s config + NodePort defaults exclude :80, so hostNetwork
    # is the cleanest path. dnsPolicy: ClusterFirstWithHostNet
    # is set by the chart template so service DNS still resolves
    # (pod talks to api via the in-cluster ClusterIP through
    # kube-proxy iptables). TLS on :443 from first boot — see
    # the self-signed cert generation below; the Secret named
    # ``spatium-appliance-tls`` is created in the spatium
    # namespace BEFORE the chart applies, so the frontend pod's
    # subPath mount finds it on first scheduling.
    frontend:
      replicas: 1  # spatium:cp-size
      hostNetwork: true
      # #272 Phase 7c — control-plane VIP. Empty on a fresh install
      # (hostNetwork frontend, no VIP); the seed supervisor patches this
      # marked line from platform_settings when the operator sets a VIP
      # in Fleet → Control plane. A non-empty value supersedes
      # hostNetwork (the chart drops it + flips the Service to a
      # LoadBalancer) and threads the VIP into the api's
      # APPLIANCE_EXTRA_CERT_SANS so the served cert validates on it.
      controlPlaneVIP: ""  # spatium:metallb-vip
      controlPlaneVIPPool: spatium-control-plane
      tls:
        enabled: true
        secretName: spatium-appliance-tls
    # Phase 11 wave 3 — flip the api into appliance-mode so the
    # cert upload / activate endpoints write to the Kubernetes
    # Secret instead of the docker-compose volume + SIGHUP path.
    # Phase 11 wave 4 — enable the api ServiceAccount + Role so
    # the kubeapi-driven surfaces (pod listing for the Fleet UI's
    # Pods tab, TLS Secret patching for the Cert Manager UI) can
    # authenticate against the in-cluster kubeapi.
    # Appliance is single-node — collapse api/worker to 1 replica
    # each + disable HPA (no horizontal scaling on a single host).
    api:
      replicas: 1  # spatium:cp-size
      autoscaling:
        enabled: false
      env:
        - name: APPLIANCE_MODE
          value: "true"
        # Agent pre-shared keys — the api validates incoming
        # registrations from DNS/DHCP agents against these. Without
        # them the api returns 503 "DNS_AGENT_KEY is not configured
        # on the control plane" and the role pods crash-loop.
        # Sourced from /etc/spatiumddi/.env which firstboot stamps
        # on first boot.
        - name: DNS_AGENT_KEY
          value: "${DNS_AGENT_KEY_VAL}"
        - name: DHCP_AGENT_KEY
          value: "${DHCP_AGENT_KEY_VAL}"
        # #272 HA — stable identity for the self-signed Web UI cert.
        # The api Deployment runs N replicas (one per control-plane
        # node), all sharing one cluster TLS Secret. WITHOUT these the
        # cert bootstrap falls back to the POD name/IP, so every replica
        # regenerates a cert for its own ephemeral identity and clobbers
        # the Secret — the operator-reported "3 certificates" churn.
        # These env values are identical for every replica (the host's
        # hostname + globally-scoped IPs, computed once at firstboot),
        # so the first node's cert is generated once and every replica
        # just re-deploys it. Operators add other node IPs as SANs via a
        # CSR. (The control-plane VIP, when one is set on promote, is
        # threaded separately as APPLIANCE_EXTRA_CERT_SANS.)
        - name: APPLIANCE_HOSTNAME
          value: "${APPLIANCE_HOSTNAME_VAL}"
        - name: APPLIANCE_HOST_IPS
          value: "${APPLIANCE_HOST_IPS_VAL}"
      serviceAccount:
        enabled: true
      # Appliance bind mounts. /var/lib/spatiumddi-host/release-state
      # backs the setup-complete flag, slot-upgrade triggers, and the
      # maintenance flag; without this the wizard's "Finish setup"
      # POST 500s with EACCES at
      # /var/lib/spatiumddi-host/release-state/setup-complete.flag.
      # /var/log/spatiumddi-host carries the slot-upgrade log the OS
      # Versions card tails; /etc/spatiumddi-host carries the host
      # env the Fleet UI reads for deployment_kind detection.
      applianceHostMounts:
        enabled: true
    worker:
      replicas: 1  # spatium:cp-size
    # #277 — PostgreSQL runs under CloudNativePG on every appliance, so
    # the data layer scales with the control-plane cluster: 1 instance on
    # a single node, growing to 3/5/7 (primary + streaming replicas with
    # automatic failover) as nodes are promoted. The CNPG operator itself
    # ships from the spatiumddi-appliance chart (cnpg.enabled). A fresh
    # install is always a single control-plane node, so instances starts
    # at 1; the seed supervisor patches the ``# spatium:cp-size`` marked
    # lines (instances + api/frontend/worker replicas) to the committed
    # member count on promote/demote, and helm-controller upgrades.
    postgresql:
      kind: cnpg
      cnpg:
        instances: 1  # spatium:cp-size
    # #272 Phase 3 — Redis runs under Sentinel on every appliance so the
    # cache/queue layer is HA like postgres: each replica pairs a
    # redis-server with a redis-sentinel that elects a master + fails
    # over automatically, and the app/worker/beat resolve the live
    # master through a sentinel:// URL. replicas tracks the control-plane
    # size via the same ``# spatium:cp-size`` marker — 1 on a single
    # node (degenerate but functional), 3/5/7 with real quorum + failover
    # after promote (the seed supervisor patches it alongside CNPG).
    redis:
      kind: sentinel
      sentinel:
        replicas: 1  # spatium:cp-size
    # DNS / DHCP agents from the umbrella chart are NOT used on the
    # appliance — the appliance chart (templates/dns-bind9.yaml etc.)
    # owns the role pods with hostNetwork + per-role node labels.
    dnsAgents:
      enabled: false
    dhcpAgents:
      enabled: false
EOF
}

case "$APPLIANCE_ROLE_VAL" in
    appliance|application)
        if [ ! -f "$CHART_TGZ" ]; then
            echo "WARN: $CHART_TGZ missing — supervisor pod won't auto-deploy. Is the chart baked?"
        else
            echo "Rendering $BOOTSTRAP_MANIFEST from $CHART_TGZ (role=appliance)"
            CHART_B64=$(base64 -w0 "$CHART_TGZ")
            tmp="${BOOTSTRAP_MANIFEST}.new"
            {
                echo "# Auto-generated by spatiumddi-firstboot — do not hand-edit."
                _render_namespace_yaml
                echo "---"
                _render_appliance_helmchart "$CHART_B64" "true" "false" "true"
            } > "$tmp"
            mv "$tmp" "$BOOTSTRAP_MANIFEST"
            chmod 0600 "$BOOTSTRAP_MANIFEST"
            rm -f "$CONTROL_MANIFEST"
        fi
        ;;
    control-plane|full-stack|frontend-core)
        # #272 — lay down the MetalLB CRDs unconditionally (the seed is a
        # control-plane node; CRDs are cluster-scoped so doing it here
        # covers any node later promoted into the cluster).
        place_metallb_crds
        # Both variants need the control-plane chart (api/frontend/db
        # /redis/worker/beat/migrate). full-stack ADDITIONALLY needs
        # the appliance chart with role pods enabled (supervisor
        # disabled — no remote control plane to pair against, this
        # box IS the control plane).
        if [ ! -f "$CONTROL_CHART_TGZ" ]; then
            echo "WARN: $CONTROL_CHART_TGZ missing — control plane won't auto-deploy. Did the bake step run?"
        else
            echo "Rendering $CONTROL_MANIFEST (deferred) from $CONTROL_CHART_TGZ (role=$APPLIANCE_ROLE_VAL)"
            CONTROL_CHART_B64=$(base64 -w0 "$CONTROL_CHART_TGZ")
            # #277 — DEFER placing the control chart into the manifests
            # dir. It creates a CNPG ``Cluster`` CR, which the operator's
            # mutating webhook (mcluster.cnpg.io) must admit. The operator
            # ships in the spatium-bootstrap chart below; if k3s applies
            # the control chart before that operator + its webhook are
            # ready, the helm install fails calling the webhook and
            # retries — each retry rolls every workload (api/worker/migrate
            # churn) until it converges. Writing to ``*.deferred`` (k3s
            # only watches ``*.yaml``) holds it back; the post-readyz step
            # at the end of firstboot waits for the webhook, then moves it
            # into place so the Cluster CR is admitted on the first try.
            tmp="${CONTROL_MANIFEST}.new"
            {
                echo "# Auto-generated by spatiumddi-firstboot — do not hand-edit."
                _render_namespace_yaml
                echo "---"
                _render_control_helmchart "$CONTROL_CHART_B64"
            } > "$tmp"
            mv "$tmp" "${CONTROL_MANIFEST}.deferred"
            chmod 0600 "${CONTROL_MANIFEST}.deferred"
        fi
        if [ -f "$CHART_TGZ" ]; then
            # #272 — the control-plane node renders the appliance chart
            # so the supervisor pod is present (the supervisor is the
            # source of truth for per-role node labels, reconciled every
            # heartbeat against /etc/spatiumddi-host/role-config:ROLE).
            #
            # DNS / DHCP role pods are DISABLED at boot — the operator
            # enables them per node via the Fleet role toggle, at which
            # point the supervisor flips dnsBind9/dhcpKea enabled in
            # this same bootstrap chart + applies the node labels. So a
            # fresh control plane never silently runs DNS/DHCP.
            role_pods_enabled="false"
            echo "Rendering $BOOTSTRAP_MANIFEST from $CHART_TGZ (role=$APPLIANCE_ROLE_VAL, supervisor enabled, role_pods=$role_pods_enabled)"
            CHART_B64=$(base64 -w0 "$CHART_TGZ")
            tmp="${BOOTSTRAP_MANIFEST}.new"
            {
                echo "# Auto-generated by spatiumddi-firstboot — do not hand-edit."
                _render_namespace_yaml
                echo "---"
                _render_appliance_helmchart "$CHART_B64" "true" "$role_pods_enabled" "false" "true"
            } > "$tmp"
            mv "$tmp" "$BOOTSTRAP_MANIFEST"
            chmod 0600 "$BOOTSTRAP_MANIFEST"
        else
            echo "WARN: $CHART_TGZ missing — supervisor pod won't auto-deploy."
            rm -f "$BOOTSTRAP_MANIFEST"
        fi
        ;;
    *)
        echo "WARN: unknown APPLIANCE_ROLE=$APPLIANCE_ROLE_VAL; refusing to render a bootstrap manifest. Re-run spatium-install."
        ;;
esac

# ── Render agent landing page ───────────────────────────────────────────────
# Static "this is a SpatiumDDI appliance" page served on :80 by the
# agent-landing nginx pod (chart template:
# templates/agent-landing.yaml). Template lives at
# /usr/local/share/spatiumddi/agent-landing/index.html.in; firstboot
# substitutes hostname + control-plane URL + version, writes the
# result to /var/lib/spatiumddi/agent-landing/index.html where the
# pod mounts it via hostPath.
#
# Reset umask before the write — the .env-secrets path above set 077
# which would leave the file 0600 (root-readable only) + nginx
# would 403 it.
umask 022
LANDING_TEMPLATE=/usr/local/share/spatiumddi/agent-landing/index.html.in
LANDING_DIR=/var/lib/spatiumddi/agent-landing
if [ -r "$LANDING_TEMPLATE" ]; then
    mkdir -p "$LANDING_DIR"
    chmod 0755 "$LANDING_DIR"
    # Pull CONTROL_PLANE_URL / APPLIANCE_HOSTNAME / SPATIUMDDI_VERSION
    # out of /etc/spatiumddi/.env (the same file firstboot just
    # wrote or refreshed above). grep|cut so we don't have to
    # ``source`` a file that might carry shell-special chars.
    HN=$(_env_get APPLIANCE_HOSTNAME)
    HN="${HN:-$(hostname 2>/dev/null || echo unknown)}"
    CPU=$(_env_get CONTROL_PLANE_URL)
    CPU="${CPU:-(not set)}"
    VER=$(_env_get SPATIUMDDI_VERSION)
    VER="${VER:-(unknown)}"
    sed \
        -e "s|__HOSTNAME__|${HN}|g" \
        -e "s|__CONTROL_PLANE_URL__|${CPU}|g" \
        -e "s|__APPLIANCE_VERSION__|${VER}|g" \
        "$LANDING_TEMPLATE" > "$LANDING_DIR/index.html"
    chmod 0644 "$LANDING_DIR/index.html"
    echo "Rendered $LANDING_DIR/index.html"
fi

# ── Phase 8 — refresh per-slot version sidecar ──────────────────────────────
# Best-effort: a failure here doesn't block — the api just falls back
# to "unknown" for the slot the operator hasn't booted into recently.
if [ -x /usr/local/bin/spatium-upgrade-slot ] && [ -e /etc/spatiumddi/role-config ]; then
    /usr/local/bin/spatium-upgrade-slot sync-versions || \
        echo "WARN: sync-versions failed — OS Image card will show 'unknown' for slot versions"
fi

# ── Readiness wait + slot commit ─────────────────────────────────────────────
# Phase 8c — commit the active slot as the durable default after a
# successful trial boot. spatium-upgrade-slot set-next-boot writes a
# one-shot saved_entry to grubenv via grub-reboot; that's auto-cleared
# on this boot. If THIS boot is healthy, we make the swap permanent
# via grub-set-default. If anything fails before this point, the
# previous slot's saved_entry stays in grubenv → next reboot reverts.
commit_slot_if_healthy() {
    local grub_boot_dir=/boot/efi
    if [ ! -f "${grub_boot_dir}/grub/grubenv" ]; then
        return 0
    fi
    local root_uuid="" current_slot=""
    root_uuid=$(awk 'BEGIN{RS=" "} /^root=UUID=/{print substr($0,11)}' /proc/cmdline 2>/dev/null | head -1)
    if [ -n "$root_uuid" ]; then
        local root_dev
        root_dev=$(blkid -U "$root_uuid" 2>/dev/null)
        if [ -n "$root_dev" ]; then
            current_slot=$(lsblk -no PARTLABEL "$root_dev" 2>/dev/null | tr 'A-Z' 'a-z' | head -1)
        fi
    fi
    case "$current_slot" in
        root_a) current_slot=slot_a ;;
        root_b) current_slot=slot_b ;;
        *)      return 0 ;;
    esac
    local saved
    saved=$(grub-editenv "${grub_boot_dir}/grub/grubenv" list 2>/dev/null \
            | awk -F= '/^saved_entry=/{print $2}')
    if [ "$saved" = "$current_slot" ]; then
        echo "  slot $current_slot is already the durable default — nothing to commit."
        return 0
    fi
    echo "  trial boot detected (booted=$current_slot, durable=${saved:-unset})."
    echo "  k3s reports Ready — committing $current_slot as the new default."
    grub-set-default --boot-directory="$grub_boot_dir" "$current_slot" \
        >> "$LOG" 2>&1 || true
}

# #277 — place the deferred control chart only AFTER the CNPG operator
# webhook has endpoints, so the Cluster CR is admitted on the first
# helm attempt (no failed-install rolling churn). Best-effort: if the
# webhook never comes up (operator broken), apply anyway after the
# timeout so the rest of the control plane still deploys + helm-
# controller retries. No-op when there's no deferred manifest (the
# appliance/application roles never write one).
place_deferred_control_manifest() {
    local deferred="${CONTROL_MANIFEST}.deferred"
    [ -f "$deferred" ] || return 0
    echo "Waiting for the CNPG operator webhook before applying the control chart…"
    local up=0
    for _ in $(seq 1 48); do   # up to 4 min
        if /usr/local/bin/k3s kubectl get endpoints -n spatium cnpg-webhook-service \
                -o jsonpath='{.subsets[*].addresses[*].ip}' 2>/dev/null | grep -q '[0-9]'; then
            up=1
            break
        fi
        sleep 5
    done
    if [ "$up" = 1 ]; then
        echo "CNPG webhook ready — applying control chart."
    else
        echo "WARN: CNPG webhook not ready after 4 min — applying control chart anyway (helm-controller retries)." >&2
    fi
    mv -f "$deferred" "$CONTROL_MANIFEST"
    chmod 0600 "$CONTROL_MANIFEST"
}

# Wait for k3s to come up + helm-controller to apply the bootstrap
# manifest. ``kubectl get --raw=/readyz`` is the canonical readiness
# probe; once it returns 200 the supervisor pod can be scheduled.
# Up to 5 min — first boot has to pull no images (everything's in
# containerd via the airgap-import path) but k3s itself + helm-
# controller + the supervisor pod still need to settle.
echo "Waiting for k3s /readyz …"
export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
ready=0
for _ in $(seq 1 60); do
    if /usr/local/bin/k3s kubectl get --raw=/readyz 2>/dev/null | grep -q '^ok'; then
        ready=1
        break
    fi
    sleep 5
done
if [ "$ready" = 1 ]; then
    date -Iseconds > "$STAMP"
    IP=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
    echo "Ready: k3s up on ${IP:-<appliance-ip>}; supervisor pod auto-deploys via $BOOTSTRAP_MANIFEST"
    place_deferred_control_manifest
    commit_slot_if_healthy
    exit 0
fi
echo "WARN: k3s /readyz did not respond within 5 minutes." >&2
echo "      Check 'systemctl status k3s' + 'journalctl -u k3s'." >&2
# k3s never became ready, but don't strand the deferred control chart —
# place it so a later k3s recovery (or manual restart) still deploys the
# control plane. helm-controller will retry the webhook on its own.
mv -f "${CONTROL_MANIFEST}.deferred" "$CONTROL_MANIFEST" 2>/dev/null || true
exit 1
