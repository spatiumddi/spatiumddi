#!/bin/sh
# SpatiumDDI appliance first-boot orchestrator (#183 Phase 7 — k3s only).
#
# Runs on every boot. On first run: generates secrets, writes /etc/
# spatiumddi/.env, renders /var/lib/rancher/k3s/server/manifests/
# spatium-bootstrap.yaml (HelmChart CR that brings up the supervisor
# pod on the local k3s). On every boot: reconciles SPATIUMDDI_VERSION
# + APPLIANCE_VERSION in .env (so a slot upgrade picks up the new
# tags), refreshes per-slot version sidecar, and (post-trial-boot)
# commits the active slot as durable once k3s reports Ready.
#
# No docker. No docker-compose. k3s.service comes up first (After=
# ordering in spatiumddi-firstboot.service); k3s's helm-controller
# applies the bootstrap manifest the moment k3s is reachable.
#
# Output is mirrored to /var/log/spatiumddi/firstboot.log so the
# operator can debug from the console without journalctl.

set -eu

LOG=/var/log/spatiumddi/firstboot.log
ENV_FILE=/etc/spatiumddi/.env
STAMP=/var/lib/spatiumddi/firstboot.done
CHART_TGZ=/usr/lib/spatiumddi/charts/spatiumddi-appliance.tgz
K3S_MANIFESTS_DIR=/var/lib/rancher/k3s/server/manifests
BOOTSTRAP_MANIFEST="$K3S_MANIFESTS_DIR/spatium-bootstrap.yaml"
SPATIUMDDI_VERSION_FILE=/usr/lib/spatiumddi/spatiumddi-version

mkdir -p "$(dirname "$LOG")" "$(dirname "$STAMP")"
exec >>"$LOG" 2>&1
echo "=== spatiumddi-firstboot $(date -Iseconds) ==="

# ── Swap (created once, idempotent) ──────────────────────────────────────────
# 2 GiB swapfile if the system has no active swap. Protects k3s
# control-plane components (etcd-like kine, kubeapi, helm-controller)
# from OOM under memory pressure. Sized small — operators with bigger
# workloads grow it.
SWAPFILE=/var/lib/spatiumddi/swapfile
if [ "$(swapon --show=NAME --noheadings | wc -l)" = "0" ] && [ ! -f "$SWAPFILE" ]; then
    echo "Creating 2 GiB swapfile at $SWAPFILE"
    if fallocate -l 2G "$SWAPFILE" 2>/dev/null || \
       dd if=/dev/zero of="$SWAPFILE" bs=1M count=2048 status=none; then
        chmod 0600 "$SWAPFILE"
        mkswap "$SWAPFILE" && swapon "$SWAPFILE"
        if ! grep -q "^$SWAPFILE " /etc/fstab 2>/dev/null; then
            echo "$SWAPFILE none swap sw 0 0" >> /etc/fstab
        fi
    else
        echo "WARN: couldn't create swapfile — continuing without swap"
    fi
fi

gen_hex()    { openssl rand -hex "${1:-32}"; }
gen_fernet() { openssl rand 32 | base64 | tr -d '\n' | tr '+/' '-_'; }

# ── Resolve SPATIUMDDI_VERSION (image tag for the chart) ─────────────────────
# Two sources, in priority order:
#   1. /usr/lib/spatiumddi/spatiumddi-version — written by the bake
#      script at build time; matches the tag every preloaded image
#      carries inside /var/lib/rancher/k3s/agent/images/*.tar.zst.
#   2. /etc/spatiumddi/release — operator override (e.g. via
#      cloud-init) to pin to a specific older / pre-release version.
# Without (1), the chart's ``image: ghcr.io/.../:${SPATIUMDDI_VERSION}``
# would resolve to ``:latest`` + try to pull from ghcr.io. Air-gap:
# fatal. The bake stamps this sidecar precisely so the chart can pull
# locally.
SPATIUMDDI_VERSION="dev"
if [ -f "$SPATIUMDDI_VERSION_FILE" ]; then
    SPATIUMDDI_VERSION="$(cat "$SPATIUMDDI_VERSION_FILE")"
fi
if [ -f /etc/spatiumddi/release ]; then
    # shellcheck disable=SC1091
    . /etc/spatiumddi/release
fi

# ── Host-side state dirs ─────────────────────────────────────────────────────
# /var/lib/spatiumddi/release-state — trigger files for slot upgrades,
# host runner state sidecars. Sticky-bit world-write so the supervisor
# pod (uid varies per image) can drop trigger files without us tracking
# its in-pod uid.
mkdir -p /var/lib/spatiumddi/release-state /var/log/spatiumddi
chmod 1777 /var/lib/spatiumddi/release-state
chmod 0755 /var/log/spatiumddi

# Detect the host's root block device's rotational flag so the
# supervisor pod (which can't see the host's /proc/mounts properly —
# its container view shows ``overlay`` mounted at /) can surface
# "ssd" / "hdd" in the Fleet UI's capabilities block. Write to a
# sidecar in release-state; the supervisor reads it on every
# heartbeat. ``unknown`` written on detection failure.
{
    detected="unknown"
    while read -r src mount _; do
        [ "$mount" = "/" ] || continue
        case "$src" in
            /dev/*)
                name="${src#/dev/}"
                # Strip trailing partition digits, but preserve nvme's
                # pN suffix by stripping until a non-digit then one
                # more strip if it ends with 'p'.
                while [ -n "$name" ] && [ -z "${name##*[0-9]}" ]; do
                    name="${name%?}"
                done
                case "$name" in *p) name="${name%p}";; esac
                if [ -r "/sys/block/$name/queue/rotational" ]; then
                    rot=$(cat "/sys/block/$name/queue/rotational")
                    if [ "$rot" = "1" ]; then
                        detected="hdd"
                    else
                        detected="ssd"
                    fi
                fi
                ;;
        esac
        break
    done < /proc/mounts
    printf '%s\n' "$detected" > /var/lib/spatiumddi/release-state/host-storage-type
    chmod 0644 /var/lib/spatiumddi/release-state/host-storage-type
}

# k3s's auto-deploy manifests dir. k3s creates this on first start,
# but firstboot races k3s.service so we may get here first. Pre-
# create with permissive perms so the supervisor / helm-controller
# can write status sidecars.
mkdir -p "$K3S_MANIFESTS_DIR"
chmod 0700 "$K3S_MANIFESTS_DIR"

# ── First-boot only: generate .env ───────────────────────────────────────────
if [ ! -f "$ENV_FILE" ]; then
    echo "Generating $ENV_FILE (first boot)"
    umask 077
    APPLIANCE_VERSION_VAL="0.1.0"
    if [ -f /etc/spatiumddi/appliance-release ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/appliance-release
        APPLIANCE_VERSION_VAL="${APPLIANCE_VERSION:-0.1.0}"
    fi
    APPLIANCE_HOSTNAME_VAL=$(hostname 2>/dev/null || echo "spatiumddi")
    # Host's globally-scoped IPs — surfaced as SANs on the self-
    # signed cert the appliance generates so browser warnings are
    # "unknown CA" instead of "subject mismatch". Comma-separated.
    APPLIANCE_HOST_IPS_VAL=$(ip -o addr show scope global 2>/dev/null \
        | awk '{print $4}' | cut -d/ -f1 | paste -sd, -)
    # spatium-install drops /etc/spatiumddi/role-config with ROLE +
    # CONTROL_PLANE_URL + BOOTSTRAP_PAIRING_CODE for Application
    # appliances. The .env carries them so the supervisor pod's
    # entrypoint can source the file + propagate to the pod env.
    ROLE=full-stack
    INSTALL_CONTROL_PLANE_URL=""
    INSTALL_BOOTSTRAP_PAIRING_CODE=""
    if [ -f /etc/spatiumddi/role-config ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/role-config
        INSTALL_CONTROL_PLANE_URL="${CONTROL_PLANE_URL:-}"
        INSTALL_BOOTSTRAP_PAIRING_CODE="${BOOTSTRAP_PAIRING_CODE:-}"
    fi

    BOOTSTRAP_PAIRING_CODE_VAL=""
    case "$ROLE" in
        application)
            DNS_AGENT_KEY_VAL=""
            DHCP_AGENT_KEY_VAL=""
            BOOTSTRAP_PAIRING_CODE_VAL="$INSTALL_BOOTSTRAP_PAIRING_CODE"
            CONTROL_PLANE_URL_VAL="$INSTALL_CONTROL_PLANE_URL"
            AGENT_GROUP_VAL="default"
            ;;
        frontend-core)
            DNS_AGENT_KEY_VAL=$(gen_hex 24)
            DHCP_AGENT_KEY_VAL=$(gen_hex 24)
            CONTROL_PLANE_URL_VAL=""
            AGENT_GROUP_VAL="default"
            ;;
        *)
            ROLE=full-stack
            DNS_AGENT_KEY_VAL=$(gen_hex 24)
            DHCP_AGENT_KEY_VAL=$(gen_hex 24)
            CONTROL_PLANE_URL_VAL=""
            AGENT_GROUP_VAL="default"
            ;;
    esac
    cat > "$ENV_FILE" <<EOF
# Auto-generated by spatiumddi-firstboot on $(date -Iseconds).
# Sourced by the spatium-supervisor pod entrypoint at startup.
# Appliance role (#170 Wave B2): $ROLE
SPATIUMDDI_VERSION=${SPATIUMDDI_VERSION}
POSTGRES_PASSWORD=$(gen_hex 24)
SECRET_KEY=$(gen_hex 32)
CREDENTIAL_ENCRYPTION_KEY=$(gen_fernet)
DNS_AGENT_KEY=${DNS_AGENT_KEY_VAL}
DHCP_AGENT_KEY=${DHCP_AGENT_KEY_VAL}
BOOTSTRAP_PAIRING_CODE=${BOOTSTRAP_PAIRING_CODE_VAL}
CONTROL_PLANE_URL=${CONTROL_PLANE_URL_VAL}
AGENT_GROUP=${AGENT_GROUP_VAL}
APPLIANCE_ROLE=${ROLE}
APPLIANCE_VERSION=${APPLIANCE_VERSION_VAL}
APPLIANCE_HOSTNAME=${APPLIANCE_HOSTNAME_VAL}
APPLIANCE_HOST_IPS=${APPLIANCE_HOST_IPS_VAL}
EOF
    # Mode 644 so the supervisor pod's unprivileged user (uid varies
    # per image) can read the file through the hostPath bind mount
    # at /etc/spatiumddi-host/.env.
    chmod 644 "$ENV_FILE"
fi

# ── Every boot: reconcile SPATIUMDDI_VERSION + APPLIANCE_VERSION ─────────────
# A slot upgrade lands new container images on the new rootfs but
# .env (on /var, shared across slots) still points at the OLD tag.
# Re-sed the matching lines so the chart's ``image: ...:${VERSION}``
# always resolves to bytes preloaded in containerd.
if [ -f "$ENV_FILE" ]; then
    if [ -f "$SPATIUMDDI_VERSION_FILE" ]; then
        CURRENT_SPATIUMDDI_VERSION="$(cat "$SPATIUMDDI_VERSION_FILE")"
        sed -i "s|^SPATIUMDDI_VERSION=.*|SPATIUMDDI_VERSION=${CURRENT_SPATIUMDDI_VERSION}|" "$ENV_FILE"
    fi
    if [ -f /etc/spatiumddi/appliance-release ]; then
        # shellcheck disable=SC1091
        . /etc/spatiumddi/appliance-release
        CURRENT_APPLIANCE_VERSION="${APPLIANCE_VERSION:-0.1.0}"
        sed -i "s|^APPLIANCE_VERSION=.*|APPLIANCE_VERSION=${CURRENT_APPLIANCE_VERSION}|" "$ENV_FILE"
    fi
fi

# ── Render the bootstrap HelmChart manifest ──────────────────────────────────
# k3s's helm-controller watches /var/lib/rancher/k3s/server/manifests/
# for ``HelmChart`` CRs + reconciles them into Helm releases at
# startup. We base64-encode the baked chart tarball into
# ``spec.chartContent`` so the chart applies inline (no registry
# lookup, no chart repo — air-gap-clean).
#
# ``supervisor.enabled: true`` is the only operator-driven flag — the
# control plane assigns role flags (dnsBind9.enabled, dnsPowerdns.
# enabled, dhcpKea.enabled) later via the supervisor's lifecycle
# module once the appliance is paired.
#
# We re-render on every boot. The chart bytes don't change between
# boots on the same slot, but a slot upgrade swings in a new tgz +
# we want the bootstrap manifest to reflect that without an extra
# step. Atomic-rename via .new so a partial write doesn't break
# helm-controller's parse.
if [ -f "$CHART_TGZ" ]; then
    echo "Rendering $BOOTSTRAP_MANIFEST from $CHART_TGZ"
    CHART_B64=$(base64 -w0 "$CHART_TGZ")
    tmp="${BOOTSTRAP_MANIFEST}.new"
    cat > "$tmp" <<EOF
# Auto-generated by spatiumddi-firstboot — do not hand-edit.
# Re-rendered on every boot from the slot-baked chart tarball.
#
# The Namespace ships separately from the HelmChart with
# createNamespace=false: if we let helm own the namespace, any later
# helm reconciliation that finds the release in a "failed" state
# will try to recreate it and hit "namespaces \"spatium\" already
# exists" because the namespace is still there from a partial
# previous install. Pre-creating + opting out of helm namespace
# management makes reinstalls idempotent.
apiVersion: v1
kind: Namespace
metadata:
  name: spatium
---
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: spatium-bootstrap
  namespace: kube-system
spec:
  chartContent: ${CHART_B64}
  targetNamespace: spatium
  createNamespace: false
  valuesContent: |
    global:
      imageTag: ${SPATIUMDDI_VERSION}
      imagePullPolicy: Never
    supervisor:
      enabled: true
    # Phase 10 wave 2 — bootstrap release owns supervisor +
    # agent-landing only; role pods live in the supervisor-driven
    # spatiumddi-appliance release. Explicit ``enabled: false`` so
    # the two releases don't fight over the same Deployments.
    dnsBind9:
      enabled: false
    dnsPowerdns:
      enabled: false
    dhcpKea:
      enabled: false
EOF
    mv "$tmp" "$BOOTSTRAP_MANIFEST"
    chmod 0600 "$BOOTSTRAP_MANIFEST"
else
    echo "WARN: $CHART_TGZ missing — supervisor pod won't auto-deploy. Is the chart baked?"
fi

# ── Render agent landing page ───────────────────────────────────────────────
# Static "this is a SpatiumDDI appliance" page served on :80 by the
# agent-landing nginx pod (chart template:
# templates/agent-landing.yaml). Template lives at
# /usr/local/share/spatiumddi/agent-landing/index.html.in; firstboot
# substitutes hostname + control-plane URL + version, writes the
# result to /var/lib/spatiumddi/agent-landing/index.html where the
# pod mounts it via hostPath.
#
# Reset umask before the write — the .env-secrets path above set 077
# which would leave the file 0600 (root-readable only) + nginx
# would 403 it.
umask 022
LANDING_TEMPLATE=/usr/local/share/spatiumddi/agent-landing/index.html.in
LANDING_DIR=/var/lib/spatiumddi/agent-landing
if [ -r "$LANDING_TEMPLATE" ]; then
    mkdir -p "$LANDING_DIR"
    chmod 0755 "$LANDING_DIR"
    # Pull CONTROL_PLANE_URL / APPLIANCE_HOSTNAME / SPATIUMDDI_VERSION
    # out of /etc/spatiumddi/.env (the same file firstboot just
    # wrote or refreshed above). grep|cut so we don't have to
    # ``source`` a file that might carry shell-special chars.
    _env_get() {
        grep "^${1}=" "$ENV_FILE" 2>/dev/null | tail -1 | cut -d= -f2-
    }
    HN=$(_env_get APPLIANCE_HOSTNAME)
    HN="${HN:-$(hostname 2>/dev/null || echo unknown)}"
    CPU=$(_env_get CONTROL_PLANE_URL)
    CPU="${CPU:-(not set)}"
    VER=$(_env_get SPATIUMDDI_VERSION)
    VER="${VER:-(unknown)}"
    sed \
        -e "s|__HOSTNAME__|${HN}|g" \
        -e "s|__CONTROL_PLANE_URL__|${CPU}|g" \
        -e "s|__APPLIANCE_VERSION__|${VER}|g" \
        "$LANDING_TEMPLATE" > "$LANDING_DIR/index.html"
    chmod 0644 "$LANDING_DIR/index.html"
    echo "Rendered $LANDING_DIR/index.html"
fi

# ── Phase 8 — refresh per-slot version sidecar ──────────────────────────────
# Best-effort: a failure here doesn't block — the api just falls back
# to "unknown" for the slot the operator hasn't booted into recently.
if [ -x /usr/local/bin/spatium-upgrade-slot ] && [ -e /etc/spatiumddi/role-config ]; then
    /usr/local/bin/spatium-upgrade-slot sync-versions || \
        echo "WARN: sync-versions failed — OS Image card will show 'unknown' for slot versions"
fi

# ── Readiness wait + slot commit ─────────────────────────────────────────────
# Phase 8c — commit the active slot as the durable default after a
# successful trial boot. spatium-upgrade-slot set-next-boot writes a
# one-shot saved_entry to grubenv via grub-reboot; that's auto-cleared
# on this boot. If THIS boot is healthy, we make the swap permanent
# via grub-set-default. If anything fails before this point, the
# previous slot's saved_entry stays in grubenv → next reboot reverts.
commit_slot_if_healthy() {
    local grub_boot_dir=/boot/efi
    if [ ! -f "${grub_boot_dir}/grub/grubenv" ]; then
        return 0
    fi
    local root_uuid="" current_slot=""
    root_uuid=$(awk 'BEGIN{RS=" "} /^root=UUID=/{print substr($0,11)}' /proc/cmdline 2>/dev/null | head -1)
    if [ -n "$root_uuid" ]; then
        local root_dev
        root_dev=$(blkid -U "$root_uuid" 2>/dev/null)
        if [ -n "$root_dev" ]; then
            current_slot=$(lsblk -no PARTLABEL "$root_dev" 2>/dev/null | tr 'A-Z' 'a-z' | head -1)
        fi
    fi
    case "$current_slot" in
        root_a) current_slot=slot_a ;;
        root_b) current_slot=slot_b ;;
        *)      return 0 ;;
    esac
    local saved
    saved=$(grub-editenv "${grub_boot_dir}/grub/grubenv" list 2>/dev/null \
            | awk -F= '/^saved_entry=/{print $2}')
    if [ "$saved" = "$current_slot" ]; then
        echo "  slot $current_slot is already the durable default — nothing to commit."
        return 0
    fi
    echo "  trial boot detected (booted=$current_slot, durable=${saved:-unset})."
    echo "  k3s reports Ready — committing $current_slot as the new default."
    grub-set-default --boot-directory="$grub_boot_dir" "$current_slot" \
        >> "$LOG" 2>&1 || true
}

# Wait for k3s to come up + helm-controller to apply the bootstrap
# manifest. ``kubectl get --raw=/readyz`` is the canonical readiness
# probe; once it returns 200 the supervisor pod can be scheduled.
# Up to 5 min — first boot has to pull no images (everything's in
# containerd via the airgap-import path) but k3s itself + helm-
# controller + the supervisor pod still need to settle.
echo "Waiting for k3s /readyz …"
export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
ready=0
for _ in $(seq 1 60); do
    if /usr/local/bin/k3s kubectl get --raw=/readyz 2>/dev/null | grep -q '^ok'; then
        ready=1
        break
    fi
    sleep 5
done
if [ "$ready" = 1 ]; then
    date -Iseconds > "$STAMP"
    IP=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
    echo "Ready: k3s up on ${IP:-<appliance-ip>}; supervisor pod auto-deploys via $BOOTSTRAP_MANIFEST"
    commit_slot_if_healthy
    exit 0
fi
echo "WARN: k3s /readyz did not respond within 5 minutes." >&2
echo "      Check 'systemctl status k3s' + 'journalctl -u k3s'." >&2
exit 1
