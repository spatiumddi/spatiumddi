#!/bin/bash
# spatiumddi-update — host-side updater run as a systemd oneshot
# whenever the api container writes /var/lib/spatiumddi/release-pending.
#
# The api can't recreate itself from inside (docker-compose up would
# kill the container mid-request). So the api writes the desired tag
# to the trigger file; ``spatiumddi-update.path`` notices; this script
# runs as root on the host, updates SPATIUMDDI_VERSION in .env,
# docker-compose pulls + recreates, renames the trigger to .done.
#
# Phase 4c, issue #134.

set -euo pipefail

TRIGGER=/var/lib/spatiumddi/release-state/release-pending
ENV_FILE=/etc/spatiumddi/.env
COMPOSE_DIR=/usr/local/share/spatiumddi
LOG_DIR=/var/log/spatiumddi
LOG="$LOG_DIR/update.log"

mkdir -p "$LOG_DIR"
exec >> "$LOG" 2>&1
echo
echo "[$(date -Iseconds)] === spatiumddi-update fired ==="

if [ ! -f "$TRIGGER" ]; then
    echo "  no trigger file at $TRIGGER, nothing to do"
    exit 0
fi

TAG=$(head -c 80 "$TRIGGER" | tr -d '\n\r ' | tr -cd 'A-Za-z0-9._-')
if [ -z "$TAG" ]; then
    echo "  empty / invalid tag in trigger file, aborting"
    mv "$TRIGGER" "${TRIGGER}.invalid.$(date +%s)"
    exit 1
fi
echo "  target tag: $TAG"

if [ ! -f "$ENV_FILE" ]; then
    echo "  ERROR: $ENV_FILE missing — appliance not initialised yet"
    exit 1
fi

if grep -q '^SPATIUMDDI_VERSION=' "$ENV_FILE"; then
    sed -i "s|^SPATIUMDDI_VERSION=.*|SPATIUMDDI_VERSION=$TAG|" "$ENV_FILE"
    echo "  updated SPATIUMDDI_VERSION in $ENV_FILE"
else
    echo "SPATIUMDDI_VERSION=$TAG" >> "$ENV_FILE"
    echo "  appended SPATIUMDDI_VERSION to $ENV_FILE"
fi

cd "$COMPOSE_DIR"

echo "  pulling image set..."
if ! docker-compose pull; then
    echo "  ERROR: docker-compose pull failed — rolling back .env"
    # Best-effort rollback so the operator isn't stuck on a non-pullable tag
    if [ -n "${PREVIOUS_TAG:-}" ]; then
        sed -i "s|^SPATIUMDDI_VERSION=.*|SPATIUMDDI_VERSION=${PREVIOUS_TAG}|" "$ENV_FILE"
    fi
    mv "$TRIGGER" "${TRIGGER}.failed.$(date +%s)"
    exit 1
fi

echo "  recreating stack..."
docker-compose up -d

mv "$TRIGGER" "${TRIGGER}.done"
echo "[$(date -Iseconds)] === spatiumddi-update complete; running $TAG ==="
