#!/bin/bash
# Mount / unmount the per-slot baked docker overlay (#170 Phase E1).
#
# Invoked by spatium-docker-overlay.service before / after
# docker.service. The overlay layout:
#
#   lowerdir: /var/lib/spatiumddi/docker-overlay/lower
#             = loop-mount of /usr/lib/spatiumddi/docker-overlay.img
#               (read-only ext4, baked at appliance-build time;
#                lives on the slot rootfs so slot rollback brings
#                the matching container set back automatically)
#   upperdir: /var/persist/docker-overlay-upper
#   workdir:  /var/persist/docker-overlay-work
#   merged:   /var/lib/docker
#
# upperdir + workdir live on /var so post-boot ``docker pull`` (e.g.
# an operator pulling a debug image) survives a reboot. They're
# wiped on slot swap so the new lower's layer set is the canonical
# source — operator-side bytes that referenced the old lower's
# layers would be broken anyway.
#
# Strict appliance-only — refuses to run on docker / k8s / dev
# without the baked overlay image.

set -euo pipefail

OVERLAY_IMG=/usr/lib/spatiumddi/docker-overlay.img
OVERLAY_VERSION=/usr/lib/spatiumddi/docker-overlay.version
LOWER_DIR=/var/lib/spatiumddi/docker-overlay/lower
UPPER_DIR=/var/persist/docker-overlay-upper
WORK_DIR=/var/persist/docker-overlay-work
MERGED_DIR=/var/lib/docker
# Slot-version sidecar — when this changes we clear upperdir so the
# new lower's layer set takes over cleanly.
LAST_LOWER_VERSION=/var/persist/docker-overlay-last-version

if [ ! -f "$OVERLAY_IMG" ]; then
    echo "spatium-docker-overlay: $OVERLAY_IMG missing — bailing" >&2
    exit 1
fi

cmd="${1:-mount}"

mount_overlay() {
    mkdir -p "$LOWER_DIR" "$UPPER_DIR" "$WORK_DIR" "$MERGED_DIR"

    # Loop-mount the read-only baked image as the lowerdir source.
    # mountpoint -q returns success when already mounted; in that case
    # don't re-mount (re-entry from systemd retry / manual run).
    if ! mountpoint -q "$LOWER_DIR"; then
        mount -o ro,loop "$OVERLAY_IMG" "$LOWER_DIR"
    fi

    # Slot-swap detection — if the baked version differs from the
    # last applied, wipe the upperdir so leftover refs to the prior
    # slot's layer SHAs don't survive. Slot-stable bytes in /var
    # (image-pull cache from operator activity) are deliberately not
    # carried across slot swaps because the underlying overlay2
    # SHAs may not match.
    current_version=""
    if [ -f "$OVERLAY_VERSION" ]; then
        current_version="$(cat "$OVERLAY_VERSION" 2>/dev/null || true)"
    fi
    last_version=""
    if [ -f "$LAST_LOWER_VERSION" ]; then
        last_version="$(cat "$LAST_LOWER_VERSION" 2>/dev/null || true)"
    fi
    if [ -n "$current_version" ] && [ "$current_version" != "$last_version" ]; then
        echo "spatium-docker-overlay: slot version $last_version → $current_version, clearing upperdir"
        rm -rf "$UPPER_DIR" "$WORK_DIR"
        mkdir -p "$UPPER_DIR" "$WORK_DIR"
        printf '%s\n' "$current_version" > "$LAST_LOWER_VERSION"
    fi

    # Overlay-mount the merged view at /var/lib/docker. Re-entry safe
    # via mountpoint check.
    if ! mountpoint -q "$MERGED_DIR"; then
        mount -t overlay overlay \
            -o "lowerdir=$LOWER_DIR,upperdir=$UPPER_DIR,workdir=$WORK_DIR" \
            "$MERGED_DIR"
    fi
}

umount_overlay() {
    if mountpoint -q "$MERGED_DIR"; then
        umount "$MERGED_DIR"
    fi
    if mountpoint -q "$LOWER_DIR"; then
        umount "$LOWER_DIR"
    fi
}

case "$cmd" in
    mount)   mount_overlay ;;
    umount)  umount_overlay ;;
    *)
        echo "Usage: $0 {mount|umount}" >&2
        exit 1
        ;;
esac
