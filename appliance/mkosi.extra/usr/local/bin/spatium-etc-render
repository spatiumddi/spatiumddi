#!/bin/sh
# spatium-etc-render — issue #276.
#
# Early-boot generator that materializes operator-mutable /etc bits
# from the STATE partition (/var/lib/spatium-state) BEFORE the
# services that read them start (systemd-hostnamed, sshd, k3s).
#
# Why this exists: pre-#276 the appliance's hostname + SSH host keys
# lived in the /etc overlay LOWER (/usr/lib/etc.image), captured
# per-slot at build/install time. Every fresh slot image carried its
# own keys + an empty hostname, so an OS slot upgrade silently
# changed the SSH host key (MITM warning) and reset the kernel
# hostname to ``localhost`` (k3s registered a brand-new node). This
# script makes STATE — a dedicated partition that survives slot swaps
# AND a /var factory reset — the single source of truth, rendered
# into /etc on every boot before anything reads it.
#
# Runs After=etc.mount + the STATE fstab mount, Before=sysinit.target
# / sshd / k3s. Degrades gracefully: a missing/empty STATE leaves the
# image-baseline /etc untouched (and seeds STATE from the current
# values so the NEXT boot is authoritative).

set -eu

STATE_DIR=/var/lib/spatium-state
CONFIG="$STATE_DIR/spatium-config.yaml"
LOG=/var/log/spatiumddi/etc-render.log

mkdir -p "$(dirname "$LOG")"
exec >>"$LOG" 2>&1
echo "=== spatium-etc-render $(date -Iseconds) ==="

# Flat ``key: value`` reader for the top level of spatium-config.yaml.
# The config is intentionally flat (no nested maps in v1) so a sed
# one-liner avoids a python/yaml dependency this early in boot.
# Strips surrounding quotes + leading/trailing whitespace.
get_cfg() {
    [ -f "$CONFIG" ] || return 0
    sed -n "s/^$1:[[:space:]]*//p" "$CONFIG" | head -1 \
        | sed 's/[[:space:]]*$//; s/^"//; s/"$//; s/^'\''//; s/'\''$//'
}

if [ ! -d "$STATE_DIR" ]; then
    echo "STATE dir $STATE_DIR absent — using image-baseline /etc (no render)."
    exit 0
fi

# ── Hostname ─────────────────────────────────────────────────────────
# Set the kernel hostname immediately (``hostname`` syscall) so k3s +
# sshd, which start after this unit, see the right name. Also write
# /etc/hostname (overlay upper) so a later systemd-hostnamed read
# agrees. systemd already set a (wrong, image-baseline) hostname in
# PID1 before etc.mount fired; this corrects it before any consumer.
HOSTNAME_VAL="$(get_cfg hostname)"
if [ -n "$HOSTNAME_VAL" ]; then
    echo "$HOSTNAME_VAL" > /etc/hostname
    hostname "$HOSTNAME_VAL" 2>/dev/null \
        && echo "hostname → $HOSTNAME_VAL" \
        || echo "WARN: 'hostname $HOSTNAME_VAL' failed (kernel hostname unchanged)"
else
    echo "no hostname in $CONFIG — leaving image-baseline hostname"
fi

# ── SSH host keys ────────────────────────────────────────────────────
# Authoritative copy lives in STATE. Restore into /etc/ssh so sshd
# presents a stable identity across slot swaps. If STATE has none yet
# (fresh install where the seeding step didn't run, or an upgrade off
# a pre-#276 image), generate the standard set + persist to STATE so
# the next boot is authoritative.
if ls "$STATE_DIR"/ssh/ssh_host_*_key >/dev/null 2>&1; then
    mkdir -p /etc/ssh
    cp -a "$STATE_DIR"/ssh/ssh_host_* /etc/ssh/ 2>/dev/null || true
    chmod 600 /etc/ssh/ssh_host_*_key 2>/dev/null || true
    chmod 644 /etc/ssh/ssh_host_*_key.pub 2>/dev/null || true
    echo "SSH host keys restored from STATE"
else
    echo "no SSH host keys in STATE — generating + persisting"
    ssh-keygen -A >/dev/null 2>&1 || true
    mkdir -p "$STATE_DIR/ssh"
    cp -a /etc/ssh/ssh_host_*_key /etc/ssh/ssh_host_*_key.pub "$STATE_DIR/ssh/" 2>/dev/null || true
fi

# ── role-config ──────────────────────────────────────────────────────
# The appliance's role + control-plane URL + bootstrap pairing code.
# firstboot transcribes ROLE into /etc/spatiumddi/.env; the supervisor
# self-bootstrap path + the api's host bind mount read it too. Source
# of truth moves to STATE; this renders it into the runtime path.
ROLE_VAL="$(get_cfg role)"
if [ -n "$ROLE_VAL" ]; then
    CONTROL_PLANE_URL_VAL="$(get_cfg control_plane_url)"
    BOOTSTRAP_PAIRING_CODE_VAL="$(get_cfg bootstrap_pairing_code)"
    mkdir -p /etc/spatiumddi
    {
        echo "ROLE=$ROLE_VAL"
        echo "CONTROL_PLANE_URL=$CONTROL_PLANE_URL_VAL"
        echo "BOOTSTRAP_PAIRING_CODE=$BOOTSTRAP_PAIRING_CODE_VAL"
    } > /etc/spatiumddi/role-config
    chmod 0644 /etc/spatiumddi/role-config
    echo "role-config rendered (ROLE=$ROLE_VAL)"
else
    echo "no role in $CONFIG — leaving existing /etc/spatiumddi/role-config"
fi

echo "=== spatium-etc-render done ==="
