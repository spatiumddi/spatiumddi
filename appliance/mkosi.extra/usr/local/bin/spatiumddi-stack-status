#!/bin/sh
# Quick at-a-glance status for the SpatiumDDI appliance stack.
# Intended to be the operator's first command after SSH'ing in.
#
# Issue #183 Phase 7 — the appliance is k3s-only; this used to
# call ``docker-compose ps``. Now it queries the local k3s via
# ``kubectl get pods``. Runs as the unprivileged admin user;
# /etc/profile.d/k3s.sh exports KUBECONFIG=/etc/rancher/k3s/
# k3s.yaml so kubectl works without flags.

set -eu

RELEASE_FILE=/etc/spatiumddi/release

echo "── SpatiumDDI appliance ──────────────────────────────────────"
if [ -r "$RELEASE_FILE" ]; then
    awk '/^SPATIUMDDI_VERSION=/{ sub(/^SPATIUMDDI_VERSION=/, "Release pin: "); print }' "$RELEASE_FILE"
elif [ -r /usr/lib/spatiumddi/spatiumddi-version ]; then
    echo "Release pin: $(cat /usr/lib/spatiumddi/spatiumddi-version)  (slot bake)"
else
    echo "Release pin: unknown"
fi

if [ -r /var/lib/spatiumddi/firstboot.done ]; then
    echo "First boot:  $(cat /var/lib/spatiumddi/firstboot.done)"
else
    echo "First boot:  NOT YET COMPLETED — see /var/log/spatiumddi/firstboot.log"
fi

IP=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
echo "Web UI:      http://${IP:-<appliance-ip>}/"
echo

if [ -x /usr/local/bin/kubectl ] && [ -r /etc/rancher/k3s/k3s.yaml ]; then
    export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
    echo "── k3s ───────────────────────────────────────────────────────"
    if kubectl get --raw=/readyz 2>/dev/null | grep -q '^ok'; then
        echo "kubeapi:     ready"
    else
        echo "kubeapi:     UNREACHABLE — see 'systemctl status k3s'"
    fi
    echo "Nodes:"
    kubectl get nodes -o wide 2>/dev/null | sed 's/^/  /' || \
        echo "  (no nodes returned)"
    echo
    echo "Pods:"
    kubectl get pods -A -o wide 2>/dev/null | sed 's/^/  /' || \
        echo "  (no pods returned)"
else
    echo "── k3s ───────────────────────────────────────────────────────"
    echo "kubectl / kubeconfig missing — k3s may still be initialising."
    echo "Check 'systemctl status k3s' + 'journalctl -u k3s'."
fi
