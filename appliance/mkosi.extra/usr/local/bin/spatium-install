#!/bin/bash
# spatium-install — Proxmox-style installer wizard for the
# SpatiumDDI appliance.
#
# Asks the operator for target disk, hostname, admin user/password,
# network (DHCP or static), and timezone; then partitions the disk
# (GPT: 512 MiB ESP + rest root), rsyncs the live rootfs onto it,
# regenerates the initrd for disk boot, installs grub for both BIOS
# and UEFI, injects the answers, and reboots.
#
# Runs automatically on boot when `spatium-mode=install` is in the
# kernel cmdline (set by the "Install SpatiumDDI to disk" GRUB
# entry). Also available as a CLI tool from the live shell.

# Bulletproof launch log — first thing we do, BEFORE any set/trap/
# redirect setup or even nounset. If /var/log/spatium-install-launch.log
# is empty after a failure, bash did not parse the script at all
# (interpreter issue, shebang corruption, etc.). If it has at least
# one LAUNCH entry, we know the script body started executing and
# can compare timestamps against journalctl + the install / trace
# logs to pinpoint the bail.
#
# Uses only shell builtins + utilities present in every Debian
# rootfs (date, tty, id, cat, command, ls) so the logger itself
# can't fail in a way the diagnostic forgets to record.
#
# Skipped entirely in the host-portable `--check-preseed` / `--help`
# modes (issue #581) so the offline lint truly touches nothing — no
# /var/log write — and can run unprivileged on any dev / CI box. The
# nested brace + `2>/dev/null` on the real-install path also silences the
# redirect-open error itself if /var/log is not writable.
case "${1:-}" in
    --check-preseed|--help|-h) : ;;
    *)
    { {
        printf '[%s] LAUNCH\n'      "$(date -Iseconds 2>/dev/null || echo '?')"
        printf '  pid=%s ppid=%s\n' "$$" "$PPID"
        printf '  tty=%s\n'         "$(tty 2>/dev/null || echo '?')"
        printf '  uid=%s\n'         "$(id -u 2>/dev/null || echo '?')"
        printf '  bash=%s\n'        "${BASH_VERSION:-?}"
        printf '  pwd=%s\n'         "$(pwd 2>/dev/null || echo '?')"
        printf '  cmdline=%s\n'     "$(tr '\n' ' ' </proc/cmdline 2>/dev/null)"
        printf '  whiptail=%s\n'    "$(command -v whiptail 2>/dev/null || echo MISSING)"
        printf '  sgdisk=%s\n'      "$(command -v sgdisk 2>/dev/null || echo MISSING)"
        printf '  rsync=%s\n'       "$(command -v rsync 2>/dev/null || echo MISSING)"
        printf '  varlog=%s\n'      "$(ls -ld /var/log 2>&1)"
        printf -- '----\n'
    } >> /var/log/spatium-install-launch.log 2>&1
    } 2>/dev/null || true
    ;;
esac

# pipefail + nounset for the wizard, but NOT -e: whiptail returns
# non-zero on Cancel/Esc and we want to handle that explicitly with
# on_cancel rather than crashing the script. -e is re-enabled inside
# do_install where we DO want any partition / rsync / chroot failure
# to abort.
set -uo pipefail

BACKTITLE="SpatiumDDI Appliance Installer 0.1.0"
# The SPATIUM_INSTALL_LOG override + the /dev/null fallback below exist
# for the host-portable `--check-preseed` linter (issue #581) and its
# pytest suite, which run this script unprivileged on machines where
# /var/log isn't writable by the caller.
INSTALL_LOG="${SPATIUM_INSTALL_LOG:-/var/log/spatium-install.log}"
MOUNT=/mnt/target

mkdir -p /var/log 2>/dev/null || true
if ! : 2>/dev/null > "$INSTALL_LOG"; then
    INSTALL_LOG=/dev/null
fi
# Log to file only — NOT stdout. The do_install brace group below
# pipes stdout to whiptail's --gauge protocol parser, which expects
# only "XXX" / percentage / prompt-text lines. If log() tee'd to
# stdout it would inject timestamped lines into the gauge stream
# between XXX blocks and break the prompt update protocol — that's
# exactly the "progress text never changes" symptom we hit.
log() { echo "[$(date -Iseconds)] $*" >> "$INSTALL_LOG"; }

# Full bash trace to a separate file — when the wizard bails
# unexpectedly, this captures every command + variable expansion so
# we can pinpoint the exact line. Doesn't pollute the user-facing
# install log.
TRACE_LOG="${SPATIUM_INSTALL_TRACE_LOG:-/var/log/spatium-install-trace.log}"
if ! : 2>/dev/null > "$TRACE_LOG"; then
    # Same host-portable fallback as INSTALL_LOG above (issue #581) — a
    # failed `exec 19>` would kill a non-interactive bash outright.
    TRACE_LOG=/dev/null
fi
exec 19> "$TRACE_LOG"
# Export so the gauge subshell pipeline below inherits the same
# trace fd. Without export, the subshell's BASH_XTRACEFD defaults
# to stderr — and the install pipeline pipes stdout to whiptail
# while stderr is the terminal, so every traced command writes
# garbage to the same TTY whiptail is trying to redraw. Result:
# whiptail's progress dialog never updates because its display
# fights with set -x output.
export BASH_XTRACEFD=19
PS4='+ ${BASH_SOURCE##*/}:${LINENO}: ${FUNCNAME[0]:-main}() '
# No bash trace in the host-portable `--check-preseed` / `--help` modes
# (issue #581): the lint runs unprivileged and its machine-readable
# output must not be polluted by set -x spew, and on bash < 4.1
# BASH_XTRACEFD isn't honoured so the trace would go to stderr.
case "${1:-}" in
    --check-preseed|--help|-h) ;;
    *) set -x ;;
esac

log "===== spatium-install wizard started at $(date -Iseconds) ====="

on_cancel() {
    set +x
    clear
    cat <<EOF

Installation cancelled at: $1

Run 'spatium-install' to start the wizard again,
or 'reboot' to leave the live ISO and try a different boot path.

EOF
    log "Wizard cancelled at: $1"
    exec /bin/bash --login
}

# Wizard state — all set by the prompt functions below.
TARGET_DISK=""
HOSTNAME=""
ADMIN_USER="admin"
ADMIN_PASSWORD=""
# Optional crypt(3) admin password hash (headless preseed, issue #549).
# When set, do_install feeds it through `chpasswd -e` instead of the
# plaintext ADMIN_PASSWORD. Mutually exclusive with ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=""
NET_MODE="dhcp"
NET_INTERFACE=""
NET_IP=""
NET_PREFIX="24"
NET_GATEWAY=""
NET_DNS="1.1.1.1 1.0.0.1"
TIMEZONE="UTC"
# Issue #302 — k3s pod + service CIDRs. Defaults match k3s upstream
# defaults exactly so operators on a clean LAN don't have to touch
# them. Customisable in ``ask_k3s_cidrs`` for installs where the LAN
# already uses one of these ranges (Flannel ``host-gw`` writes routes
# directly; an overlapping pod CIDR masks the LAN). The cluster-dns
# IP is derived as ``<service_cidr_base>.0.10`` — k3s/kube-dns
# convention.
K3S_POD_CIDR="10.42.0.0/16"
K3S_SERVICE_CIDR="10.43.0.0/16"
# Disk / RAM sizing (#312).
#   MIN_DISK_GIB     — absolute hard floor for the A/B partition layout;
#                      pick_disk refuses below it for ANY role. Raised
#                      24 → 32 because the 24 GiB floor left /var only
#                      ~7 GiB, and the Control plane's first boot (k3s
#                      image import + CNPG/Redis PVCs all on /var) tipped
#                      the kubelet DiskPressure threshold into an
#                      eviction / image-GC thrash loop that never
#                      converges. 32 GiB leaves ~14 GiB usable /var.
#   REC_CP_DISK_GIB /
#   REC_CP_RAM_GIB   — RECOMMENDED Control-plane figures. Between the
#                      floor and these, pick_disk soft-warns (install
#                      proceeds) because the box still risks DiskPressure
#                      under load. The Appliance/agent role is light and
#                      gets no soft warning. Keep in sync with the
#                      "Recommended sizing" table in README +
#                      docs/deployment/APPLIANCE.md.
MIN_DISK_GIB=32
REC_CP_DISK_GIB=40
REC_CP_RAM_GIB=8
# Default ROLE = appliance (the role screen frames it as "Additional
# node"). #272 UX fix: operators don't read the body text, and a
# misclick / blind Enter on "control plane" silently spins up a SECOND
# standalone control plane (its own DB + cluster) instead of joining the
# existing one. Defaulting to the additive, non-destructive role — plus
# a confirm guard on the control-plane choice in ask_role() — makes that
# accident hard. The very first install actively picks "First node".
ROLE="appliance"
# Installer roles (#272 — collapsed from the old three to two; the
# old full-stack / frontend-core distinction is now a runtime DNS/DHCP
# role toggle, not an install choice):
#   control-plane — Runs the SpatiumDDI control plane (api + worker +
#                   beat + db + redis + frontend) and is the k3s etcd
#                   seed. DNS (BIND9) + DHCP (Kea) are OFF at install —
#                   the operator enables them per node via the Fleet
#                   role toggle (so the data plane is a deliberate
#                   fleet decision, not a silent install default). The
#                   required FIRST install; extra control-plane nodes
#                   are made by promoting Appliances in the Fleet UI,
#                   not installed as this role.
#   appliance     — Supervisor only. Pairs with a remote control plane
#                   via an 8-digit pairing code and sits in
#                   pending_approval until an admin clicks Approve in
#                   the Fleet UI. The control plane assigns the role(s)
#                   + group(s) after approval (DNS / DHCP). Can later
#                   be promoted to join the control-plane cluster.
# Every role still creates an OS admin account so the operator can
# SSH in and manage the appliance, irrespective of which web UI runs.
CONTROL_PLANE_URL=""
# Pairing code claimed by the supervisor on first boot. 8 decimal
# digits — single-use ephemeral or persistent depending on what the
# control-plane admin minted. Only meaningful when ROLE=appliance.
BOOTSTRAP_PAIRING_CODE=""

# ── Headless preseed state (issue #549) ────────────────────────────────
# When a preseed answer file is discovered + parsed, load_preseed sets
# PRESEED_ACTIVE=1, sources the resolved wizard variables + per-field
# PRESEED_HAS_* markers, and computes FULLY_UNATTENDED. Each ask_*
# prompt short-circuits when its field is preseeded; welcome + the final
# confirm are skipped entirely on a fully-unattended run. Partial
# preseeds fall through to the interactive prompt for missing fields.
PRESEED_ACTIVE=0
FULLY_UNATTENDED=0
PRESEED_SOURCE=""
PRESEED_ENV=/run/spatium-preseed.env
PRESEED_SECRET_ENV=/run/spatium-preseed-secret.env
# Candidate answer files discovered by discover_preseed, in priority
# order (parallel arrays). KIND is "explicit" (kernel cmdline value or a
# file literally named spatium-preseed.*) or "opportunistic" (a
# cloud-init user-data that may or may not carry a spatium_preseed
# block). load_preseed tries them in order, skipping ones with no
# preseed content so a plain user-data doesn't shadow a real preseed on
# a lower-priority source.
PRESEED_CAND_FILE=()
PRESEED_CAND_SRC=()
PRESEED_CAND_KIND=()

# ── Prompts ───────────────────────────────────────────────────────────────────

welcome() {
    log "Step: welcome"
    whiptail --backtitle "$BACKTITLE" --title "Welcome" \
        --msgbox "Welcome to the SpatiumDDI Appliance Installer.\n\n\
This installer will ERASE a target disk and install SpatiumDDI to it.\n\n\
You'll be asked for:\n\
  - Role (Control plane / Appliance)\n\
  - Target disk\n\
  - Hostname\n\
  - Admin OS user + password (for SSH access)\n\
  - Network (DHCP or static)\n\
  - Timezone\n\n\
Press OK to begin, or Cancel to drop to a shell." 18 70 \
        || on_cancel "welcome"
}

ask_role() {
    log "Step: ask_role"
    if [ -n "${PRESEED_HAS_ROLE:-}" ]; then
        log "Preseed: role=$ROLE (skipping prompt)"
        return 0
    fi
    # #272 UX — reframe the install role around the decision operators
    # actually make ("is this my FIRST SpatiumDDI node, or am I adding
    # one to an existing install?") instead of the jargon control-plane
    # vs appliance, which most people don't read past. The radio TAGS
    # are operator-facing (``add-node`` / ``first-node``) and map back to
    # the internal ROLE values (``appliance`` / ``control-plane``) that
    # firstboot + the supervisor consume — so downstream is unchanged.
    #
    # ``add-node`` (appliance) is listed first + default: it's the common
    # case once a control plane exists, and it's the non-destructive
    # choice. ``first-node`` (control-plane) creates a NEW, standalone
    # SpatiumDDI (its own DB + cluster), so a wrong pick there is the
    # real footgun — it's guarded by an explicit confirm below. The
    # per-row ON flag reflects $ROLE so backing in preserves the pick.
    local first_flag=OFF add_flag=OFF
    case "$ROLE" in
        control-plane) first_flag=ON ;;
        *) add_flag=ON ;;  # appliance (or unset) → default
    esac
    local pick
    while true; do
        pick=$(whiptail --backtitle "$BACKTITLE" --title "What is this node?" \
            --cancel-button "Back" \
            --radiolist "Is this your FIRST SpatiumDDI node, or are you adding one to an existing install?\n\n  Additional node  (default)\n    Pairs with an EXISTING SpatiumDDI over an 8-digit code; an\n    admin then approves it and assigns DNS / DHCP roles in the\n    Fleet UI. Can be PROMOTED into the control-plane cluster later\n    — this is how you add control-plane nodes for HA (NOT by\n    installing 'First node' again).\n\n  First node\n    Creates a NEW SpatiumDDI: the control plane (api + database +\n    web UI) + k3s seed. DNS + DHCP stay OFF — enable them per node\n    from the Fleet UI. Pick this for a homelab, a single box, or\n    the seed of a brand-new HA cluster." \
            27 84 2 \
            "add-node"   "Additional node — DNS/DHCP agent (promotable)" "$add_flag" \
            "first-node" "First node — new control plane (api+db+UI)" "$first_flag" \
            3>&1 1>&2 2>&3) || return 1
        if [ -z "$pick" ]; then
            whiptail --msgbox "Please pick an option to continue." 9 60 || true
            continue
        fi
        case "$pick" in
            add-node)
                ROLE="appliance"
                break
                ;;
            first-node)
                # Confirm guard — the accidental-footgun direction. A new
                # control plane is a separate database + cluster; adding
                # to an existing SpatiumDDI must use "Additional node"
                # then promote. --defaultno so a blind Enter says No.
                if whiptail --backtitle "$BACKTITLE" \
                    --title "Create a NEW control plane?" \
                    --defaultno --yes-button "Yes, new" --no-button "Go back" \
                    --yesno "This creates a NEW, standalone SpatiumDDI — its own database and cluster.\n\nIf you are ADDING a node to an existing SpatiumDDI (for HA, or as a DNS / DHCP agent), choose \"Additional node\" instead, then promote it from the Fleet UI.\n\nCreate a new control plane on this box?" \
                    16 76; then
                    ROLE="control-plane"
                    break
                fi
                # No → re-show the radio with the safe default pre-selected.
                first_flag=OFF
                add_flag=ON
                continue
                ;;
        esac
    done
    log "Selected role: $ROLE"
}

ask_application_config() {
    # Only fires for the Appliance role. The control-plane role IS a
    # control plane — it doesn't need to be told where one is.
    # (Function/step name kept historical to avoid churning the wizard
    # state machine; it gates on the appliance role now.)
    if [ "$ROLE" != "appliance" ]; then
        return 0
    fi
    log "Step: ask_application_config"

    if [ -n "${PRESEED_HAS_CONTROL_URL:-}" ]; then
        log "Preseed: control_plane_url=$CONTROL_PLANE_URL (skipping prompt)"
    else
        local default_url="${CONTROL_PLANE_URL:-https://}"
        while true; do
            CONTROL_PLANE_URL=$(whiptail --backtitle "$BACKTITLE" \
                --title "Control plane URL" \
                --cancel-button "Back" \
                --inputbox "Where does this Application appliance register?\n\nFormat: https://<control-plane-host>/  — the URL of the SpatiumDDI control plane this supervisor pairs against. The supervisor submits its Ed25519 pubkey here, sits in pending until an admin clicks Approve, then receives a control-plane-CA-signed identity cert.\n\nHA TIP: if the control plane is a multi-node cluster, point this at the MetalLB virtual IP (VIP), NOT a single node's IP — otherwise this appliance loses its control plane whenever that one node is down. Configure the VIP under Appliance -> Network & Host on the control plane.\n\nUse https:// in production; http:// is acceptable for lab installs." \
                21 78 "$default_url" 3>&1 1>&2 2>&3) \
                || return 1
            if [ -z "$CONTROL_PLANE_URL" ] || [ "$CONTROL_PLANE_URL" = "https://" ]; then
                whiptail --msgbox "Control-plane URL is required for an Application install." 8 60 || true
                continue
            fi
            break
        done
    fi

    # Pairing code only — Application appliances never paste a long
    # bootstrap key. The supervisor generates its own Ed25519 keypair
    # on first boot and submits the pubkey against the code; the
    # control plane stores it and waits for admin approval. The 8-digit
    # code is the only thing the operator types over an IPMI / serial
    # console.
    if [ -n "${PRESEED_HAS_PAIRING_CODE:-}" ]; then
        log "Preseed: pairing code supplied (skipping prompt)"
        return 0
    fi
    local code_val
    while true; do
        code_val=$(whiptail --backtitle "$BACKTITLE" --title "Pairing code" \
            --cancel-button "Back" \
            --inputbox "Enter the 8-digit pairing code from the control plane.\n\nMint one at https://<control-plane>/appliance → Pairing → 'New pairing code'. Single-use ephemeral codes expire after 15 min by default; persistent codes (multi-claim) stay valid until disabled or revoked.\n\nAfter the supervisor claims the code, the appliance sits in pending — ask the control plane admin to click Approve in the fleet UI to issue the identity cert and assign a role." \
            18 78 "$BOOTSTRAP_PAIRING_CODE" 3>&1 1>&2 2>&3) \
            || return 1
        # The frontend displays codes as ``1234-5678`` for
        # readability; an operator typing in dashes or spaces from
        # what they see on screen should validate cleanly. Strip
        # every non-digit before checking the length.
        code_val=$(echo "$code_val" | tr -cd '0-9')
        if [ -z "$code_val" ]; then
            whiptail --msgbox "Pairing code is required for an Application install." 8 60 || true
            continue
        fi
        # Validate: exactly 8 decimal digits after stripping. Catch
        # typos before firstboot tries to redeem the code and fails
        # with a generic 403 (which we'd then surface on the console).
        if ! [[ "$code_val" =~ ^[0-9]{8}$ ]]; then
            whiptail --msgbox "Pairing code must be 8 decimal digits (dashes / spaces accepted as separators).\n\nGot after strip: $code_val" 10 60 || true
            continue
        fi
        break
    done
    BOOTSTRAP_PAIRING_CODE="$code_val"
    log "Application paired against $CONTROL_PLANE_URL with an 8-digit pairing code"
}

pick_disk() {
    log "Step: pick_disk"
    if [ -n "${PRESEED_HAS_DISK:-}" ]; then
        log "Preseed: target_disk=$TARGET_DISK (confirm_wipe authorised; skipping picker)"
        return 0
    fi
    local options=()
    # #554 — exclude EVERY disk backing the live boot medium, not just the
    # one findmnt resolves. The old code checked only ``findmnt -no SOURCE
    # /run/live/medium``; with ``boot=live toram`` (or a layout that
    # unmounts the medium) that returns empty, so the boot USB — an ``sd*``
    # device the ``grep -vE "^(sr|loop|fd|ram|zram)"`` filter does NOT
    # exclude — appeared as a wipe target and picking it destroyed the
    # running install media mid-install. Scan /proc/mounts for every
    # /run/live // /lib/live mount and map each source back to its parent
    # disk, keeping the findmnt-derived one too as belt-and-braces.
    local -A live_disks=()
    local _src _mnt _rest _pk
    while read -r _src _mnt _rest; do
        case "$_mnt" in
            /run/live|/run/live/*|/lib/live/mount|/lib/live/mount/*)
                case "$_src" in
                    /dev/*)
                        _pk=$(lsblk -no PKNAME "$_src" 2>/dev/null | head -n1)
                        [ -z "$_pk" ] && _pk=$(basename "$_src")
                        [ -n "$_pk" ] && live_disks["/dev/$_pk"]=1
                        ;;
                esac
                ;;
        esac
    done < /proc/mounts
    local live_src
    live_src=$(findmnt -no SOURCE /run/live/medium 2>/dev/null || \
               findmnt -no SOURCE /lib/live/mount/medium 2>/dev/null || true)
    if [ -n "$live_src" ]; then
        local live_disk
        live_disk=$(lsblk -no PKNAME "$live_src" 2>/dev/null | head -n1 || true)
        [ -n "$live_disk" ] && live_disks["/dev/$live_disk"]=1
    fi

    while IFS= read -r line; do
        local name size model
        name=$(echo "$line" | awk '{print $1}')
        size=$(echo "$line" | awk '{print $2}')
        model=$(echo "$line" | cut -d' ' -f3- | sed 's/  */ /g')
        [ -z "$model" ] && model="(no model)"
        # Skip any disk that backs the live boot medium.
        [ -n "${live_disks[/dev/$name]:-}" ] && continue
        options+=("/dev/$name" "$size - $model")
    done < <(lsblk -dn -o NAME,SIZE,MODEL -r 2>/dev/null | grep -vE "^(sr|loop|fd|ram|zram)")

    if [ ${#options[@]} -eq 0 ]; then
        log "No installable disks found (lsblk: $(lsblk -dn -o NAME,SIZE,TYPE 2>&1 | tr '\n' ';'))"
        whiptail --backtitle "$BACKTITLE" --title "No disks" \
            --msgbox "No installable disks found.\n\nAttach a target disk to the VM and reboot." 10 60 \
            || true
        on_cancel "disk picker (no disks present)"
    fi

    # Pick-and-validate loop. If the operator picks a disk that's too
    # small for the A/B layout, show the error immediately + send them
    # back to the menu — used to fire much later from inside
    # do_install AFTER the operator had already filled out hostname /
    # admin user / network / timezone, which was wasted typing.
    local MIN_BYTES=$((MIN_DISK_GIB * 1024 * 1024 * 1024))
    while true; do
        TARGET_DISK=$(whiptail --backtitle "$BACKTITLE" --title "Target Disk" \
            --cancel-button "Back" \
            --menu "Select the disk to install SpatiumDDI to.\nALL DATA on the chosen disk will be DESTROYED." \
            20 70 10 "${options[@]}" 3>&1 1>&2 2>&3) \
            || return 1
        local DISK_BYTES
        DISK_BYTES=$(blockdev --getsize64 "$TARGET_DISK" 2>/dev/null || echo 0)
        if [ "$DISK_BYTES" -ge "$MIN_BYTES" ]; then
            # Hard floor cleared. The Control plane role gets a second,
            # SOFT check against the recommended figures (#312) — it can
            # proceed under-spec but is warned about first-boot
            # DiskPressure. A declined warning re-prompts the disk menu.
            if _control_plane_sizing_ok "$DISK_BYTES"; then
                log "Picked target disk $TARGET_DISK ($((DISK_BYTES / 1024 / 1024 / 1024)) GiB)"
                break
            fi
            continue
        fi
        log "Operator picked $TARGET_DISK ($((DISK_BYTES / 1024 / 1024 / 1024)) GiB) — below ${MIN_DISK_GIB} GiB minimum; re-prompting"
        whiptail --backtitle "$BACKTITLE" --title "Disk too small" --msgbox \
            "Target disk $TARGET_DISK is only $((DISK_BYTES / 1024 / 1024 / 1024)) GiB.\n\nSpatiumDDI's A/B atomic-upgrade layout needs at least ${MIN_DISK_GIB} GiB:\n  ESP        512 MiB\n  STATE      256 MiB\n  root_A       8 GiB\n  root_B       8 GiB\n  var       remainder (≥14 GiB usable)\n\nThe slots carry the full container image set (issue #170 Wave A4) so the appliance works air-gapped without ghcr.io, and /var must hold the k3s image store + database + logs without tipping the kubelet DiskPressure threshold on the Control plane role (issue #312).\n\nPick a different disk, or Cancel out to attach a larger one." 21 76
    done
}

# #312 — soft sizing gate for the heavy Control plane role. The hard
# floor in pick_disk only guarantees the appliance installs + boots; the
# Control plane (k3s etcd + CloudNativePG + Redis + api/worker/beat/
# frontend, plus 2× HA replicas) wants REC_CP_DISK_GIB / REC_CP_RAM_GIB
# or its first boot risks a DiskPressure eviction storm — the image pull
# + Postgres/Redis PVCs land on a small /var and tip the kubelet nodefs
# threshold into an evict / image-GC thrash loop that never converges.
#
# Warns, does not block (the operator can knowingly proceed). Returns 0
# to proceed with the picked disk, 1 to send them back to the disk menu.
# No-op for the lightweight Appliance/agent role — 32 GiB is plenty
# there, so it never sees this.
_control_plane_sizing_ok() {
    local disk_bytes="$1"
    [ "$ROLE" = "control-plane" ] || return 0

    local disk_gib ram_kib ram_gib under_disk=0 under_ram=0
    disk_gib=$((disk_bytes / 1024 / 1024 / 1024))
    ram_kib=$(awk '/^MemTotal:/ {print $2; exit}' /proc/meminfo 2>/dev/null || echo 0)
    # Round RAM to the nearest GiB for display; MemTotal sits a little
    # under provisioned RAM (kernel reserve).
    ram_gib=$(((ram_kib + 524288) / 1024 / 1024))

    [ "$disk_gib" -lt "$REC_CP_DISK_GIB" ] && under_disk=1
    # Warn one GiB under the recommendation so a box provisioned at
    # exactly REC_CP_RAM_GIB (whose MemTotal reads slightly low) doesn't
    # false-warn. ram_kib==0 means /proc/meminfo was unreadable — skip
    # the RAM dimension rather than warn on bad data.
    if [ "$ram_kib" -gt 0 ] && [ "$ram_kib" -lt $(((REC_CP_RAM_GIB - 1) * 1024 * 1024)) ]; then
        under_ram=1
    fi
    if [ "$under_disk" -eq 0 ] && [ "$under_ram" -eq 0 ]; then
        return 0
    fi

    local msg
    msg="The Control plane is the heaviest role — k3s + PostgreSQL (CloudNativePG) + Redis + api / worker / beat / frontend, plus 2× HA replicas.\n\n"
    msg+="Recommended:  ≥ ${REC_CP_DISK_GIB} GiB disk,  ≥ ${REC_CP_RAM_GIB} GiB RAM\n"
    msg+="This machine:  ${disk_gib} GiB disk"
    [ "$ram_kib" -gt 0 ] && msg+=",  ~${ram_gib} GiB RAM"
    msg+="\n\nIt will INSTALL and boot, but at this size the first boot pulls the full control-plane image set onto /var while the Postgres + Redis volumes also land there — very likely tipping the kubelet's DiskPressure threshold into a pod-eviction / image-GC thrash loop that never converges.\n\n"
    msg+="See \"Recommended sizing\" in the README / docs/deployment/APPLIANCE.md.\n\n"
    msg+="Continue with this disk anyway?"

    # --defaultno so a careless Enter re-picks rather than committing to a
    # known-risky control-plane install.
    if whiptail --backtitle "$BACKTITLE" --title "Control plane: below recommended size" \
        --defaultno --yesno "$msg" 23 78; then
        log "Operator acknowledged under-spec control-plane sizing (disk=${disk_gib}G ram=${ram_gib}G); proceeding"
        return 0
    fi
    log "Operator declined under-spec control-plane sizing (disk=${disk_gib}G ram=${ram_gib}G); re-prompting disk"
    return 1
}

# Issue #276 — partition-layout confirmation. Shows the exact GPT
# layout that ``do_install`` will create on $TARGET_DISK and forces
# the operator to tick a confirmation checkbox before proceeding.
# Back (or an un-ticked box) returns to disk selection so a misclick
# costs nothing.
confirm_partition_layout() {
    log "Step: confirm_partition_layout"
    if [ -n "${PRESEED_HAS_DISK:-}" ]; then
        # confirm_wipe: true in the preseed IS the wipe authorisation —
        # don't re-prompt the layout checkbox on an unattended run.
        log "Preseed: partition-layout confirm skipped (confirm_wipe authorised $TARGET_DISK)"
        return 0
    fi
    local DISK_BYTES disk_gib var_gib
    DISK_BYTES=$(blockdev --getsize64 "$TARGET_DISK" 2>/dev/null || echo 0)
    disk_gib=$((DISK_BYTES / 1024 / 1024 / 1024))
    # var = total − (1 MiB BBP + 512 MiB ESP + 256 MiB STATE + 2× 8 GiB
    # slots). Round the fixed overhead up to ~17 GiB and subtract 1 for
    # GPT/rounding slack so the figure shown is a safe lower bound.
    var_gib=$(( disk_gib - 17 - 1 ))
    [ "$var_gib" -lt 1 ] && var_gib=1

    local layout
    layout="Layout to be created on $TARGET_DISK ($disk_gib GiB):\n\n"
    layout+="  p1  BIOS boot   1 MiB    legacy boot chain-load\n"
    layout+="  p2  ESP       512 MiB    /boot/efi (FAT32)\n"
    layout+="  p3  STATE     256 MiB    /var/lib/spatium-state\n"
    layout+="                           machine config + SSH host keys +\n"
    layout+="                           supervisor identity (survives OS\n"
    layout+="                           slot swaps + a /var factory reset)\n"
    layout+="  p4  root_A      8 GiB    active OS slot (this install)\n"
    layout+="  p5  root_B      8 GiB    standby OS slot (next upgrade)\n"
    layout+="  p6  var       ~$var_gib GiB    /var — database, k3s, logs\n\n"
    layout+="ALL EXISTING DATA on $TARGET_DISK will be ERASED.\n"
    layout+="There is no undo.\n\n"
    layout+="Tick the box and choose OK to proceed, or Back to pick\n"
    layout+="a different disk."

    while true; do
        local choice
        choice=$(whiptail --backtitle "$BACKTITLE" --title "Confirm Partition Layout" \
            --cancel-button "Back" \
            --checklist "$layout" 24 76 1 \
            "erase" "I understand all data on $TARGET_DISK will be erased" OFF \
            3>&1 1>&2 2>&3) \
            || return 1
        # whiptail returns the ticked tags quoted, e.g. "erase".
        case "$choice" in
            *erase*)
                log "Operator confirmed partition layout for $TARGET_DISK"
                return 0
                ;;
            *)
                whiptail --backtitle "$BACKTITLE" --title "Confirmation required" \
                    --msgbox "You must tick the confirmation box to continue.\n\nChoose Back on the next screen if you'd rather pick a different disk." 10 64 || true
                ;;
        esac
    done
}

ask_hostname() {
    log "Step: ask_hostname"
    if [ -n "${PRESEED_HAS_HOSTNAME:-}" ]; then
        log "Preseed: hostname=$HOSTNAME (skipping prompt)"
        return 0
    fi
    # No pre-filled default — multiple appliances on the same network
    # all named "spatiumddi" caused real-world server-name collisions
    # (the agent registers its SERVER_NAME with the control plane;
    # two agents on the same name conflict). Require operator input.
    while true; do
        HOSTNAME=$(whiptail --backtitle "$BACKTITLE" --title "Hostname" \
            --cancel-button "Back" \
            --inputbox "System hostname (also used as the SERVER_NAME this appliance registers under for DNS / DHCP agent roles, and shown in shell prompts + audit logs).\n\nGive each appliance a unique name (e.g. dns-east-1, dhcp-prod-a, ddi-control)." \
            14 72 "$HOSTNAME" 3>&1 1>&2 2>&3) \
            || return 1
        HOSTNAME=$(echo "$HOSTNAME" | tr -d '[:space:]')
        if [ -z "$HOSTNAME" ]; then
            whiptail --msgbox "Hostname is required. Pick something descriptive for this appliance — it shouldn't collide with any other SpatiumDDI box." 9 60 || true
            continue
        fi
        # Loose RFC 1123 sanity: lower-case alphanum + hyphen, no
        # leading / trailing hyphen, length <= 63. Reject anything
        # that systemd-hostnamed would later refuse silently.
        case "$HOSTNAME" in
            *[!a-zA-Z0-9-]*|-*|*-)
                whiptail --msgbox "Hostname must be alphanumeric + hyphen, not start or end with a hyphen, and contain no spaces or dots. Try again." 10 64 || true
                continue
                ;;
        esac
        if [ "${#HOSTNAME}" -gt 63 ]; then
            whiptail --msgbox "Hostname must be 63 characters or fewer." 8 60 || true
            continue
        fi
        break
    done
}

ask_user_password() {
    log "Step: ask_user_password"
    # Username prompt is skipped when the admin user is preseeded, OR
    # when a preseeded password makes this a headless run (in which case
    # the ADMIN_USER default of "admin" — or a preseeded value — stands).
    if [ -z "${PRESEED_HAS_ADMIN_USER:-}" ] && [ -z "${PRESEED_HAS_PASSWORD:-}" ]; then
        ADMIN_USER=$(whiptail --backtitle "$BACKTITLE" --title "Admin OS user" \
            --cancel-button "Back" \
            --inputbox "OS-level admin username (for SSH + sudo).\n\nThe SpatiumDDI web UI uses 'admin/admin' separately - change it on first login." \
            12 70 "$ADMIN_USER" 3>&1 1>&2 2>&3) \
            || return 1
        [ -z "$ADMIN_USER" ] && ADMIN_USER="admin"
    else
        log "Preseed: admin user=$ADMIN_USER (skipping username prompt)"
    fi

    if [ -n "${PRESEED_HAS_PASSWORD:-}" ]; then
        log "Preseed: admin password supplied (skipping prompt)"
        return 0
    fi

    while true; do
        local p1 p2
        p1=$(whiptail --backtitle "$BACKTITLE" --title "Admin password" \
            --cancel-button "Back" \
            --passwordbox "Password for '$ADMIN_USER' (and root):" 10 60 \
            3>&1 1>&2 2>&3) \
            || return 1
        p2=$(whiptail --backtitle "$BACKTITLE" --title "Confirm password" \
            --cancel-button "Back" \
            --passwordbox "Repeat:" 10 60 3>&1 1>&2 2>&3) \
            || return 1
        if [ "$p1" = "$p2" ] && [ -n "$p1" ]; then
            ADMIN_PASSWORD="$p1"
            break
        fi
        whiptail --backtitle "$BACKTITLE" \
            --msgbox "Passwords don't match or are empty. Try again." 8 50 \
            || true
    done
}

# #554 — validate the static-IP fields with Python's ``ipaddress`` (same
# approach as the k3s CIDR step). Without this, a blank gateway wrote
# ``address1=<ip>/<prefix>,`` (trailing comma) into the NetworkManager
# keyfile → NM rejects it → the connection never loads → headless
# appliance comes up with NO IP (console-only recovery). A typo'd
# prefix / IP / gateway failed the same silent way. Prints the problem(s)
# on stdout + exits 1 on any error.
_validate_static_net() {
    python3 - "$NET_IP" "$NET_PREFIX" "$NET_GATEWAY" "$NET_DNS" <<'PY' 2>&1
import ipaddress
import sys

ip_s, prefix_s, gw_s, dns_s = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
errs = []

prefix = None
try:
    prefix = int(prefix_s)
    # Allow /1../32. /32 is a valid single-host assignment (some cloud /
    # VPS hosts hand one out with an off-link gateway reached via an
    # on-link route); /31 is RFC 3021 point-to-point.
    if not 0 < prefix <= 32:
        errs.append(f"Prefix must be between 1 and 32 (got {prefix_s!r}).")
        prefix = None
except ValueError:
    errs.append(f"Prefix must be a whole number (got {prefix_s!r}).")

ip = None
try:
    ip = ipaddress.IPv4Address(ip_s.strip())
except ValueError:
    errs.append(f"IP address {ip_s!r} is not a valid IPv4 address.")

gw = None
if not gw_s.strip():
    errs.append("Gateway is required for a static install.")
else:
    try:
        gw = ipaddress.IPv4Address(gw_s.strip())
    except ValueError:
        errs.append(f"Gateway {gw_s!r} is not a valid IPv4 address.")

if ip is not None and gw is not None and prefix is not None and prefix < 32:
    # For /32 the network is the host itself, so an off-link gateway
    # (reached via an on-link route) is normal and expected — skip the
    # in-subnet check. For /1../31 the gateway must be on-link.
    net = ipaddress.ip_network(f"{ip_s.strip()}/{prefix}", strict=False)
    if gw not in net:
        errs.append(
            f"Gateway {gw_s.strip()} is not inside {net} — the appliance "
            "would not be able to reach it."
        )

for tok in dns_s.split():
    try:
        ipaddress.ip_address(tok)
    except ValueError:
        errs.append(f"DNS server {tok!r} is not a valid IP address.")

if errs:
    print("\n".join(errs))
    sys.exit(1)
PY
}

ask_network() {
    log "Step: ask_network"
    if [ -n "${PRESEED_HAS_NETWORK:-}" ]; then
        log "Preseed: network=$NET_MODE (skipping prompt)"
        # Validate a preseeded static config too — a bad answer file would
        # otherwise brick a fully-headless install with no way to recover.
        if [ "$NET_MODE" = "static" ]; then
            local perr
            if ! perr=$(_validate_static_net); then
                log "FATAL: preseed static network is invalid: $perr"
                whiptail --msgbox "Preseed static network settings are invalid:\n\n$perr\n\nFix the answer file and reinstall." 16 72 || true
                on_cancel
            fi
        fi
        return 0
    fi
    NET_MODE=$(whiptail --backtitle "$BACKTITLE" --title "Network" \
        --cancel-button "Back" \
        --menu "How should the appliance configure its network?" 12 70 2 \
        "dhcp"   "Automatic via DHCP (recommended for evaluation)" \
        "static" "Static IP" \
        3>&1 1>&2 2>&3) \
        || return 1

    if [ "$NET_MODE" = "static" ]; then
        local ifs=()
        for iface in $(ls /sys/class/net 2>/dev/null | grep -E "^(en|eth)"); do
            ifs+=("$iface" "$(cat /sys/class/net/$iface/address 2>/dev/null || echo "?")")
        done
        if [ ${#ifs[@]} -eq 0 ]; then
            whiptail --msgbox "No ethernet interfaces found - falling back to DHCP." 8 60 || true
            NET_MODE="dhcp"
            return 0
        fi
        NET_INTERFACE=$(whiptail --backtitle "$BACKTITLE" --title "Static IP -interface" \
            --cancel-button "Back" \
            --menu "Pick an interface:" 12 60 5 "${ifs[@]}" 3>&1 1>&2 2>&3) \
            || return 1
        # #554 — collect + validate in a loop: on a validation error re-show
        # the four fields (pre-filled with what was entered) instead of
        # writing an invalid keyfile. Back (Cancel) on any field still exits
        # the step backward via ``return 1``.
        while true; do
            NET_IP=$(whiptail --backtitle "$BACKTITLE" --title "Static IP -address" \
                --cancel-button "Back" \
                --inputbox "IPv4 address (e.g. 192.168.1.10):" 10 60 "$NET_IP" 3>&1 1>&2 2>&3) \
                || return 1
            NET_PREFIX=$(whiptail --backtitle "$BACKTITLE" --title "Static IP -prefix" \
                --cancel-button "Back" \
                --inputbox "Prefix length:" 10 60 "$NET_PREFIX" 3>&1 1>&2 2>&3) \
                || return 1
            NET_GATEWAY=$(whiptail --backtitle "$BACKTITLE" --title "Static IP -gateway" \
                --cancel-button "Back" \
                --inputbox "Gateway:" 10 60 "$NET_GATEWAY" 3>&1 1>&2 2>&3) \
                || return 1
            NET_DNS=$(whiptail --backtitle "$BACKTITLE" --title "Static IP -DNS" \
                --cancel-button "Back" \
                --inputbox "DNS servers (space-separated):" 10 60 "$NET_DNS" 3>&1 1>&2 2>&3) \
                || return 1
            local nerr
            if nerr=$(_validate_static_net); then
                break
            fi
            whiptail --backtitle "$BACKTITLE" --title "Static network — invalid" \
                --msgbox "Please correct these before continuing:\n\n$nerr" 16 72 || true
        done
    fi
}

ask_timezone() {
    log "Step: ask_timezone"
    if [ -n "${PRESEED_HAS_TIMEZONE:-}" ]; then
        log "Preseed: timezone=$TIMEZONE (skipping prompt)"
        return 0
    fi
    TIMEZONE=$(whiptail --backtitle "$BACKTITLE" --title "Timezone" \
        --cancel-button "Back" \
        --inputbox "Timezone (IANA name, e.g. America/Toronto, Europe/Berlin, UTC):" \
        10 70 "$TIMEZONE" 3>&1 1>&2 2>&3) \
        || return 1
    # ``[ -z "$TIMEZONE" ] && TIMEZONE="UTC"`` here would return 1 when
    # TIMEZONE is non-empty (the [ test fails, && short-circuits, the
    # function inherits the [ test's exit code), and the state machine
    # would then treat OK as Back — infinite-looping the operator back
    # into ask_network. Use an if/then so the function always exits 0
    # on success.
    if [ -z "$TIMEZONE" ]; then
        TIMEZONE="UTC"
    fi
}

# Issue #302 — operator-customisable k3s pod + service CIDRs.
#
# k3s defaults (10.42.0.0/16 pods, 10.43.0.0/16 services) collide
# with several common LAN ranges in the wild (Flannel docs example,
# some VPN/overlay setups, branch SD-WAN). Defaults pre-filled so
# clean-LAN operators just press Enter through this step; overrides
# kick in for operators whose LAN already uses one of these ranges.
#
# Validation runs server-side via Python's ``ipaddress`` because bash
# regex CIDR validation is awful and we want overlap detection
# (between pod / service / operator's static-IP subnet) for free.
ask_k3s_cidrs() {
    log "Step: ask_k3s_cidrs"
    if [ -n "${PRESEED_HAS_K3S:-}" ]; then
        if [ -n "${PRESEED_HAS_NETWORK:-}" ]; then
            log "Preseed: k3s pod=$K3S_POD_CIDR svc=$K3S_SERVICE_CIDR (skipping prompt)"
            return 0
        fi
        # k3s was preseeded but the network was chosen interactively, so
        # the parser could not check the pod/service CIDRs against the
        # operator's static LAN subnet. Re-run the same validator now
        # that NET_* is known; if it passes we skip the prompt, if it
        # flags an overlap the operator gets the interactive prompt to
        # fix it (this only happens on a partial, already-interactive
        # run — never a fully-unattended one).
        if _validate_k3s_cidrs "$K3S_POD_CIDR" "$K3S_SERVICE_CIDR"; then
            log "Preseed: k3s CIDRs validated against interactive network (skipping prompt)"
            return 0
        fi
        log "Preseed: k3s CIDRs conflict with the interactively-chosen network — prompting"
    fi
    while true; do
        local pod
        pod=$(whiptail --backtitle "$BACKTITLE" --title "k3s pod network" \
            --cancel-button "Back" \
            --inputbox "Pod CIDR — internal range Flannel uses for per-pod IPs. Default works for most LANs; change only if your network already uses 10.42.x.x.\n\nIPv4 CIDR (e.g. 10.42.0.0/16):" \
            14 70 "$K3S_POD_CIDR" 3>&1 1>&2 2>&3) \
            || return 1
        local svc
        svc=$(whiptail --backtitle "$BACKTITLE" --title "k3s service network" \
            --cancel-button "Back" \
            --inputbox "Service CIDR — internal range k8s uses for service ClusterIPs (incl. cluster DNS). Must not overlap with the pod CIDR or your LAN.\n\nIPv4 CIDR (e.g. 10.43.0.0/16):" \
            14 70 "$K3S_SERVICE_CIDR" 3>&1 1>&2 2>&3) \
            || return 1
        if _validate_k3s_cidrs "$pod" "$svc"; then
            K3S_POD_CIDR="$pod"
            K3S_SERVICE_CIDR="$svc"
            return 0
        fi
        # _validate_k3s_cidrs already showed the operator a msgbox
        # with the reason — loop back to the pod CIDR prompt with the
        # operator's just-typed values pre-filled so they don't lose
        # them. Set the running defaults to what they typed so the
        # next prompt-iteration's inputbox shows those values.
        K3S_POD_CIDR="$pod"
        K3S_SERVICE_CIDR="$svc"
    done
}

# Pure validation core for a pod/service CIDR pair — prints the problem
# on stdout (empty output = valid), reading NET_MODE/NET_IP/NET_PREFIX to
# cross-check the operator's static LAN subnet. Split out of
# _validate_k3s_cidrs (issue #581) so the headless `--check-preseed`
# linter can reuse the EXACT rule the interactive wizard enforces,
# without the whiptail dialog.
_k3s_cidr_error() {
    local pod="$1" svc="$2"
    # Hand off to Python — ``ipaddress`` does parsing, prefix-len
    # checking, and overlap detection in three idiomatic lines. The
    # bash regex alternative would be 30 lines + still wrong on edge
    # cases. We pass the operator's static-IP subnet (if static
    # mode) so we can refuse pod/svc CIDRs that would mask the LAN.
    local static_subnet=""
    if [ "$NET_MODE" = "static" ] && [ -n "$NET_IP" ] && [ -n "$NET_PREFIX" ]; then
        static_subnet="$NET_IP/$NET_PREFIX"
    fi
    python3 - "$pod" "$svc" "$static_subnet" <<'PY' 2>&1
import ipaddress
import sys
pod_s, svc_s, static_s = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    pod = ipaddress.ip_network(pod_s, strict=False)
except ValueError as exc:
    print(f"Pod CIDR is not a valid IPv4 network: {exc}")
    sys.exit(1)
try:
    svc = ipaddress.ip_network(svc_s, strict=False)
except ValueError as exc:
    print(f"Service CIDR is not a valid IPv4 network: {exc}")
    sys.exit(1)
if pod.version != 4 or svc.version != 4:
    print("Only IPv4 CIDRs are supported.")
    sys.exit(1)
# /22 is the upper bound — k3s allocates /24 per node out of the pod
# CIDR (max ~64 nodes from /22) and /16 service CIDRs are k3s
# convention. Tighter than /22 silently breaks at scale + once-
# allocated CIDRs can't be expanded without a reinstall.
if pod.prefixlen > 22:
    print(f"Pod CIDR prefix {pod.prefixlen} is too small. Use /22 or wider (e.g. /16).")
    sys.exit(1)
if svc.prefixlen > 22:
    print(f"Service CIDR prefix {svc.prefixlen} is too small. Use /22 or wider (e.g. /16).")
    sys.exit(1)
if pod.overlaps(svc):
    print(f"Pod CIDR {pod} overlaps with service CIDR {svc}. They must be disjoint.")
    sys.exit(1)
if static_s:
    try:
        lan = ipaddress.ip_interface(static_s).network
    except ValueError:
        # Bad static-IP shape elsewhere in the wizard — let that
        # surface there, not here.
        sys.exit(0)
    if pod.overlaps(lan):
        print(
            f"Pod CIDR {pod} overlaps with the LAN subnet {lan} you "
            f"just configured. Flannel's host-gw backend would mask "
            f"the LAN. Pick a non-overlapping range."
        )
        sys.exit(1)
    if svc.overlaps(lan):
        print(
            f"Service CIDR {svc} overlaps with the LAN subnet {lan}. "
            f"Pick a non-overlapping range."
        )
        sys.exit(1)
PY
}

# Helper: validate the two CIDRs typed by ask_k3s_cidrs. Returns 0 on
# success; on fail, shows a whiptail msgbox describing the problem +
# returns 1 so the caller re-prompts. The check itself lives in
# _k3s_cidr_error (issue #581) so the `--check-preseed` linter can reuse
# it without popping a dialog.
_validate_k3s_cidrs() {
    local err
    err=$(_k3s_cidr_error "$1" "$2")
    if [ -z "$err" ]; then
        return 0
    fi
    whiptail --backtitle "$BACKTITLE" --title "k3s networking — invalid" \
        --msgbox "$err\n\nPress OK to fix." 14 72 || true
    return 1
}

# Helper: compute the cluster-dns IP from the chosen service CIDR.
# k3s + kube-dns convention is ``<service_cidr_base>.10`` (e.g. the
# 10.43.0.0/16 default gives 10.43.0.10). Outputs the address only;
# called by do_install when writing the k3s config drop-in.
_cluster_dns_ip_from_svc_cidr() {
    python3 - "$1" <<'PY'
import ipaddress
import sys
net = ipaddress.ip_network(sys.argv[1], strict=False)
print(str(net.network_address + 10))
PY
}

confirm() {
    log "Step: confirm"
    local role_label
    case "$ROLE" in
        control-plane) role_label="Control plane — api + db + DNS + DHCP (first node)" ;;
        appliance)     role_label="Appliance — DNS / DHCP agent (pairs with a control plane)" ;;
        *)             role_label="$ROLE" ;;
    esac
    local s
    s="Role:        $role_label\n"
    if [ "$ROLE" = "appliance" ]; then
        s+="Control URL: $CONTROL_PLANE_URL\n"
        # Mask the code in the confirmation screen — the IPMI / serial
        # console operator already typed it; no need to flash all 8
        # digits back at them. ●●●●●●●● is enough confirmation that
        # something landed.
        s+="Pair code:   ●●●●●●●●\n"
    fi
    s+="Target disk: $TARGET_DISK\n"
    s+="Hostname:    $HOSTNAME\n"
    s+="OS user:     $ADMIN_USER\n"
    s+="Network:     $NET_MODE"
    if [ "$NET_MODE" = "static" ]; then
        s+=" ($NET_INTERFACE: $NET_IP/$NET_PREFIX via $NET_GATEWAY)"
    fi
    s+="\nTimezone:    $TIMEZONE\n"
    # Only show the k3s CIDR row when the operator overrode either
    # default — keeps the confirm screen short for the common case.
    if [ "$K3S_POD_CIDR" != "10.42.0.0/16" ] || [ "$K3S_SERVICE_CIDR" != "10.43.0.0/16" ]; then
        s+="K3s pod CIDR: $K3S_POD_CIDR\n"
        s+="K3s svc CIDR: $K3S_SERVICE_CIDR\n"
    fi
    s+="\nWARNING: $TARGET_DISK will be ERASED. There is no undo.\n\n"
    s+="Proceed with installation?"
    whiptail --backtitle "$BACKTITLE" --title "Confirm" \
        --no-button "Back" \
        --yesno "$s" 20 72 \
        || return 1
}

# ── Install ───────────────────────────────────────────────────────────────────

partition_node() {
    # Translate $TARGET_DISK + index → /dev/sdaN or /dev/nvme0n1pN
    local idx="$1"
    case "$TARGET_DISK" in
        *nvme*|*mmcblk*) echo "${TARGET_DISK}p${idx}" ;;
        *)               echo "${TARGET_DISK}${idx}"  ;;
    esac
}

do_install() {
    # Now we're past all the prompts — enable -e so any failure
    # inside the partitioning / rsync / chroot block aborts cleanly
    # and the EXIT trap drops the operator to a shell with the log.
    set -e

    # GPT layout — Atomic A/B image upgrade (issue #138 Phase 8a-1) +
    # Talos-style STATE partition (issue #276):
    #
    #   p1  BIOS Boot     1 MiB     ef02   legacy chain-load (grub i386-pc)
    #   p2  ESP          512 MiB    ef00   FAT32, /boot/efi
    #   p3  state        256 MiB    8300   /var/lib/spatium-state — machine
    #                                      config, SSH host keys, supervisor
    #                                      identity. Survives slot swaps AND
    #                                      a /var factory reset; replaces
    #                                      the per-slot /etc.image drift
    #                                      that #272 Phase 1 bandaided.
    #   p4  root_A         8 GiB    8304   active slot (this install lands here)
    #   p5  root_B         8 GiB    8304   inactive slot (staging next image)
    #   p6  var          rest       8310   /var, persisted across slot swaps
    #
    # Slot sizing — #170 Phase A4 bakes every container image into the
    # rootfs (~800 MB-1.2 GB compressed depending on third-party
    # versions); base Debian + Python + system packages is ~1.8 GiB.
    # 8 GiB per slot gives ~2.7× headroom over the current ~3 GiB
    # working set and accommodates Wave B+ growth (CA tooling, the
    # supervisor's expanded toolset, future kernel upgrades).
    # Previous 4 GiB slots predated baking and are too tight once
    # the full container set lives on-rootfs.
    #
    # Hard floor: MIN_DISK_GIB (32) target disk (= 1 MiB BBP + 512 MiB
    # ESP + 256 MiB STATE + 2× 8 GiB slots + ~14 GiB usable /var). Below
    # that, postgres + k3s state (containerd content store, local-path
    # PV dirs) + audit log outgrow /var quickly — on the Control plane
    # role a 24 GiB disk's ~7 GiB /var tipped the kubelet DiskPressure
    # threshold into an eviction storm on first boot (issue #312).
    local BBP ESP STATE ROOT_A ROOT_B VAR
    BBP=$(partition_node 1)
    ESP=$(partition_node 2)
    STATE=$(partition_node 3)
    ROOT_A=$(partition_node 4)
    ROOT_B=$(partition_node 5)
    VAR=$(partition_node 6)

    # Disk-size validation lives in ``pick_disk`` now (fires right
    # after the operator picks rather than at the end of the wizard
    # after they've typed hostname / admin / network / timezone).

    log "Install starting: target=$TARGET_DISK BBP=$BBP ESP=$ESP STATE=$STATE ROOT_A=$ROOT_A ROOT_B=$ROOT_B VAR=$VAR"

    {
        echo "XXX"; echo "3"; echo "Releasing existing partitions on $TARGET_DISK..."; echo "XXX"
        # Pre-existing install on the target disk leaves partitions
        # that the live system's systemd-gpt-auto-generator may have
        # auto-mounted (ESP → /boot/efi, root → /sysroot) or that
        # the kernel still holds open via stale device-mapper or
        # swap entries. sgdisk -Z, mkfs.fat, and the subsequent
        # mount all fail on a busy device, so unconditionally
        # release everything before partitioning.
        for part in $(lsblk -nr -o NAME "$TARGET_DISK" 2>/dev/null | tail -n +2); do
            swapoff "/dev/$part" >> "$INSTALL_LOG" 2>&1 || true
            umount "/dev/$part"  >> "$INSTALL_LOG" 2>&1 || true
            umount -l "/dev/$part" >> "$INSTALL_LOG" 2>&1 || true
        done
        # device-mapper entries (LVM / dm-crypt) backed by this disk
        if command -v dmsetup >/dev/null 2>&1; then
            for dm in $(dmsetup ls --target linear 2>/dev/null | awk '{print $1}'); do
                dmsetup remove "$dm" >> "$INSTALL_LOG" 2>&1 || true
            done
        fi

        echo "XXX"; echo "5"; echo "Partitioning $TARGET_DISK (A/B + var layout)..."; echo "XXX"
        wipefs -af "$TARGET_DISK"           >> "$INSTALL_LOG" 2>&1
        sgdisk -Z "$TARGET_DISK"            >> "$INSTALL_LOG" 2>&1
        # Force the kernel to forget the old partition table before
        # we lay down a new one. Without this, mkfs against the new
        # partition nodes can race with udev rebuilding /dev/disk/.
        blockdev --rereadpt "$TARGET_DISK"  >> "$INSTALL_LOG" 2>&1 || true
        # GPT type codes — sgdisk shortcuts:
        #   ef02 = BIOS Boot         (i386-pc grub core.img target)
        #   ef00 = EFI System        (FAT32 /boot/efi)
        #   8304 = Linux root (x86-64) — systemd-gpt-auto-generator
        #          can find /usr-aware slots by partition type, used
        #          by 8b's sysupdate slot picker
        #   8300 = generic Linux fs  (var; we mount via /etc/fstab)
        # Partition type codes:
        #   ef02 = BIOS Boot                  (grub i386-pc core.img target)
        #   ef00 = EFI System                 (FAT32 /boot/efi)
        #   8304 = Linux root x86-64          (systemd-gpt-auto-generator
        #                                      hint for root slot — used
        #                                      by 8b's slot-write logic)
        #   8310 = Linux /var (4d21b016-...)  (sysd-gpt-auto-generator
        #                                      auto-mounts /var without
        #                                      needing an /etc/fstab
        #                                      entry — critical because
        #                                      the operator-overlay's
        #                                      fstab is INSIDE the
        #                                      overlay we're trying to
        #                                      mount; chicken+egg
        #                                      otherwise. Sets the var
        #                                      partition discoverable.)
        sgdisk -n1:0:+1M    -t1:ef02 -c1:bios_boot \
               -n2:0:+512M  -t2:ef00 -c2:ESP \
               -n3:0:+256M  -t3:8300 -c3:state \
               -n4:0:+8G    -t4:8304 -c4:root_A \
               -n5:0:+8G    -t5:8304 -c5:root_B \
               -n6:0:0      -t6:8310 -c6:var \
               "$TARGET_DISK"               >> "$INSTALL_LOG" 2>&1
        partprobe "$TARGET_DISK"            >> "$INSTALL_LOG" 2>&1 || true
        udevadm settle                      >> "$INSTALL_LOG" 2>&1 || true
        sleep 1

        echo "XXX"; echo "10"; echo "Formatting partitions..."; echo "XXX"
        mkfs.fat -F32 -n ESP "$ESP"         >> "$INSTALL_LOG" 2>&1
        # STATE partition — issue #276. Small ext4 holding machine
        # config + SSH host keys + supervisor identity. Mounted at
        # /var/lib/spatium-state. Label ``state`` so fstab can
        # ``LABEL=state`` it without chasing UUIDs across re-installs.
        mkfs.ext4 -F -L state "$STATE"      >> "$INSTALL_LOG" 2>&1
        # Label the slots distinctly so the boot loader / sysupdate
        # can pick them by label rather than position. root_a is the
        # active slot for this install; root_b is empty until 8b's
        # `spatium-update` writes the next image there.
        mkfs.ext4 -F -L root_a "$ROOT_A"    >> "$INSTALL_LOG" 2>&1
        mkfs.ext4 -F -L root_b "$ROOT_B"    >> "$INSTALL_LOG" 2>&1
        mkfs.ext4 -F -L var    "$VAR"       >> "$INSTALL_LOG" 2>&1

        echo "XXX"; echo "15"; echo "Mounting target..."; echo "XXX"
        # Mount layout for rsync: root_A as / and var as /var BEFORE
        # rsync runs, so files going to /var land on the var partition
        # automatically (rsync follows the mount tree).
        mkdir -p "$MOUNT"
        mount "$ROOT_A" "$MOUNT"
        mkdir -p "$MOUNT/var"
        mount "$VAR" "$MOUNT/var"
        mkdir -p "$MOUNT/boot/efi"
        mount "$ESP" "$MOUNT/boot/efi"
        # Issue #276 — mount the STATE partition under the eventual
        # runtime path so the install-time render seeds it directly.
        # The unmount step at the end of do_install drops it before
        # /var (LIFO ordering); on next boot fstab re-mounts it via
        # LABEL=state.
        mkdir -p "$MOUNT/var/lib/spatium-state"
        mount "$STATE" "$MOUNT/var/lib/spatium-state"

        echo "XXX"; echo "20"; echo "Copying root filesystem (3-5 min)..."; echo "XXX"
        rsync -aAXH \
            --exclude="/dev/*" \
            --exclude="/proc/*" \
            --exclude="/sys/*" \
            --exclude="/tmp/*" \
            --exclude="/run/*" \
            --exclude="/mnt/*" \
            --exclude="/media/*" \
            --exclude="/lib/live" \
            --exclude="/var/log/*" \
            --exclude="/var/cache/apt/archives/*" \
            --exclude="/var/lib/spatiumddi/firstboot.done" \
            --exclude="/var/lib/spatiumddi/swapfile" \
            --exclude="/etc/spatiumddi/.env" \
            --exclude="/etc/ssh/sshd_config.d/00-spatium-live.conf" \
            --exclude="/etc/issue.d/zz-spatium-live.issue" \
            / "$MOUNT/" >> "$INSTALL_LOG" 2>&1

        echo "XXX"; echo "60"; echo "Writing boot-critical config to root baseline..."; echo "XXX"
        # IMPORTANT: fstab + /etc/hostname need to land on the
        # UNDERLYING root_A partition (not in the overlay upper), since
        # systemd reads them at boot BEFORE etc.mount can fire. If they
        # were in the overlay only, systemd would never see them, /var
        # wouldn't mount, and the overlay would never mount either —
        # which was the build030 install bug.
        #
        # Belt + braces: /var has GPT type Linux /var
        # (4d21b016-b534-45c2-a9fb-5c16e091fd2d, sgdisk code 8310, set
        # earlier in the partitioning step) so systemd-gpt-auto-
        # generator auto-mounts it even without an fstab entry. On a
        # Phase 8b slot swap to image v2, root_B will ship its own
        # vanilla fstab that lacks our /var UUID — gpt-auto picks up
        # the slack.
        #
        # /home + /root bind mounts deliberately NOT in fstab. They
        # ship as systemd .mount unit files
        # (/etc/systemd/system/home.mount + root.mount) baked into the
        # image baseline, so EVERY image slot's /etc has them. fstab
        # entries would get reset to vanilla on slot swap → operator
        # data masked because /home wouldn't bind-mount; the .mount
        # files are immune to that failure mode.
        # Phase 8a-7 — fstab is IMAGE-BASELINE (no operator-specific
        # UUIDs). Every slot's image-shipped /etc/fstab carries the
        # same content, so a slot swap to image v2 doesn't need any
        # fstab rewrite — root_B's image-baseline fstab is identical.
        #
        # Each mountpoint uses a slot-stable identifier:
        #
        # / (root)         — NOT in fstab. Mounted by kernel via
        #                    root=UUID=… on the cmdline (set per-slot
        #                    in grub.cfg menuentries via grub-install).
        #
        # /var             — LABEL=var. Belt-and-braces with
        #                    systemd-gpt-auto-generator (GPT type
        #                    8310 / 4d21b016-…). gpt-auto's machine-id
        #                    matching can be finicky on first boot;
        #                    LABEL=var in fstab is a reliable fallback.
        #
        # /boot/efi        — LABEL=ESP (set by `mkfs.fat -n ESP`).
        #                    fmask=0133 / dmask=0022 makes files 0644
        #                    and dirs 0755 so the api container (uid
        #                    1000) can read grubenv through the read-
        #                    only /boot/efi:/boot/efi-host bind mount
        #                    that drives the SlotUpgradeCard. No
        #                    secrets live on the ESP — just grub.cfg
        #                    + grubenv + boot loader binaries —
        #                    relaxing perms here is fine.
        #
        # /tmp             — tmpfs, image-baseline.
        #
        # /home + /root    — systemd .mount unit files (image-shipped
        #                    at /etc/systemd/system/home.mount +
        #                    root.mount). Not in fstab.
        # /var/lib/spatium-state — LABEL=state (issue #276). Holds
        # machine config + SSH host keys + supervisor identity.
        # ``nofail`` so a missing/corrupt STATE partition degrades
        # to a normal boot instead of dropping to emergency.target
        # (the render service tolerates an absent STATE and falls
        # back to image-baseline values). Mounted under /var so it
        # orders after the /var mount — the render service's
        # After=local-fs.target dependency covers ordering.
        cat > "$MOUNT/etc/fstab" <<'EOF'
LABEL=var    /var                    ext4   defaults                              0 2
LABEL=state  /var/lib/spatium-state  ext4   defaults,nofail                       0 2
LABEL=ESP    /boot/efi               vfat   fmask=0133,dmask=0022,shortname=winnt 0 2
tmpfs        /tmp                     tmpfs  nosuid,nodev,noexec,mode=1777         0 0
EOF
        echo "$HOSTNAME" > "$MOUNT/etc/hostname"

        echo "XXX"; echo "62"; echo "Snapshotting /etc baseline + mounting overlay (Phase 8a)..."; echo "XXX"
        # Phase 8a-2 — Atomic A/B image upgrade (#138).
        # /usr/lib/etc.image is the slot's "image-shipped /etc"
        # baseline. We snapshot AFTER fstab + hostname write so the
        # snapshot has working boot config (root_B will get its own
        # snapshot from image v2 — sysupdate updates the lower layer).
        # Operator-mutable config (passwd, shadow, network, certs) goes
        # through the overlay later in this install + persists via the
        # /var/persist/etc upper layer across slot swaps.
        #
        # Use cp -a to preserve perms / xattrs / symlinks. /etc is
        # only ~10 MiB so the copy is fast (<2 s on any disk worth
        # running an appliance on).
        mkdir -p "$MOUNT/usr/lib/etc.image"
        cp -a "$MOUNT/etc/." "$MOUNT/usr/lib/etc.image/" >> "$INSTALL_LOG" 2>&1

        # Phase 8a-3 — overlay layout on /var:
        #   /var/persist/etc       upperdir  (operator writes land here)
        #   /var/persist/etc-work  workdir   (overlay scratch space)
        mkdir -p "$MOUNT/var/persist/etc" "$MOUNT/var/persist/etc-work"

        # Issue #276 — SSH host keys + machine config are seeded into
        # the STATE partition, which spatium-etc-render copies into
        # /etc on every boot BEFORE sshd / k3s start. STATE survives
        # both an OS slot swap AND a /var factory reset, so the host
        # key + hostname stay stable forever. Strip the keys out of
        # /etc.image (the overlay LOWER) so a future slot image's
        # mkosi-built keys can never shadow the operator's. (Supersedes
        # the #272 Phase 1 bandaid that parked keys in
        # /var/persist/etc/ssh — STATE is the authoritative home now.)
        STATE_MNT="$MOUNT/var/lib/spatium-state"
        mkdir -p "$STATE_MNT/ssh"
        for k in "$MOUNT/usr/lib/etc.image/ssh/"ssh_host_*_key \
                 "$MOUNT/usr/lib/etc.image/ssh/"ssh_host_*_key.pub; do
            [ -f "$k" ] || continue
            cp -a "$k" "$STATE_MNT/ssh/" >> "$INSTALL_LOG" 2>&1
            rm -f "$k"
        done

        # spatium-config.yaml — the operator-authoritative machine
        # config the render service reads. Flat ``key: value`` shape
        # (see spatium-etc-render's get_cfg parser). Network config is
        # a follow-up; v1 carries hostname + role + control-plane
        # pairing fields.
        cat > "$STATE_MNT/spatium-config.yaml" <<EOF
# SpatiumDDI appliance machine config (issue #276).
# Authoritative source for hostname / role / pairing / network —
# rendered into /etc by spatium-etc-render on every boot. Survives
# OS slot swaps + a /var factory reset.
hostname: "$HOSTNAME"
role: "$ROLE"
control_plane_url: "$CONTROL_PLANE_URL"
bootstrap_pairing_code: "$BOOTSTRAP_PAIRING_CODE"
# Network — flat keys (no nested map) so the render service's sed
# parser stays dependency-free. mode=dhcp leaves NetworkManager on
# its auto-DHCP default; mode=static makes the render service write
# a keyfile connection profile.
network_mode: "$NET_MODE"
network_interface: "$NET_INTERFACE"
network_ip: "$NET_IP"
network_prefix: "$NET_PREFIX"
network_gateway: "$NET_GATEWAY"
network_dns: "$NET_DNS"
EOF
        chmod 0644 "$STATE_MNT/spatium-config.yaml"

        # Mount overlay over /target/etc for the REMAINDER of the
        # install. Every chroot useradd / chpasswd / file write that
        # would normally land in /etc instead lands in the upper layer
        # on /var/persist/etc — which persists across slot swaps. The
        # subsequent unmount step has to release this BEFORE /var.
        mount -t overlay overlay \
            -o "lowerdir=$MOUNT/usr/lib/etc.image,upperdir=$MOUNT/var/persist/etc,workdir=$MOUNT/var/persist/etc-work" \
            "$MOUNT/etc" >> "$INSTALL_LOG" 2>&1

        # Phase 8a — /home + /root on /var so operator home dirs
        # survive slot swaps. The bind mounts are wired via shipped
        # systemd unit files (home.mount + root.mount, baked into the
        # image) rather than fstab — fstab gets reset to image vanilla
        # on slot swap, but every image slot ships the same .mount unit
        # files, so binds are immune to that reset path.
        #
        # useradd inside the upcoming chroot writes to /home/admin →
        # transparent via the install-time bind mount → /var/home/admin
        # on disk → ready for the .mount unit to re-bind at every boot.
        mkdir -p "$MOUNT/var/home" "$MOUNT/home"
        mkdir -p "$MOUNT/var/root"
        # /root already exists in the image rootfs with the live-system
        # contents — move them to /var/root so they live on the
        # persistent side, then re-create an empty /root mountpoint.
        if [ -d "$MOUNT/root" ] && [ -z "$(ls -A "$MOUNT/var/root" 2>/dev/null)" ]; then
            cp -a "$MOUNT/root/." "$MOUNT/var/root/" >> "$INSTALL_LOG" 2>&1 || true
            rm -rf "$MOUNT/root"
        fi
        mkdir -p "$MOUNT/root"
        mount --bind "$MOUNT/var/home" "$MOUNT/home" >> "$INSTALL_LOG" 2>&1
        mount --bind "$MOUNT/var/root" "$MOUNT/root" >> "$INSTALL_LOG" 2>&1

        # Write operator's hostname through the overlay too — lands in
        # /var/persist/etc/hostname on disk → persists across slot
        # swaps verbatim. The underlying root_A /etc/hostname (written
        # earlier) covers the brief window before the overlay mounts
        # on first boot; the overlay upper covers everything else.
        echo "$HOSTNAME" > "$MOUNT/etc/hostname"

        echo "XXX"; echo "65"; echo "Writing system config..."; echo "XXX"
        # fstab + /etc/hostname were already written to the underlying
        # root_A /etc earlier (before the overlay was mounted) so boot
        # can find them. The overlay's lower layer (/usr/lib/etc.image)
        # captured those writes in the snapshot — so they appear in the
        # merged view even though we don't re-write them through the
        # overlay here.
        #
        # role-config + /etc/hosts go through the overlay → upper. The
        # role-config IS operator state (carries the agent key + control
        # plane URL the wizard captured); /etc/hosts carries the
        # operator's hostname. Both must persist across slot swaps.
        mkdir -p "$MOUNT/etc/spatiumddi"
        cat > "$MOUNT/etc/spatiumddi/role-config" <<EOF
ROLE=$ROLE
CONTROL_PLANE_URL=$CONTROL_PLANE_URL
BOOTSTRAP_PAIRING_CODE=$BOOTSTRAP_PAIRING_CODE
EOF
        # Mode 0644 — readable by the host's non-root user (`app`,
        # uid 1000) so the api pod can introspect ``ROLE=`` via its
        # ``/etc/spatiumddi-host/role-config`` bind mount (#272 Phase
        # 1's self-bootstrap endpoint gates on that match). Pairing
        # codes are single-use + 15 min TTL, so a non-root shell on
        # the host already has access via ``sudo`` and the looser
        # mode isn't a meaningful exfiltration vector. firstboot
        # transcribes the value into ``/etc/spatiumddi/.env`` (also
        # mode 0644) on first boot anyway.
        chmod 0644 "$MOUNT/etc/spatiumddi/role-config"

        # Phase 11 (#183) — pre-bake the per-role node labels at
        # install time so the appliance chart's DaemonSets +
        # umbrella chart's control-plane Deployments schedule at
        # first boot without waiting for the supervisor pod to
        # come up + apply labels via its heartbeat reconciler.
        # The supervisor (now running on every variant per #272
        # Phase 1) maintains the labels going forward.
        #
        # IMPORTANT: k3s ``config.yaml.d/*`` drop-ins REPLACE (not
        # append to) list-valued keys from the main ``config.yaml``,
        # so we must re-list the base ``spatium.io/role=appliance``
        # label here. Without it, the chart's
        # ``global.nodeSelector: {spatium.io/role: appliance}``
        # default wouldn't match — DaemonSets compute DESIRED=0 and
        # nothing schedules.
        mkdir -p "$MOUNT/etc/rancher/k3s/config.yaml.d"
        if [ "$ROLE" = "control-plane" ]; then
            # control-plane runs ONLY the umbrella control-plane
            # workloads (api / frontend / worker / beat / postgres /
            # redis) at install time. DNS / DHCP are NOT enabled by
            # default (#272) — the operator turns them on per node via
            # the Fleet role toggle, so DNS/DHCP are a deliberate fleet
            # decision rather than a silent install-time default. Baked
            # unconditionally so the umbrella pods can schedule before
            # the supervisor pod itself is healthy.
            cat > "$MOUNT/etc/rancher/k3s/config.yaml.d/spatium-roles.yaml" <<EOF
# Auto-generated by spatium-install for ROLE=control-plane.
# #272 — supervisor reconciles these on every heartbeat; install-time
# bake is the boot-up bootstrap so pods schedule before the supervisor
# is healthy. DNS/DHCP are enabled later via the Fleet role toggle.
node-label:
  - spatium.io/role=appliance
  - spatium.io/role-control-plane=true
EOF
            chmod 0644 "$MOUNT/etc/rancher/k3s/config.yaml.d/spatium-roles.yaml"
        fi
        # ROLE=appliance leaves the role-label drop-in absent; the
        # supervisor applies role-* labels dynamically via the
        # heartbeat-driven role-assignment flow.

        # Issue #302 — k3s pod + service CIDR drop-in. ALWAYS written,
        # even on defaults, so the values are explicit on disk + a
        # future operator editing /etc/rancher/k3s/config.yaml.d/
        # spatium-cidrs.yaml sees what's in effect (instead of having
        # to grep the upstream k3s default elsewhere). Drop-in form
        # rather than editing the main config.yaml so the in-tree
        # config.yaml stays operator-readable + the install-time
        # choices are isolated in their own file.
        #
        # cluster-dns is derived from the service CIDR base + 10 —
        # k3s + kube-dns convention. The coredns Deployment binds to
        # this IP at startup; changing it post-install requires a
        # coredns restart and is documented as "reinstall" today.
        local cluster_dns_ip
        cluster_dns_ip=$(_cluster_dns_ip_from_svc_cidr "$K3S_SERVICE_CIDR")
        cat > "$MOUNT/etc/rancher/k3s/config.yaml.d/spatium-cidrs.yaml" <<EOF
# Auto-generated by spatium-install (issue #302) — operator-chosen
# k3s pod + service CIDRs from the install wizard. Values default to
# k3s upstream defaults (10.42.0.0/16 / 10.43.0.0/16) unless the
# operator overrode them on an installation where the LAN collided.
#
# These CANNOT be changed in-place — k3s does not support live CIDR
# migration. Reinstall is required to change them (the partition
# layout permits keeping /var across reinstalls; data + Postgres
# state on the persistent volume survive).
cluster-cidr: $K3S_POD_CIDR
service-cidr: $K3S_SERVICE_CIDR
cluster-dns: $cluster_dns_ip
EOF
        chmod 0644 "$MOUNT/etc/rancher/k3s/config.yaml.d/spatium-cidrs.yaml"
        log "k3s CIDRs: pod=$K3S_POD_CIDR svc=$K3S_SERVICE_CIDR dns=$cluster_dns_ip"

        cat > "$MOUNT/etc/hosts" <<EOF
127.0.0.1 localhost
127.0.1.1 $HOSTNAME
::1 ip6-localhost ip6-loopback
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
EOF

        # Timezone
        if [ -e "/usr/share/zoneinfo/$TIMEZONE" ]; then
            ln -sf "/usr/share/zoneinfo/$TIMEZONE" "$MOUNT/etc/localtime"
            echo "$TIMEZONE" > "$MOUNT/etc/timezone"
        else
            log "WARN: timezone $TIMEZONE not found, defaulting to UTC"
            ln -sf "/usr/share/zoneinfo/UTC" "$MOUNT/etc/localtime"
            echo "UTC" > "$MOUNT/etc/timezone"
        fi

        # Static-IP config — issue #276. The NetworkManager keyfile is
        # NOT written here anymore; spatium-etc-render materializes it
        # from STATE's spatium-config.yaml (network_* keys, seeded
        # above) on every boot, before NetworkManager starts. That
        # makes the static config survive a /var factory reset (STATE
        # outlives /var) and keeps a single source of truth. NM
        # auto-DHCPs every ethernet interface by default, so dhcp mode
        # needs no keyfile at all.

        echo "XXX"; echo "75"; echo "Creating admin user..."; echo "XXX"
        # Bind /proc /sys /dev for chroot operations.
        for d in proc sys dev; do
            mount --bind "/$d" "$MOUNT/$d"
        done

        # User + password. -m creates home; -G adds to sudo only.
        # (Issue #183 Phase 7 — no docker group on the appliance.)
        chroot "$MOUNT" useradd -m -G sudo -s /bin/bash "$ADMIN_USER" \
            >> "$INSTALL_LOG" 2>&1 || true
        # Set the admin + root passwords with tracing OFF so the
        # plaintext / hash never lands in the set -x trace log. A
        # preseed can supply a crypt(3) hash (ADMIN_PASSWORD_HASH) via
        # `chpasswd -e` instead of the plaintext (#549); the interactive
        # path always uses the plaintext ADMIN_PASSWORD.
        { set +x; } 2>/dev/null
        if [ -n "$ADMIN_PASSWORD_HASH" ]; then
            echo "$ADMIN_USER:$ADMIN_PASSWORD_HASH" | chroot "$MOUNT" chpasswd -e \
                >> "$INSTALL_LOG" 2>&1
            echo "root:$ADMIN_PASSWORD_HASH" | chroot "$MOUNT" chpasswd -e \
                >> "$INSTALL_LOG" 2>&1
        else
            echo "$ADMIN_USER:$ADMIN_PASSWORD" | chroot "$MOUNT" chpasswd \
                >> "$INSTALL_LOG" 2>&1
            echo "root:$ADMIN_PASSWORD" | chroot "$MOUNT" chpasswd \
                >> "$INSTALL_LOG" 2>&1
        fi
        set -x

        # Disable cloud-init on the installed system (we configured
        # everything ourselves; cloud-init would just sit waiting for a
        # datasource that isn't there).
        chroot "$MOUNT" systemctl mask \
            cloud-init.service cloud-init-local.service \
            cloud-config.service cloud-final.service \
            >> "$INSTALL_LOG" 2>&1 || true

        echo "XXX"; echo "78"; echo "Installing kernel into /boot..."; echo "XXX"
        # mkosi strips /boot from the rootfs during image build —
        # it stages the kernel and initrd as separate output files
        # for its own bootable image, then deletes them from /boot.
        # The rsync above brought across an empty /boot, so we need
        # to put the kernel binary back before update-grub can scan
        # for boot menu entries.
        local KVER
        KVER=$(ls "$MOUNT/lib/modules" 2>/dev/null | head -1)
        if [ -z "$KVER" ]; then
            log "ERROR: no /lib/modules in target — rsync didn't copy modules?"
            exit 1
        fi
        log "Target kernel version: $KVER"

        local LIVE_KERNEL=""
        for path in /run/live/medium/live/vmlinuz \
                    /lib/live/mount/medium/live/vmlinuz \
                    /run/live/medium/live/vmlinuz1 \
                    /lib/live/mount/medium/live/vmlinuz1; do
            [ -f "$path" ] && LIVE_KERNEL="$path" && break
        done
        if [ -z "$LIVE_KERNEL" ]; then
            log "ERROR: couldn't find live kernel binary to install"
            ls /run/live/medium/live/ >> "$INSTALL_LOG" 2>&1 || true
            ls /lib/live/mount/medium/live/ >> "$INSTALL_LOG" 2>&1 || true
            exit 1
        fi
        log "Copying $LIVE_KERNEL -> /boot/vmlinuz-$KVER"
        install -m 0644 "$LIVE_KERNEL" "$MOUNT/boot/vmlinuz-$KVER"
        ln -sf "vmlinuz-$KVER" "$MOUNT/boot/vmlinuz"
        # Phase 8c — initrd.img symlink alongside vmlinuz so grub.cfg
        # can reference stable paths regardless of kernel version. The
        # symlink target is created by update-initramfs below.
        ln -sf "initrd.img-$KVER" "$MOUNT/boot/initrd.img"

        echo "XXX"; echo "80"; echo "Configuring initramfs (virtio + storage modules)..."; echo "XXX"
        # Force the storage / virtio drivers into the initrd so the
        # installed kernel can find its root partition. MODULES=most
        # is the Debian default but is overly conservative on slim
        # cloud-amd64 — explicit module list guarantees they're in.
        # Without virtio_blk the kernel panics at boot with
        # "VFS: Unable to mount root fs on unknown-block(0,0)" on
        # any VM hypervisor.
        sed -i 's/^MODULES=.*/MODULES=most/' \
            "$MOUNT/etc/initramfs-tools/initramfs.conf" 2>/dev/null || true
        cat > "$MOUNT/etc/initramfs-tools/modules" <<'EOF'
# Forced into the initrd by spatium-install for VM compatibility.
virtio
virtio_pci
virtio_blk
virtio_scsi
virtio_net
virtio_ring
ext4
EOF

        echo "XXX"; echo "82"; echo "Regenerating initrd for disk boot..."; echo "XXX"
        # live-tools dpkg-diverts /usr/sbin/update-initramfs into a
        # no-op symlink that points at /usr/bin/live-update-initramfs
        # (the live-update-initramfs binary prints "I: update-initramfs
        # is disabled (live system is running...)" and exits 0). The
        # rsync'd rootfs inherits that diversion, so a naive
        # `chroot $MOUNT update-initramfs` is silently the no-op and
        # /boot/initrd.img-<kver> never lands. Fix in three steps:
        # (1) `rm` the live-tools symlink at /usr/sbin/update-initramfs.
        #     A bare `dpkg-divert --rename --remove` errors with
        #     "rename involves overwriting ... with different file ...
        #     not allowed" because the symlink is in the way.
        # (2) `dpkg-divert --rename --remove` then moves the parked
        #     /usr/sbin/update-initramfs.orig.initramfs-tools back
        #     into /usr/sbin/update-initramfs cleanly.
        # (3) update-initramfs is now the real binary and future
        #     kernel upgrades on the installed system regenerate
        #     initrds normally.
        log "Undiverting update-initramfs (live-tools shadowed it as a no-op)"
        chroot "$MOUNT" rm -f /usr/sbin/update-initramfs \
            >> "$INSTALL_LOG" 2>&1 || true
        chroot "$MOUNT" /usr/bin/dpkg-divert --rename --remove \
            /usr/sbin/update-initramfs >> "$INSTALL_LOG" 2>&1 || true

        chroot "$MOUNT" env \
            PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
            /usr/sbin/update-initramfs -c -k "$KVER" \
            >> "$INSTALL_LOG" 2>&1

        # Verify the initrd actually landed. The wrap-iso pipeline
        # to whiptail --gauge has surprised us before by swallowing
        # the failure (subshell + pipefail interactions); on the
        # previous install attempt update-initramfs silently failed
        # and the installed system grub then couldn't find
        # /boot/initrd.img-<kver>.
        if [ ! -f "$MOUNT/boot/initrd.img-$KVER" ]; then
            log "ERROR: update-initramfs did NOT produce /boot/initrd.img-$KVER"
            log "Contents of $MOUNT/boot:"
            ls -la "$MOUNT/boot" >> "$INSTALL_LOG" 2>&1
            log "End of install log — see above for update-initramfs output."
            exit 1
        fi
        log "initrd written: $(ls -lh "$MOUNT/boot/initrd.img-$KVER" | awk '{print $5}')"
        ln -sf "initrd.img-$KVER" "$MOUNT/boot/initrd.img"

        echo "XXX"; echo "85"; echo "Writing GRUB config (Phase 8c A/B + boot counting)..."; echo "XXX"
        # GRUB still needs the slot UUIDs for `search --fs-uuid` (so
        # it can find each slot's /boot/vmlinuz regardless of disk
        # ordering) and `root=UUID=…` on the kernel cmdline. fstab no
        # longer carries them (Phase 8a-7 — image-baseline fstab uses
        # LABEL= only); grub.cfg keeps using per-slot UUIDs because
        # it's WHERE the boot menu lives + the menuentries are
        # per-slot anyway.
        local ROOT_A_UUID ROOT_B_UUID
        ROOT_A_UUID=$(blkid -s UUID -o value "$ROOT_A")
        ROOT_B_UUID=$(blkid -s UUID -o value "$ROOT_B")
        # #554 — guard against an empty UUID (blkid racing the just-created
        # filesystem). An empty value renders ``root=UUID=`` into grub.cfg —
        # valid syntax that grub-script-check accepts but that produces an
        # unbootable slot. Settle udev + retry once before giving up.
        if [ -z "$ROOT_A_UUID" ] || [ -z "$ROOT_B_UUID" ]; then
            udevadm settle 2>/dev/null || true
            [ -z "$ROOT_A_UUID" ] && ROOT_A_UUID=$(blkid -s UUID -o value "$ROOT_A")
            [ -z "$ROOT_B_UUID" ] && ROOT_B_UUID=$(blkid -s UUID -o value "$ROOT_B")
        fi
        if [ -z "$ROOT_A_UUID" ] || [ -z "$ROOT_B_UUID" ]; then
            log "ERROR: could not read slot filesystem UUIDs (A=$ROOT_A_UUID B=$ROOT_B_UUID) — refusing to render grub with an empty root=UUID="
            exit 1
        fi

        # Write /etc/default/grub explicitly so future `update-grub`
        # runs (e.g. on kernel upgrade) get the same cmdline. We
        # don't rely on update-grub at install time — we write
        # grub.cfg directly below — but installed-system tooling
        # will read this file later.
        cat > "$MOUNT/etc/default/grub" <<EOF
GRUB_DEFAULT=saved
GRUB_TIMEOUT=3
GRUB_DISTRIBUTOR="SpatiumDDI"
GRUB_SAVEDEFAULT=true
# Issue #136: do NOT hide boot output ("quiet" / show_status=false).
# spatium-console.service claims tty1 seconds after kernel boot and
# overpaints whatever was there, so the brief visible boot text only
# matters when something is wrong (a panic, a missed module, plymouth
# eating keystrokes — all silently undebuggable otherwise).
GRUB_CMDLINE_LINUX_DEFAULT="loglevel=3 audit=0"
GRUB_CMDLINE_LINUX="console=tty0 console=ttyS0,115200n8"
GRUB_TERMINAL_INPUT="console serial"
GRUB_TERMINAL_OUTPUT="console serial"
GRUB_SERIAL_COMMAND="serial --unit=0 --speed=115200"
GRUB_DISABLE_OS_PROBER=true
GRUB_DISABLE_LINUX_UUID=false
EOF

        # Phase 8c — grub.cfg + grubenv on the ESP (/boot/efi/grub/),
        # NOT on each slot's /boot/grub/. Reasons:
        #   * ESP is shared between slots → single source of truth for
        #     the boot menu. spatium-upgrade-slot doesn't need to keep
        #     two grub.cfg copies in sync.
        #   * grub-reboot / grub-set-default write to grubenv on the
        #     same filesystem as grub.cfg — keeping both on ESP means
        #     they survive verbatim across slot swaps.
        #   * If an operator wipes /var, the boot menu still works
        #     (it's on the ESP, untouched).
        #
        # Two slot menuentries with --id=slot_a / slot_b. default reads
        # ${saved_entry} from grubenv. spatiumddi-firstboot.service
        # commits saved_entry via grub-set-default once the new slot
        # passes /health/live. grub-reboot from spatium-upgrade-slot
        # is the one-shot "try this slot once" mechanism.
        #
        # APPLIANCE_VERSION_LABEL feeds the menuentry titles so the
        # grub menu shows "SpatiumDDI Appliance <ver> (slot A)" instead
        # of the bare slot letter. Both slots get the same version at
        # install time (they're identical copies after the rsync at
        # line 1060); spatium-upgrade-slot apply re-stamps the
        # inactive slot's title after each dd via _patch_grub_cfg_slot_
        # _label so the menu stays accurate across upgrades.
        local APPLIANCE_VERSION_LABEL=""
        if [ -f "$MOUNT/etc/spatiumddi/appliance-release" ]; then
            APPLIANCE_VERSION_LABEL=$(awk -F= '/^APPLIANCE_VERSION=/{
                gsub(/^"|"$|^'\''|'\''$/, "", $2); print $2; exit
            }' "$MOUNT/etc/spatiumddi/appliance-release" || true)
        fi
        local SLOT_TITLE_PREFIX="SpatiumDDI Appliance"
        if [ -n "$APPLIANCE_VERSION_LABEL" ]; then
            SLOT_TITLE_PREFIX="SpatiumDDI Appliance $APPLIANCE_VERSION_LABEL"
        fi
        mkdir -p "$MOUNT/boot/efi/grub"
        # #395 — grub.cfg is now rendered by spatium-grub-render (one source of
        # truth for the menu, shared with the firstboot reconcile and
        # spatium-upgrade-slot apply). The renderer runs in a chroot so it uses
        # the rootfs's own grub-script-check for syntax validation. Both UUIDs
        # come from the freshly-formatted partitions (blkid'd above); the version
        # label seeds both slot titles (root_B is an rsync clone of root_A at
        # install, so both slots have the same version at this point).
        chroot "$MOUNT" /usr/local/bin/spatium-grub-render \
            --install-root / \
            --root-a-uuid "$ROOT_A_UUID" \
            --root-b-uuid "$ROOT_B_UUID" \
            --version-label "$APPLIANCE_VERSION_LABEL" \
            >> "$INSTALL_LOG" 2>&1
        # Seed grubenv with default + saved_entry pointing at slot_a so
        # the very first boot lands on slot_a unambiguously. grub-editenv
        # creates the file with the right size (1024 bytes, zero-padded).
        chroot "$MOUNT" /usr/bin/grub-editenv /boot/efi/grub/grubenv set saved_entry=slot_a \
            >> "$INSTALL_LOG" 2>&1
        # Seed the verbose-boot toggle OFF (quiet boot + dashboard) so the
        # menuentry's ${spatium_verbose} conditional resolves to the default
        # branch from the very first boot. The Fleet UI flips it to 1 later via
        # spatiumddi-verbose-boot-reload.
        chroot "$MOUNT" /usr/bin/grub-editenv /boot/efi/grub/grubenv set spatium_verbose=0 \
            >> "$INSTALL_LOG" 2>&1

        echo "XXX"; echo "88"; echo "Installing bootloader (BIOS + UEFI to ESP)..."; echo "XXX"
        # Use --boot-directory=/boot/efi so BOTH BIOS and UEFI grub
        # read their config (and grubenv) from the ESP. Without this,
        # BIOS grub embeds slot_a's UUID + /boot/grub path into
        # core.img — meaning a damaged slot_a breaks the boot menu
        # even when slot_b is healthy.
        chroot "$MOUNT" /usr/sbin/grub-install --target=i386-pc \
            --boot-directory=/boot/efi \
            "$TARGET_DISK" >> "$INSTALL_LOG" 2>&1
        chroot "$MOUNT" /usr/sbin/grub-install --target=x86_64-efi \
            --efi-directory=/boot/efi \
            --boot-directory=/boot/efi \
            --bootloader-id=SPATIUMDDI \
            --removable \
            >> "$INSTALL_LOG" 2>&1 || true

        echo "XXX"; echo "93"; echo "Cloning root_A → root_B (slot redundancy)..."; echo "XXX"
        # Phase 8c — install BOTH slots with the same content so an
        # operator can `spatium-upgrade-slot set-next-boot slot_b`
        # immediately after install. Without this, root_B is mkfs'd
        # but empty — the first set-next-boot fails at the grub prompt
        # with "no such device: <root_B-UUID>" and "file /boot/vmlinuz
        # not found", leaving the system stuck at the grub menu.
        #
        # Source: /target with the overlay /etc + var/home/root binds
        # mounted. We rsync the merged view of /etc (so root_B's
        # underlying /etc has the same hostname/fstab as root_A's
        # snapshot did at install) but skip the mount-targets for
        # /var, /home, /root, /boot/efi (those are bind/auto-mounted
        # at runtime, root_B doesn't carry their content).
        mkdir -p /mnt/spatium-root-b
        mount "$ROOT_B" /mnt/spatium-root-b
        rsync -aAXH \
            --exclude="/var/*" \
            --exclude="/home/*" \
            --exclude="/root/*" \
            --exclude="/boot/efi/*" \
            --exclude="/dev/*" \
            --exclude="/proc/*" \
            --exclude="/sys/*" \
            --exclude="/tmp/*" \
            --exclude="/run/*" \
            --exclude="/mnt/*" \
            "$MOUNT/" /mnt/spatium-root-b/ >> "$INSTALL_LOG" 2>&1
        # rsync excludes ./var/* but it can still create the empty
        # /var dir — make sure all the mount-points exist as empty
        # directories on root_B so the boot-time mount units succeed.
        mkdir -p /mnt/spatium-root-b/var /mnt/spatium-root-b/home \
                 /mnt/spatium-root-b/root /mnt/spatium-root-b/boot/efi
        umount /mnt/spatium-root-b 2>/dev/null || umount -l /mnt/spatium-root-b 2>/dev/null || true
        rmdir /mnt/spatium-root-b 2>/dev/null || true

        echo "XXX"; echo "95"; echo "Unmounting..."; echo "XXX"
        for d in dev sys proc; do
            umount "$MOUNT/$d" 2>/dev/null || true
        done
        # #554 — these cleanup unmounts run AFTER the install is complete,
        # under ``set -e``. A single busy mount (e.g. something still holding
        # /var) would abort do_install → the EXIT trap fires → the reboot
        # below never runs, showing "Installer exited with status N" after a
        # SUCCESSFUL install. Make each best-effort with a lazy-unmount
        # fallback; the imminent reboot clears anything still held.
        # Phase 8a unmount order matters:
        #   1. /home, /root            — bind mounts onto /var subdirs
        #   2. /etc (overlay)          — upper is on /var, release first
        #   3. /var/lib/spatium-state  — STATE partition, mounted under
        #                                /var so release before /var (#276)
        #   4. /var partition          — after /etc overlay + binds + STATE
        #   5. root_A                  — last
        for mp in \
            "$MOUNT/boot/efi" \
            "$MOUNT/home" \
            "$MOUNT/root" \
            "$MOUNT/etc" \
            "$MOUNT/var/lib/spatium-state" \
            "$MOUNT/var" \
            "$MOUNT"; do
            umount "$mp" 2>/dev/null || umount -l "$mp" 2>/dev/null || true
        done
        sync

        echo "XXX"; echo "100"; echo "Done."; echo "XXX"
        sleep 1
    } | whiptail --backtitle "$BACKTITLE" --title "Installing SpatiumDDI" \
        --gauge "Starting installation…" 12 76 0
    # Notes on the --gauge args:
    #   * Initial text MUST be non-empty. newt-based whiptail (Debian)
    #     skips drawing the message line entirely when the initial text
    #     is "", and subsequent XXX/N/message/XXX update blocks then
    #     don't bring it back. The operator sees only the % bar and no
    #     "Creating admin user" / "Installing bootloader" copy.
    #   * Height 12 (was 10) gives enough vertical space for a wrapped
    #     line — a few of the step messages run ~50 chars and on the
    #     fbcon=font:VGA8x8 console they can wrap before width=70 fits.
    #   * Width 76 (was 70) for the same wrap-headroom reason.

    # Best-effort eject of the install media BEFORE the operator
    # confirms reboot. Real CD-ROM drives obviously unmount and pop
    # the tray; QEMU/Proxmox virtual CD-ROMs honor the guest's ATA
    # EJECT — the device stays present in the VM but the ISO is
    # unmapped, so even if BIOS boot order still prefers CD it gets
    # "no media" and falls through to the disk. Errors are
    # ignored: ejecting a USB stick from inside the running guest
    # can't actually disconnect it electrically; the message below
    # tells the operator to pull it manually.
    for dev in /dev/sr0 /dev/sr1 /dev/cdrom; do
        [ -b "$dev" ] || continue
        eject "$dev" >> "$INSTALL_LOG" 2>&1 || true
    done

    # Title kept short (4 chars) so it doesn't collide with the 36-char
    # BACKTITLE on the dialog top frame — whiptail renders backtitle on
    # row 0 + dialog title on the immediately-adjacent dialog top
    # border, and overlong combined widths cause the title to overflow
    # into the backtitle (visible as e.g. "0.1.0ation complete").
    #
    # No inner box-drawing in the body: whiptail's own dialog frame
    # is the visual container, an inner ASCII box renders inconsistently
    # across console fonts (right edge alignment depends on each
    # content line being padded to the exact same column, which is
    # fragile + ugly) and the console font on the live ISO doesn't
    # render Unicode box-drawing chars at all. Plain indented text +
    # the `*** … ***` attention rule scans cleanly on tty1, in serial
    # consoles, and over SSH.
    whiptail --backtitle "$BACKTITLE" --title "Done" \
        --msgbox "\
SpatiumDDI is installed on $TARGET_DISK.


   *** REMOVE THE INSTALL MEDIA before the reboot ***

   Otherwise the BIOS will boot back into this installer.

      Virtual:   detach the ISO from the VM's CD-ROM drive
                 Proxmox: Hardware -> CD/DVD -> 'Do not use'
      Physical:  unplug the USB stick

   The installer already issued an ATA EJECT - most hypervisors
   honor it and the ISO is already unmapped, but detach it from
   the VM config too so it doesn't reattach on the next boot.


First boot of the installed system takes 2-5 min while it pulls
the SpatiumDDI container images.

   Web UI:  http://<appliance IP>/
   Login:   admin / admin   (change forced on first login)

Press OK to reboot." 24 72

    log "Install complete. Rebooting."
    systemctl reboot
}

# ── Headless preseed (issue #549) ──────────────────────────────────────────────

# Fetch a URL to $2 with a bounded retry loop — the installer wizard can
# reach discover_preseed before NetworkManager has finished DHCP, so a
# single curl would lose the race and drop a URL-preseeded fleet box to
# the interactive wizard. Retry ~6× over ~30 s (only the cmdline-URL
# path pays this; file / CIDATA transports never call it). Returns 0 on
# success.
_fetch_preseed_url() {
    local url="$1" dest="$2" attempt
    for attempt in 1 2 3 4 5 6; do
        if curl -fsSL --max-time 20 "$url" -o "$dest" 2>>"$INSTALL_LOG"; then
            return 0
        fi
        log "Preseed: fetch attempt $attempt/6 for $url failed (network may still be coming up)"
        sleep 5
    done
    return 1
}

# Append a discovered candidate to the parallel arrays.
#   $1 local file path, $2 human source description, $3 kind
_add_preseed_cand() {
    PRESEED_CAND_FILE+=("$1")
    PRESEED_CAND_SRC+=("$2")
    PRESEED_CAND_KIND+=("$3")
}

# Collect every preseed answer-file candidate, in priority order, into
# the PRESEED_CAND_* arrays. Sources:
#   1. Kernel cmdline `spatium.preseed=<url|path>` (PXE/IPMI) — explicit.
#   2. A block device labelled CIDATA (NoCloud): spatium-preseed.yaml /
#      .yml (explicit) or a cloud-init user-data (opportunistic — only
#      used if it actually carries a spatium_preseed block). VM/Proxmox.
#   3. The live install medium / rootfs-baked spatium-preseed.yaml
#      (sneakernet / CI) — explicit.
# Returns 0 if at least one candidate was found; 1 otherwise.
discover_preseed() {
    local cmdval
    cmdval=$(sed -n 's/.*spatium\.preseed=\([^ ]*\).*/\1/p' /proc/cmdline 2>/dev/null)
    if [ -n "$cmdval" ]; then
        case "$cmdval" in
            http://*|https://*)
                local dest=/run/spatium-cand-cmdline.yaml
                if _fetch_preseed_url "$cmdval" "$dest"; then
                    _add_preseed_cand "$dest" "kernel cmdline URL $cmdval" explicit
                else
                    log "Preseed: gave up fetching $cmdval from cmdline after retries"
                fi
                ;;
            *)
                if [ -f "$cmdval" ]; then
                    _add_preseed_cand "$cmdval" "kernel cmdline path $cmdval" explicit
                else
                    log "Preseed: cmdline path $cmdval not found"
                fi
                ;;
        esac
    fi

    # NoCloud CIDATA volume(s). Case-insensitive label match; try a few
    # spellings operators use.
    local dev label
    for label in CIDATA cidata Cidata; do
        dev=$(blkid -L "$label" 2>/dev/null || true)
        [ -n "$dev" ] && break
    done
    if [ -n "$dev" ]; then
        local mnt=/run/spatium-cidata
        mkdir -p "$mnt"
        if mount -o ro "$dev" "$mnt" 2>>"$INSTALL_LOG"; then
            local cand kind dest i=0
            for cand in spatium-preseed.yaml spatium-preseed.yml user-data; do
                [ -f "$mnt/$cand" ] || continue
                case "$cand" in
                    user-data) kind=opportunistic ;;
                    *)         kind=explicit ;;
                esac
                # Copy off the volume before we umount it.
                dest="/run/spatium-cand-cidata-$i.yaml"
                i=$((i + 1))
                cp "$mnt/$cand" "$dest" 2>>"$INSTALL_LOG"
                _add_preseed_cand "$dest" "CIDATA volume $dev ($cand)" "$kind"
            done
            umount "$mnt" 2>>"$INSTALL_LOG" || true
        fi
    fi

    # Live install medium + rootfs-baked locations (all explicit).
    local path
    for path in \
        /run/live/medium/spatium-preseed.yaml \
        /lib/live/mount/medium/spatium-preseed.yaml \
        /spatium-preseed.yaml \
        /etc/spatium-preseed.yaml; do
        [ -f "$path" ] && _add_preseed_cand "$path" "$path" explicit
    done

    [ "${#PRESEED_CAND_FILE[@]}" -gt 0 ]
}

# Recompute FULLY_UNATTENDED — true only when EVERY field the wizard
# would prompt for is preseeded (so the run needs zero console input).
# Missing anything leaves it 0 and the wizard shows welcome + the final
# confirm around whatever prompts still fire.
compute_unattended() {
    FULLY_UNATTENDED=0
    [ -n "${PRESEED_HAS_ROLE:-}" ]      || return 0
    [ -n "${PRESEED_HAS_DISK:-}" ]      || return 0
    [ -n "${PRESEED_HAS_HOSTNAME:-}" ]  || return 0
    [ -n "${PRESEED_HAS_PASSWORD:-}" ]  || return 0
    [ -n "${PRESEED_HAS_NETWORK:-}" ]   || return 0
    [ -n "${PRESEED_HAS_TIMEZONE:-}" ]  || return 0
    [ -n "${PRESEED_HAS_K3S:-}" ]       || return 0
    if [ "$ROLE" = "appliance" ]; then
        [ -n "${PRESEED_HAS_CONTROL_URL:-}" ]  || return 0
        [ -n "${PRESEED_HAS_PAIRING_CODE:-}" ] || return 0
    fi
    FULLY_UNATTENDED=1
}

# Halt-loud helper — a preseed that WAS supplied but failed validation
# (or couldn't be parsed) must stop the unattended run with a clear
# message + non-zero exit, never silently pick a default on a wipe.
preseed_halt() {
    set +x
    clear
    cat <<EOF

============================================================
  SpatiumDDI headless install — PRESEED ERROR
============================================================

$1

The preseed answer file was found but could not be used, so
the install has stopped rather than guess a value on an
unattended disk wipe.

Fix the answer file and reboot the installer, or run
'spatium-install' from this shell to install interactively.

Source: ${PRESEED_SOURCE:-<unknown>}
Log:    $INSTALL_LOG
============================================================

EOF
    log "Preseed halt: $1"
    exit 1
}

# ── Offline preseed linter — `--check-preseed` (issue #581) ────────────────────
#
# Usage text, printed by `--help` (to stdout) and shared with the usage
# error path (which prints its own one-liner to stderr).
usage() {
    cat <<'EOF'
spatium-install — SpatiumDDI appliance disk installer

Usage:
  spatium-install
      Run the interactive install wizard (must be root). Also picks up a
      headless preseed answer file automatically when one is present
      (spatium.preseed= cmdline, a CIDATA seed, or a rootfs-baked
      spatium-preseed.yaml) — see docs for the format.

  spatium-install --check-preseed <preseed.yaml>
      Offline-lint a headless preseed answer file (issue #549 format)
      WITHOUT installing anything. Runs unprivileged, reads only the
      given file, and touches no disk / whiptail / /run. Reports every
      problem it finds in one pass. Exit status:
        0  the preseed is valid (a real headless install would accept it)
        1  the preseed is invalid (errors printed to stderr)
        2  usage error (missing / unreadable file)
      Machine-specific checks (does target_disk exist / clear the size
      floor on THIS box) are reported as warnings, so the same file lints
      identically on a dev laptop and the real appliance.

  spatium-install --help
      Show this help.
EOF
}

# Host-portable pre-flight for a #549 preseed answer file. It parses the
# file with the SAME helper the real headless install uses
# (spatium-preseed-parse) so the lint can never diverge from what an
# unattended boot actually accepts, then re-runs the interactive wizard's
# own rules (_validate_static_net + _k3s_cidr_error) against the resolved
# values.
#
# That second layer matters: the parser's built-in static-network check
# is looser than _validate_static_net (it does NOT enforce
# gateway-in-subnet or validate the DNS list). On a real install
# ask_network re-validates a preseeded static block and halts — but only
# at install time, after the operator has already committed the boot. The
# linter surfaces the same problem offline, before any disk is touched,
# on any machine — which is the whole point of a pre-flight.
check_preseed() {
    local file="$1"
    local -a errors=() warns=()
    local line

    local parser
    parser="$(dirname "$0")/spatium-preseed-parse"
    [ -f "$parser" ] || parser="/usr/local/bin/spatium-preseed-parse"
    if [ ! -f "$parser" ]; then
        echo "ERROR: spatium-preseed-parse not found next to $0 or in /usr/local/bin" >&2
        return 2
    fi

    # Reuse the real parser. Its two output files (non-secret env + secret
    # env) go to tempfiles we own and delete; the secret file may carry an
    # admin password / pairing code, so it's 0600.
    local tmp_env tmp_secret out rc
    tmp_env=$(mktemp 2>/dev/null) || { echo "ERROR: cannot create tempfile" >&2; return 2; }
    tmp_secret=$(mktemp 2>/dev/null) || { rm -f "$tmp_env"; echo "ERROR: cannot create tempfile" >&2; return 2; }
    chmod 0600 "$tmp_secret" 2>/dev/null || true

    out=$(python3 "$parser" "$file" "$tmp_env" "$tmp_secret" 2>&1)
    rc=$?

    case "$rc" in
        0) : ;;  # parsed OK — resolved values are in $tmp_env / $tmp_secret
        2)
            # A supplied field failed the parser's own validation. The
            # parser accumulates + prints EVERY such error already, one
            # per `  - ` line — lift them verbatim.
            while IFS= read -r line; do
                case "$line" in
                    "  - "*) errors+=("${line#  - }") ;;
                esac
            done <<<"$out"
            [ "${#errors[@]}" -eq 0 ] && errors+=("preseed validation failed: $out")
            ;;
        3) errors+=("preseed file is not valid YAML / could not be read: $out") ;;
        4) errors+=("no spatium preseed content — the file has no spatium_preseed block and no recognised preseed field; is this the right file?") ;;
        *) errors+=("unexpected spatium-preseed-parse error (rc=$rc): $out") ;;
    esac

    # Advisory parser NOTES (e.g. an absent target_disk, a bare sdX name)
    # become WARNINGS — they never fail the lint.
    while IFS= read -r line; do
        case "$line" in
            "NOTE: "*) warns+=("${line#NOTE: }") ;;
        esac
    done <<<"$out"

    local role_display="<interactive>" unattended="no"
    if [ "$rc" -eq 0 ]; then
        # Load the resolved values + PRESEED_HAS_* markers exactly as
        # load_preseed would, then apply the interactive wizard's rules on
        # top. shellcheck can't follow the runtime source.
        # shellcheck disable=SC1090
        [ -f "$tmp_env" ] && . "$tmp_env"
        # shellcheck disable=SC1090
        [ -f "$tmp_secret" ] && . "$tmp_secret"

        # Static network — reuse the interactive prompt's own helper,
        # which is stricter than the parser (gateway-in-subnet + DNS).
        if [ -n "${PRESEED_HAS_NETWORK:-}" ] && [ "${NET_MODE:-}" = "static" ]; then
            local nerr
            if ! nerr=$(_validate_static_net); then
                while IFS= read -r line; do
                    [ -n "$line" ] && errors+=("network: $line")
                done <<<"$nerr"
            fi
        fi

        # k3s CIDRs — reuse the shared _k3s_cidr_error core (belt-and-
        # braces: the parser already validates k3s, so this only fires if
        # the two implementations ever drift).
        if [ -n "${PRESEED_HAS_K3S:-}" ]; then
            local kerr
            kerr=$(_k3s_cidr_error "${K3S_POD_CIDR}" "${K3S_SERVICE_CIDR}")
            [ -n "$kerr" ] && errors+=("k3s: $kerr")
        fi

        [ -n "${PRESEED_HAS_ROLE:-}" ] && role_display="$ROLE"
        compute_unattended
        [ "$FULLY_UNATTENDED" = "1" ] && unattended="yes"
    fi

    rm -f "$tmp_env" "$tmp_secret"

    local i
    for ((i = 0; i < ${#warns[@]}; i++)); do
        echo "WARN: ${warns[$i]}"
    done

    if [ "${#errors[@]}" -gt 0 ]; then
        {
            echo ""
            echo "The preseed answer file failed validation:"
            for ((i = 0; i < ${#errors[@]}; i++)); do
                echo "  ERROR: ${errors[$i]}"
            done
        } >&2
        return 1
    fi

    echo "OK: $file is a valid spatium preseed (role=$role_display, fully-unattended=$unattended)."
    return 0
}

# Discover + parse a preseed, if present. Tries every discovered
# candidate in priority order; the first one that carries real preseed
# content is adopted. A candidate with a spatium block but an invalid
# field halts loudly; a candidate with NO preseed content (e.g. a plain
# cloud-init user-data) is skipped so it can't shadow a real preseed on
# a lower-priority source. On success sources the resolved wizard
# variables + PRESEED_HAS_* markers and sets PRESEED_ACTIVE=1.
load_preseed() {
    if ! discover_preseed; then
        log "No preseed answer file found — interactive install"
        return 0
    fi

    local i f src kind out rc chosen=""
    for i in "${!PRESEED_CAND_FILE[@]}"; do
        f="${PRESEED_CAND_FILE[$i]}"
        src="${PRESEED_CAND_SRC[$i]}"
        kind="${PRESEED_CAND_KIND[$i]}"
        # The answer file may carry a plaintext admin password / pairing
        # code — lock it down on the (tmpfs) live rootfs before parsing.
        chmod 0600 "$f" 2>/dev/null || true
        log "Preseed: trying candidate ($kind) $src -> $f"

        out=$(python3 /usr/local/bin/spatium-preseed-parse \
            "$f" "$PRESEED_ENV" "$PRESEED_SECRET_ENV" 2>&1)
        rc=$?
        printf '%s\n' "$out" >> "$INSTALL_LOG"
        case "$rc" in
            0)
                PRESEED_SOURCE="$src"
                chosen=1
                break
                ;;
            2)
                # Has a spatium block but a supplied field is invalid —
                # halt regardless of source kind (it IS an intended
                # preseed, just broken).
                PRESEED_SOURCE="$src"
                preseed_halt "Preseed validation failed:"$'\n\n'"$out"
                ;;
            3)
                # Malformed YAML. An explicit spatium-preseed.yaml / a
                # cmdline value the operator clearly meant as a preseed
                # halts; an opportunistic user-data that just happens to
                # be unparseable is not ours — skip it.
                if [ "$kind" = "explicit" ]; then
                    PRESEED_SOURCE="$src"
                    preseed_halt "Preseed file could not be parsed:"$'\n\n'"$out"
                fi
                log "Preseed: skipping unparseable opportunistic $src"
                ;;
            4)
                # Parsed fine but no spatium content (plain cloud-init
                # user-data). Skip to the next candidate.
                log "Preseed: $src has no spatium preseed content — trying next candidate"
                ;;
            *)
                PRESEED_SOURCE="$src"
                preseed_halt "Unexpected preseed parser error (rc=$rc):"$'\n\n'"$out"
                ;;
        esac
    done

    if [ -z "$chosen" ]; then
        log "Preseed: no candidate carried preseed content — interactive install"
        return 0
    fi
    log "Preseed source adopted: $PRESEED_SOURCE"

    # Source the resolved non-secret values (ROLE / HOSTNAME / TARGET_DISK
    # / NET_* / K3S_* / PRESEED_HAS_* markers). shellcheck can't follow
    # the runtime path.
    # shellcheck disable=SC1090
    [ -f "$PRESEED_ENV" ] && . "$PRESEED_ENV"
    # Secrets (admin password / hash, pairing code) with tracing OFF so
    # they never reach the set -x trace log.
    { set +x; } 2>/dev/null
    # shellcheck disable=SC1090
    [ -f "$PRESEED_SECRET_ENV" ] && . "$PRESEED_SECRET_ENV"
    set -x

    PRESEED_ACTIVE=1
    compute_unattended
    log "Preseed loaded: role=${ROLE} disk=${TARGET_DISK:-<interactive>} fully_unattended=$FULLY_UNATTENDED"
    return 0
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
    # Non-install command modes (issue #581). These run BEFORE the root
    # check so an operator can lint an answer file or read the help on any
    # workstation. Clear the on_failure EXIT trap first: its drop-to-shell
    # recovery is for the live installer, not a CLI that intentionally
    # exits non-zero.
    case "${1:-}" in
        -h|--help)
            trap - EXIT
            usage
            exit 0
            ;;
        --check-preseed)
            trap - EXIT
            if [ -z "${2:-}" ] || [ ! -f "${2:-}" ]; then
                echo "usage: spatium-install --check-preseed <preseed.yaml>" >&2
                exit 2
            fi
            check_preseed "$2"
            exit $?
            ;;
    esac

    if [ "$(id -u)" -ne 0 ]; then
        echo "Run as root." >&2
        exit 1
    fi

    # Headless preseed (issue #549) — if an answer file is present, load
    # + validate it first. Populated fields skip their prompt below; a
    # fully-preseeded run skips welcome + the final confirm too. A bad
    # preseed halts loudly here rather than falling through.
    load_preseed
    if [ "$PRESEED_ACTIVE" = "1" ]; then
        if [ "$FULLY_UNATTENDED" = "1" ]; then
            log "Preseed: fully unattended — no console interaction required"
        else
            log "Preseed: partial — prompting interactively for missing fields"
        fi
    fi

    # State-machine wizard. Each step is one function that returns:
    #   0 — operator pressed OK / Yes / made a valid selection
    #   1 — operator pressed Back (or Cancel/Esc on Welcome, which
    #       exits the wizard entirely via on_cancel).
    # Cancel on Welcome is the only exit-installer path; every other
    # screen's Cancel button is renamed "Back" and walks the wizard
    # back one step. ask_application_config is conditional on
    # ROLE=appliance — it returns 0 immediately for the control-plane
    # role so Back from confirm walks through it transparently to
    # ask_timezone.
    local step="welcome"
    while [ -n "$step" ]; do
        log "Wizard state: $step"
        case "$step" in
            welcome)
                # welcome only returns 0 — Cancel here calls on_cancel
                # which exec's a shell (never returns). That's the
                # explicit "I changed my mind, don't install" path.
                # Skipped entirely on a fully-unattended preseed run.
                if [ "$FULLY_UNATTENDED" != "1" ]; then
                    welcome
                fi
                step="ask_role"
                ;;
            ask_role)
                if ask_role; then step="pick_disk"; else step="welcome"; fi
                ;;
            pick_disk)
                if pick_disk; then step="confirm_partition_layout"; else step="ask_role"; fi
                ;;
            confirm_partition_layout)
                if confirm_partition_layout; then step="ask_hostname"; else step="pick_disk"; fi
                ;;
            ask_hostname)
                if ask_hostname; then step="ask_user_password"; else step="confirm_partition_layout"; fi
                ;;
            ask_user_password)
                if ask_user_password; then step="ask_network"; else step="ask_hostname"; fi
                ;;
            ask_network)
                if ask_network; then step="ask_timezone"; else step="ask_user_password"; fi
                ;;
            ask_timezone)
                if ask_timezone; then step="ask_k3s_cidrs"; else step="ask_network"; fi
                ;;
            ask_k3s_cidrs)
                # Issue #302 — operator picks (or accepts the defaults
                # for) the k3s pod + service CIDRs. Forward → application
                # role config; back → timezone.
                if ask_k3s_cidrs; then step="ask_application_config"; else step="ask_timezone"; fi
                ;;
            ask_application_config)
                # Returns 0 immediately when ROLE != application — so
                # forward navigation moves straight to confirm and
                # backward navigation from confirm walks through here
                # without showing any whiptail screen.
                if ask_application_config; then step="confirm"; else step="ask_k3s_cidrs"; fi
                ;;
            confirm)
                # Fully-unattended preseed skips the final confirm —
                # confirm_wipe:true in the answer file already authorised
                # the destructive install. A partial preseed still shows
                # it (the operator was prompted for something, so give
                # them the review screen).
                if [ "$FULLY_UNATTENDED" = "1" ]; then
                    step="do_install"
                elif confirm; then
                    step="do_install"
                else
                    # #554 — Back. ask_application_config returns 0 without
                    # showing a screen for every role EXCEPT appliance, so
                    # routing Back through it for a control-plane install
                    # bounced confirm→ask_application_config→confirm forever
                    # (the operator could never get back to hostname / tz /
                    # disk / CIDRs). Skip straight to ask_k3s_cidrs unless the
                    # appliance role, which has a real screen there.
                    if [ "$ROLE" = "appliance" ]; then
                        step="ask_application_config"
                    else
                        step="ask_k3s_cidrs"
                    fi
                fi
                ;;
            do_install)
                do_install
                step=""
                ;;
        esac
    done
}

on_failure() {
    local exit_code=$?
    [ "$exit_code" -eq 0 ] && exit 0
    set +x
    clear
    echo
    echo "Installer exited with status $exit_code"
    echo
    echo "-- Last 20 lines of $INSTALL_LOG --"
    tail -20 "$INSTALL_LOG" 2>/dev/null \
        || echo "  (install log empty or missing - script bailed before any log() call)"
    echo
    echo "-- Last 20 lines of /var/log/spatium-install-launch.log --"
    tail -20 /var/log/spatium-install-launch.log 2>/dev/null \
        || echo "  (launch log missing - bash didn't even parse the script)"
    echo
    echo "-- Last 30 lines of $TRACE_LOG --"
    tail -30 "$TRACE_LOG" 2>/dev/null \
        || echo "  (trace log empty - script bailed before set -x at line 51)"
    echo "------------------------------------------------------------------"
    echo
    if [ -r /var/log/spatium-live-ssh-password ]; then
        echo "Live-mode SSH (for log capture from a real terminal):"
        echo "  user:     root"
        echo "  password: $(cat /var/log/spatium-live-ssh-password)"
        echo "  address:  $(ip -4 -br addr 2>/dev/null | awk '$1!="lo" && $3!="" {print $3; exit}' || echo '?')"
        echo
    fi
    echo "Also useful from the shell:"
    echo "  journalctl -u spatium-install.service --no-pager"
    echo "  systemctl cat spatium-install.service"
    echo
    echo "Press Enter to drop to a root shell."
    echo "(From the shell you can re-run 'spatium-install' or 'reboot'.)"
    read -r _ || true
    exec /bin/bash --login
}
trap on_failure EXIT

main "$@"
