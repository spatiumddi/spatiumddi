# mkosi build outputs.
build/
*.raw
*.qcow2
*.vhd
*.vmdk
*.iso
*.tar.zst
*.manifest

# Generated cloud-init seed.
cloud-init/cidata.iso
cloud-init/user-data
cloud-init/meta-data

# mkosi caches.
.mkosi-*/
mkosi.cache/
mkosi.workspace/

# Build-time stamp written by .github/workflows/release.yml (CalVer)
# or by hand for local dev slot builds. Never tracked — committing
# a stale stamp would either get clobbered by the next CI run or
# ship as the real APPLIANCE_VERSION on a production cut.
mkosi.extra/etc/spatiumddi/appliance-release
